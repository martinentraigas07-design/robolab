// ──────────────────────────────────────────────────────────────────
// U0 EXT — PWM: Control de Brillo y Velocidad
// Pedagogía: señal PWM, duty cycle, analogWrite 0-255
// El mismo comando controla brillo de LED y velocidad de motor.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-pwm'] = {
  id: 'u0-pwm',
  name: 'U0.8 — PWM: Brillo y Velocidad',
  description: 'PWM (Pulse Width Modulation) es una señal que varía su tiempo en HIGH para controlar potencia. analogWrite(pin, 0-255) lo usa en Arduino. 0=apagado, 255=máximo.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: false,
    extLeds: [{pin:'D10',color:'#18cc60'}],
    description: 'El LED del canvas muestra brillo variable. El motor se ve en el overlay de motores (tab Código).',
  },
  sketch:
`// ━━━ U0.8 — PWM: Control de Potencia ━━━
// PWM = Pulse Width Modulation (Modulación por Ancho de Pulso)
//
// La señal PWM alterna entre HIGH y LOW muy rápido.
// El "duty cycle" es el porcentaje de tiempo en HIGH:
//   duty 0   = siempre LOW   = apagado
//   duty 127 = 50% HIGH      = mitad de potencia
//   duty 255 = siempre HIGH  = potencia máxima
//
// En Arduino: analogWrite(pin, 0-255)
// Funciona en pines marcados con ~ : D3, D5, D6, D9, D10, D11

#define LED   10   // ~ (PWM disponible)
#define PWMA   3   // ~ Motor A velocidad
#define STBY   6   // Driver enable
#define AIN1   5
#define AIN2   4

void setup() {
  Serial.begin(9600);
  pinMode(LED, OUTPUT);
  pinMode(STBY, OUTPUT); digitalWrite(STBY, HIGH);
  pinMode(PWMA, OUTPUT); pinMode(AIN1, OUTPUT); pinMode(AIN2, OUTPUT);
  digitalWrite(AIN1, HIGH); digitalWrite(AIN2, LOW); // adelante
  Serial.println("PWM listo — observá el LED y el motor overlay");
}

void loop() {
  // TODO 1: Subir el brillo del LED de 0 a 255 gradualmente
  // Tip: usá un bucle for con analogWrite(LED, i)
  // for (int i = 0; i <= 255; i++) {
  //   ???
  //   delay(10);
  // }


  // TODO 2: Bajar el brillo de 255 a 0
  // Tip: mismo bucle pero i-- (o i = 255 hasta 0)


  // TODO 3: Controlar la velocidad del Motor A igual que el LED
  // analogWrite(PWMA, velocidad) — probá 100, 150, 200, 255
  // ¿El motor y el LED cambian al mismo tiempo?


  Serial.println("Ciclo PWM completo");
  delay(200);
}`,
  objectives: [
    { id: 'obj-pwm-low',   label: 'PWM en valor bajo (0-100): LED/motor a baja potencia', required: true },
    { id: 'obj-pwm-high',  label: 'PWM en valor alto (200-255): LED/motor a alta potencia', required: true },
    { id: 'obj-pwm-sweep', label: 'Barrido progresivo: al menos 3 valores distintos de PWM', required: true },
    { id: 'obj-motor-pwm', label: 'Motor A con velocidad variable (PWM > 0 y < 255)', required: false },
  ],
  validate: function(vars, flags) {
    // Track PWM values seen on D10 (LED) — proxy for analogWrite calls
    // analogWrite to D10 sets value 0-255 in HAL
    const pins = (typeof eco !== 'undefined') ? eco.hal.getAllPins() : {};
    const d10val = pins['D10']?.value || 0;
    const mApwm  = vars.motorA_pwm || 0;
    // Accumulate distinct PWM bands seen
    const sf = S._synthState._flags;
    sf._pwm_bands = sf._pwm_bands || {};
    if (d10val > 0   && d10val <= 100)  sf._pwm_bands['low']  = true;
    if (d10val > 200 && d10val <= 255)  sf._pwm_bands['high'] = true;
    if (d10val > 100 && d10val <= 200)  sf._pwm_bands['mid']  = true;
    if (mApwm > 0    && mApwm < 255)    _synthFlag('motor_varied', true);
    const bands = Object.keys(sf._pwm_bands || {}).length;
    return {
      'obj-pwm-low':   !!(sf._pwm_bands && sf._pwm_bands['low']),
      'obj-pwm-high':  !!(sf._pwm_bands && sf._pwm_bands['high']),
      'obj-pwm-sweep': bands >= 2,
      'obj-motor-pwm': !!(flags.motor_varied),
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — Mapeo Analógico: map() y constrain()
// Pedagogía: convertir rangos, función map(), diseño de control
// El sensor controla el LED y el motor de forma proporcional.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-mapeo'] = {
  id: 'u0-mapeo',
  name: 'U0.9 — Mapeo Analógico: map() y constrain()',
  description: 'map(valor, entradaBaja, entradaAlta, salidaBaja, salidaAlta) convierte un rango a otro. Usalo para que el sensor Sharp controle el brillo del LED proporcionalmente.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: false,
    extLeds: [{pin:'D10',color:'#18cc60'}],
    description: 'Arrastrá el obstáculo rojo hacia el robot. El LED debe cambiar de brillo según la distancia.',
  },
  sketch:
`// ━━━ U0.9 — Mapeo Analógico ━━━
// El sensor Sharp devuelve 0-1023 (más cerca = valor más bajo).
// El LED acepta 0-255.
// Necesitamos "traducir" el rango del sensor al rango del LED.
//
// FUNCIÓN MAP:
//   map(valor, desde_min, desde_max, hacia_min, hacia_max)
//
// Ejemplo:
//   map(sensor, 0, 1023, 0, 255)
//   → si sensor=0    → resultado=0   (LED apagado)
//   → si sensor=512  → resultado=128 (LED medio)
//   → si sensor=1023 → resultado=255 (LED máximo)
//
// INVERSIÓN: el Sharp tiene valor ALTO cuando está LEJOS.
// Si queremos LED brillante cuando hay objeto CERCA:
//   map(sensor, 0, 1023, 255, 0)  ← ojo, los extremos están invertidos

#define SENSOR A0
#define LED    10
#define STBY   6
#define AIN1   5
#define AIN2   4
#define PWMA   3

void setup() {
  Serial.begin(9600);
  pinMode(LED, OUTPUT);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);
}

void loop() {
  int sensor = analogRead(SENSOR);

  // TODO 1: Mapeá el sensor al brillo del LED (invertido: cerca = más brillo)
  // int brillo = map(sensor, ???, ???, ???, ???);
  int brillo = ???;

  // TODO 2: Asegurate de que brillo esté en [0, 255]
  // brillo = constrain(brillo, 0, 255);
  brillo = constrain(???, 0, 255);

  // TODO 3: Aplicá el brillo al LED
  analogWrite(LED, brillo);

  // TODO 4 (opcional): Mapeá el sensor también a la velocidad del motor
  // int velocidad = map(sensor, ???, ???, ???, ???);
  // analogWrite(PWMA, constrain(velocidad, 0, 255));

  Serial.print("Sensor:"); Serial.print(sensor);
  Serial.print(" Brillo:"); Serial.println(brillo);
  delay(50);
}`,
  objectives: [
    { id: 'obj-sensor-read', label: 'Leer A0 y ejecutar el sketch', required: true },
    { id: 'obj-map-applied', label: 'LED cambia con la distancia (brillo variable según sensor)', required: true },
    { id: 'obj-constrain',   label: 'Brillo siempre en rango válido 0-255', required: true },
    { id: 'obj-motor-map',   label: 'Motor también controlado proporcionalmente por el sensor', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.sim_time > 200)  _synthFlag('sensor_read', true);
    // LED PWM changes with sensor — detect variation
    const pins = (typeof eco !== 'undefined') ? eco.hal.getAllPins() : {};
    const d10val = pins['D10']?.value || 0;
    const sf = S._synthState._flags;
    sf._led_vals = sf._led_vals || {};
    if (d10val > 0) sf._led_vals[Math.floor(d10val/30)] = true; // bucket by 30
    const ledVaries = Object.keys(sf._led_vals || {}).length >= 3;
    if (d10val >= 0 && d10val <= 255) _synthFlag('constrain_ok', true);
    if (vars.motorA_pwm > 0 && vars.motorA_fwd) _synthFlag('motor_mapped', true);
    return {
      'obj-sensor-read': !!(flags.sensor_read),
      'obj-map-applied': ledVaries,
      'obj-constrain':   !!(flags.constrain_ok),
      'obj-motor-map':   !!(flags.motor_mapped),
    };
  },
};


// ──────────────────────────────────────────────────────────────────
// U0 EXT — Movimiento Geométrico
// Pedagogía: tiempo como herramienta de control, figuras geométricas
// El robot puede trazar figuras si los tiempos son precisos.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-movimiento'] = {
  id: 'u0-movimiento',
  name: 'U0.10 — Movimiento Geométrico',
  description: 'El robot puede trazar figuras geométricas si controlás los tiempos con precisión. Avanzar recto + girar exactamente 90° + repetir 4 veces = cuadrado.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: null,
  sketch:
`// ━━━ U0.10 — Movimiento Geométrico ━━━
// El tiempo es tu herramienta de control.
// Si el robot avanza a velocidad constante:
//   distancia = velocidad × tiempo
// Si el robot gira:
//   ángulo depende del tiempo y la diferencia de velocidad entre ruedas.
//
// Con los valores de abajo el robot debería girar ~90°.
// En la simulación podés ajustar los tiempos exactos.

#define PWMA  3
#define AIN1  5
#define AIN2  4
#define PWMB  9
#define BIN1  7
#define BIN2  8
#define STBY  6

#define VEL_AVZ  180   // velocidad al avanzar
#define VEL_GIR  160   // velocidad al girar
#define T_AVANCE 800   // ms para avanzar un lado
#define T_GIRO   420   // ms para girar ~90° (ajustar según el robot)

void avanzar() {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,VEL_AVZ);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,VEL_AVZ);
}
void girarDerecha() {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,VEL_GIR);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,VEL_GIR);
}
void parar() {
  analogWrite(PWMA,0); analogWrite(PWMB,0);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
  delay(1000); // esperar antes de comenzar
}

void loop() {
  // TODO 1: Avanzar un lado del cuadrado
  // avanzar(); delay(T_AVANCE); parar(); delay(100);
  ???;

  // TODO 2: Girar 90° a la derecha
  // girarDerecha(); delay(T_GIRO); parar(); delay(100);
  ???;

  // TODO 3: Repetí TODO 1 y TODO 2 tres veces más para completar el cuadrado.
  // Tip: copiá el bloque avanzar+girar 3 veces más (total 4 lados)


  // DESAFÍO EXTRA: ¿Podés cambiar T_GIRO para hacer un triángulo?
  // Un triángulo equilátero gira 120° en cada vértice.
  // ¿Cuántos ms necesitás?

  Serial.println("Figura completada");
  delay(5000); // pausa antes de repetir
}`,
  objectives: [
    { id: 'obj-avance',    label: 'Robot avanza en línea recta (ambos motores forward)', required: true },
    { id: 'obj-giro',      label: 'Robot gira (motores en sentido opuesto)', required: true },
    { id: 'obj-secuencia', label: 'Secuencia avance+giro ejecutada al menos 2 veces', required: true },
    { id: 'obj-cuadrado',  label: 'Secuencia completa de 4 lados + 4 giros', required: true },
    { id: 'obj-extra',     label: 'Experimentar con ángulo distinto (triángulo u otra figura)', required: false },
  ],
  validate: function(vars, flags) {
    // Detect forward movement (both motors same direction)
    if (vars.motorA_fwd && vars.motorB_fwd && vars.motorA_pwm > 0) _synthFlag('avance_ok', true);
    // Detect turn (motors in opposite directions)
    if ((vars.motorA_fwd && vars.motorB_rev) || (vars.motorA_rev && vars.motorB_fwd)) {
      _synthFlag('giro_ok', true);
    }
    // Count avance+giro sequences
    const sf = S._synthState._flags;
    if (!sf._last_state) sf._last_state = 'idle';
    if (vars.motorA_fwd && vars.motorB_fwd && sf._last_state !== 'fwd') {
      sf._last_state = 'fwd';
    } else if ((vars.motorA_fwd && !vars.motorB_fwd) || (!vars.motorA_fwd && vars.motorB_fwd)) {
      if (sf._last_state === 'fwd') {
        sf._seq_count = (sf._seq_count || 0) + 1;
        sf._last_state = 'turn';
      }
    } else if (vars.motorA_pwm === 0 && vars.motorB_pwm === 0) {
      if (sf._last_state === 'turn') sf._last_state = 'stopped';
    }
    const seqs = sf._seq_count || 0;
    return {
      'obj-avance':    !!(flags.avance_ok),
      'obj-giro':      !!(flags.giro_ok),
      'obj-secuencia': seqs >= 2,
      'obj-cuadrado':  seqs >= 4,
      'obj-extra':     seqs >= 6,
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — Evasión Completa
// Pedagogía: sistema reactivo completo, retroceder+girar, estados
// Primer robot que "decide" basándose en el ambiente.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-evasion'] = {
  id: 'u0-evasion',
  name: 'U0.11 — Evasión: Robot Reactivo Completo',
  description: 'El robot avanza, detecta un obstáculo con el Sharp IR, retrocede, gira y sigue. Es el primer comportamiento reactivo completo: percibir → decidir → actuar.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: null,
  sketch:
`// ━━━ U0.11 — Evasión Completa ━━━
// Arquitectura de un robot reactivo:
//
//   loop:
//     leer sensor
//     si hay obstáculo → maniobra de evasión
//     si no            → avanzar
//
// Maniobra de evasión:
//   1. Retroceder (salir del obstáculo)
//   2. Girar (cambiar dirección)
//   3. Continuar

#define PWMA    3
#define AIN1    5
#define AIN2    4
#define PWMB    9
#define BIN1    7
#define BIN2    8
#define STBY    6
#define SENSOR  A0
#define UMBRAL  400   // Sharp IR: < 400 → obstáculo cerca (~20cm)

void avanzar(int vel) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,vel);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,vel);
}
void retroceder(int vel) {
  // TODO 1: Completá esta función para que ambos motores vayan en reversa
  // Tip: AIN1=LOW, AIN2=HIGH para reversa en Motor A


}
void girar(int vel) {
  // TODO 2: Completá esta función para girar (Motor A fwd, Motor B rev)


}
void parar() {
  analogWrite(PWMA,0); analogWrite(PWMB,0);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sensor = analogRead(SENSOR);
  Serial.print("Sensor:"); Serial.print(sensor);

  if (sensor < UMBRAL) {
    // Obstáculo detectado — evadir
    Serial.println(" → EVASIÓN");

    // TODO 3: Completá la maniobra de evasión:
    // Paso 1: retroceder 300ms
    ???;

    // Paso 2: girar 400ms
    ???;

    // Paso 3: parar brevemente
    parar(); delay(100);

  } else {
    // Campo libre — avanzar
    Serial.println(" → AVANZANDO");

    // TODO 4: Avanzar a velocidad 180
    ???;
  }

  delay(30);  // frecuencia del bucle reactivo (~33Hz)
}`,
  objectives: [
    { id: 'obj-avance-libre', label: 'Robot avanza cuando no hay obstáculo', required: true },
    { id: 'obj-retrocede',    label: 'Robot retrocede al detectar obstáculo (A0 < 400)', required: true },
    { id: 'obj-gira',         label: 'Robot gira después de retroceder', required: true },
    { id: 'obj-ciclo',        label: 'Ciclo completo de evasión ≥ 2 veces (avanza → evade → avanza)', required: true },
    { id: 'obj-fluido',       label: 'Evasión fluida: retroceso + giro + avance sin pausa larga', required: false },
  ],
  validate: function(vars, flags) {
    // Forward when no obstacle
    if (vars.motorA_fwd && vars.motorB_fwd && vars.motorA_pwm > 0 && vars.a0_raw >= 400) {
      _synthFlag('avance_libre', true);
    }
    // Reverse when obstacle detected
    if (vars.motorA_rev && vars.motorB_rev && vars.a0_raw < 400) {
      _synthFlag('retrocede', true);
    }
    // Turn after reverse
    if (flags.retrocede && ((vars.motorA_fwd && vars.motorB_rev) || (vars.motorA_rev && vars.motorB_fwd))) {
      _synthFlag('gira_ok', true);
    }
    // Count full evasion cycles (avance_libre → retrocede → gira → avance_libre again)
    const sf = S._synthState._flags;
    if (!sf._evade_state) sf._evade_state = 'init';
    if (flags.avance_libre && sf._evade_state === 'init') sf._evade_state = 'moving';
    if (flags.retrocede && sf._evade_state === 'moving') sf._evade_state = 'evading';
    if (flags.avance_libre && sf._evade_state === 'evading') {
      sf._evade_state = 'moving';
      sf._cycles = (sf._cycles || 0) + 1;
    }
    // Fluent: check timing between evasion phases
    const cycles = sf._cycles || 0;
    return {
      'obj-avance-libre': !!(flags.avance_libre),
      'obj-retrocede':    !!(flags.retrocede),
      'obj-gira':         !!(flags.gira_ok),
      'obj-ciclo':        cycles >= 2,
      'obj-fluido':       cycles >= 3,
    };
  },
};


// ──────────────────────────────────────────────────────────────────
// U0 EXT — HC-SR04 Ultrasónico
// Pedagogía: medición activa por tiempo de vuelo, pulseIn, protocolo
// DIFERENCIA CLAVE vs Sharp IR:
//   Sharp IR = pasivo (siempre midiendo, leer con analogRead)
//   HC-SR04  = activo (el robot dispara, espera eco, mide tiempo)
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-ultrasonido'] = {
  id: 'u0-ultrasonido',
  name: 'U0.12 — HC-SR04: Sensor Ultrasónico',
  description: 'El HC-SR04 mide distancia por tiempo de vuelo del sonido. El robot dispara un pulso (TRIG), espera el eco (ECHO) y mide cuánto tardó. Diferente al Sharp IR que es pasivo.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: false, showHCSR04: true,
    extLeds: [{pin:'D10',color:'#18cc60'}],
    description: 'El cono azul-verde muestra el haz ultrasónico. La distancia medida aparece en cm sobre el cono.',
  },
  sketch:
`// ━━━ U0.12 — HC-SR04 Ultrasónico ━━━
// El HC-SR04 funciona por tiempo de vuelo del sonido:
//   1. TRIG: el robot envía un pulso de 10 microsegundos
//   2. ECHO: el sensor manda HIGH mientras espera el rebote
//   3. pulseIn() mide el tiempo en microsegundos
//   4. Convertir: cm = microsegundos / 58
//                (el sonido viaja a ~340 m/s → 29 us/cm ida y vuelta = 58 us/cm)
//
// DIFERENCIA vs Sharp IR:
//   Sharp IR = analogRead(A0) → un número, SIEMPRE disponible
//   HC-SR04  = secuencia TRIG→esperar→ECHO→calcular → ACTIVO

#define TRIG  12   // pin de disparo (D12)
#define ECHO  A3   // pin de eco (A3 en ROBOARD)
#define LED   10
#define UMBRAL_CM  20   // detección a 20cm

long medirDistancia() {
  // TODO 1: Generar pulso de trigger
  // El sensor necesita un pulso HIGH de 10 microsegundos en TRIG:
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);
  // ??? escribí HIGH en TRIG, esperá 10us, volvé a LOW


  // TODO 2: Medir el tiempo del eco con pulseIn
  // pulseIn(pin, HIGH) espera que el pin vaya a HIGH y mide cuánto dura
  long duracion = ???;   // pulseIn(ECHO, HIGH)

  // TODO 3: Convertir microsegundos a centímetros
  // Un valor de 0 significa sin eco (objeto muy lejos o muy cerca)
  if (duracion == 0) return 999;  // sin eco → muy lejos
  int cm = ???;   // duracion / 58
  return cm;
}

void setup() {
  Serial.begin(9600);
  // TODO 4: Configurar TRIG como OUTPUT, ECHO como INPUT, LED como OUTPUT
  // Tip: necesitás tres líneas de pinMode()
  ???;

}

void loop() {
  long distancia = medirDistancia();
  Serial.print("Distancia: "); Serial.print(distancia); Serial.println(" cm");

  // TODO 5: Si distancia < UMBRAL_CM, encender LED; si no, apagarlo


  delay(60);  // no medir más rápido que ~16ms (interferencia entre pulsos)
}`,
  objectives: [
    { id: 'obj-trig-pulse', label: 'Generar pulso TRIG de 10µs (digitalWrite + delayMicroseconds)', required: true },
    { id: 'obj-echo-read',  label: 'Leer duración del eco con pulseIn', required: true },
    { id: 'obj-distance-cm',label: 'Calcular y mostrar distancia en cm', required: true },
    { id: 'obj-led-detect', label: 'LED reacciona a distancia < 20cm', required: true },
    { id: 'obj-serial',     label: 'Imprimir distancia en Serial Monitor', required: false },
  ],
  validate: function(vars, flags) {
    // HC-SR04 distance comes from S._periph.hcsrDist (injected in simTick)
    const dist = vars.hcsr04_cm;
    if (dist !== null && dist !== undefined) {
      _synthFlag('echo_read', true);   // distance was measured
      _synthFlag('distance_cm', true); // cm calculated
      if (vars.sim_time > 200) _synthFlag('trig_pulse', true); // timing inferred
    }
    if (vars.hcsr04_near && vars.led_on) _synthFlag('led_detect', true);
    if (dist !== null && vars.sim_time > 500) _synthFlag('serial_ok', true);
    return {
      'obj-trig-pulse': !!(flags.trig_pulse),
      'obj-echo-read':  !!(flags.echo_read),
      'obj-distance-cm':!!(flags.distance_cm),
      'obj-led-detect': !!(flags.led_detect),
      'obj-serial':     !!(flags.serial_ok),
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — Comparar Sharp IR vs HC-SR04
// Pedagogía: decisiones de diseño, ventajas/limitaciones de cada sensor
// No hay respuesta única — el alumno elige y justifica.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-comparar-sensores'] = {
  id: 'u0-comparar-sensores',
  name: 'U0.13 — Sharp IR vs HC-SR04: ¿Cuál elegir?',
  description: 'Cada sensor tiene ventajas y limitaciones. Ninguno es universalmente mejor. Probá ambos con el mismo obstáculo y observá las diferencias.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: false, showHCSR04: true,
    extLeds: [{pin:'D10',color:'#18cc60'},{pin:'A0',color:'#f09600'}],
    description: 'LED verde = Sharp IR detecta. LED naranja = HC-SR04 detecta. El cono azul muestra el haz ultrasónico. Arrastrá el obstáculo a distintas posiciones.',
  },
  sketch:
`// ━━━ U0.13 — Sharp IR vs HC-SR04 ━━━
// Observación comparativa: dos sensores, mismo obstáculo, resultados distintos.
//
// SHARP IR (analógico):
//   + Respuesta muy rápida (sin protocolo)
//   + Detecta desde 4cm hasta 80cm
//   - El valor varía con el COLOR y MATERIAL del objeto
//   - La curva no es lineal (no se puede convertir fácilmente a cm)
//
// HC-SR04 (ultrasónico):
//   + Medición precisa en cm
//   + El color del objeto no importa
//   - Punto muerto: no detecta objetos a menos de 2cm
//   - Más lento (necesita esperar el eco)
//   - Afectado por superficies muy inclinadas

#define TRIG   12
#define ECHO   A3
#define SHARP  A0
#define LED_SH 10    // LED verde: Sharp IR activo
#define LED_HC A1    // LED naranja: HC-SR04 activo
#define U_SHARP 400  // umbral Sharp: < 400 → cerca
#define U_HCSR  25   // umbral HC-SR04: < 25cm → cerca

long medirHCSR04() {
  digitalWrite(TRIG,LOW); delayMicroseconds(2);
  digitalWrite(TRIG,HIGH); delayMicroseconds(10); digitalWrite(TRIG,LOW);
  long d = pulseIn(ECHO,HIGH); return d>0 ? d/58 : 999;
}

void setup() {
  Serial.begin(9600);
  pinMode(TRIG,OUTPUT); pinMode(ECHO,INPUT);
  pinMode(LED_SH,OUTPUT); pinMode(LED_HC,OUTPUT);
}

void loop() {
  // Leer Sharp IR
  int sharp = analogRead(SHARP);
  bool sharpDetecta = sharp < U_SHARP;

  // Leer HC-SR04
  long cm = medirHCSR04();
  bool hcsrDetecta = cm < U_HCSR;

  // Mostrar en LEDs
  digitalWrite(LED_SH, sharpDetecta ? HIGH : LOW);
  digitalWrite(LED_HC, hcsrDetecta  ? HIGH : LOW);

  Serial.print("Sharp:"); Serial.print(sharp);
  Serial.print(" HC-SR04:"); Serial.print(cm); Serial.print("cm");
  Serial.print(" | Sharp:"); Serial.print(sharpDetecta?"CERCA":"libre");
  Serial.print(" HC:"); Serial.println(hcsrDetecta?"CERCA":"libre");

  // EXPERIMENTO 1: Acercá el obstáculo muy lentamente.
  // ¿Detectan al mismo tiempo los dos sensores?

  // EXPERIMENTO 2: Ponés el obstáculo a 45°.
  // ¿Cuál sensor falla primero?

  // EXPERIMENTO 3: ¿Qué pasa a menos de 2cm con el HC-SR04?

  delay(80);
}`,
  objectives: [
    { id: 'obj-both-read',   label: 'Ambos sensores leyendo simultáneamente', required: true },
    { id: 'obj-sharp-det',   label: 'Sharp IR detecta obstáculo (A0 < 400)', required: true },
    { id: 'obj-hcsr-det',    label: 'HC-SR04 detecta obstáculo (< 25cm)', required: true },
    { id: 'obj-leds-both',   label: 'Ambos LEDs reaccionan a sus sensores', required: true },
    { id: 'obj-observacion', label: 'Experimento completo: obstáculo movido en múltiples posiciones', required: false },
  ],
  validate: function(vars, flags) {
    const sharpOk = vars.a0_raw > 0;
    const hcsrOk  = vars.hcsr04_cm !== null;
    if (sharpOk && hcsrOk && vars.sim_time > 300) _synthFlag('both_read', true);
    if (vars.a0_raw < 400) _synthFlag('sharp_det', true);
    if (vars.hcsr04_near)  _synthFlag('hcsr_det', true);
    if (flags.sharp_det && vars.led_on) _synthFlag('leds_both', true);
    // Track obstacle positions (bucket by 50px distance)
    const sf = S._synthState._flags;
    sf._positions = sf._positions || {};
    if (vars.hcsr04_cm) sf._positions[Math.floor(vars.hcsr04_cm/10)] = true;
    const posCount = Object.keys(sf._positions || {}).length;
    return {
      'obj-both-read':   !!(flags.both_read),
      'obj-sharp-det':   !!(flags.sharp_det),
      'obj-hcsr-det':    !!(flags.hcsr_det),
      'obj-leds-both':   !!(flags.leds_both),
      'obj-observacion': posCount >= 4,
    };
  },
};


// ──────────────────────────────────────────────────────────────────
// U0 EXT — I2C: Bus de Comunicación
// Pedagogía: buses compartidos, protocolo, múltiples dispositivos
// Un solo par de cables (SDA+SCL) conecta MUCHOS dispositivos.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-i2c'] = {
  id: 'u0-i2c',
  name: 'U0.14 — I2C: Bus de Periféricos',
  description: 'I2C es un bus que conecta múltiples dispositivos con solo 2 cables (SDA y SCL). Cada dispositivo tiene una dirección única (0x00-0x7F). La ROBOARD usa A4=SDA y A5=SCL.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: true,
    oledLines: ['I2C no iniciado'],
    description: 'El bus I2C usa A4 (SDA) y A5 (SCL). La OLED en el canvas muestra lo que el sketch escribe con Serial.println("OLED:texto").',
  },
  sketch:
`// ━━━ U0.14 — Bus I2C ━━━
// I2C = Inter-Integrated Circuit
// Un solo par de cables conecta múltiples dispositivos:
//   A4 = SDA (datos, bidireccional)
//   A5 = SCL (reloj, controla velocidad de transferencia)
//
// Cada dispositivo tiene una DIRECCIÓN única (0x00 a 0x7F).
// El maestro (Arduino) llama a la dirección, el esclavo responde.
//
// Dispositivos comunes con I2C:
//   OLED SSD1306    → dirección 0x3C o 0x3D
//   Sensor TOF VL53 → dirección 0x29
//   MPU6050 IMU     → dirección 0x68 o 0x69
//   PCF8574 expansor→ dirección 0x20-0x27

#include <Wire.h>

void setup() {
  Serial.begin(9600);

  // TODO 1: Iniciá el bus I2C con Wire.begin()
  // Esto configura A4 (SDA) y A5 (SCL) automáticamente.


  Serial.println("OLED:CLR");
  Serial.println("OLED:I2C iniciado");
  Serial.println("OLED:Escaneando bus...");
  Serial.println("Bus I2C iniciado. Escaneando...");

  // TODO 2: Scanner I2C — detectar qué dispositivos están conectados
  // El scanner prueba todas las direcciones de 1 a 127.
  // Si Wire.endTransmission() devuelve 0, el dispositivo existe.
  int encontrados = 0;
  for (int dir = 1; dir < 128; dir++) {
    Wire.beginTransmission(dir);
    int error = Wire.endTransmission();
    if (error == 0) {
      Serial.print("Dispositivo en 0x");
      if (dir < 16) Serial.print("0");
      Serial.println(dir, HEX);
      encontrados++;
    }
  }

  if (encontrados == 0) {
    Serial.println("Sin dispositivos I2C detectados");
    Serial.println("OLED:Sin dispositivos");
  } else {
    Serial.print(encontrados); Serial.println(" dispositivo(s) encontrado(s)");
    // TODO 3: Mostrá el conteo en la OLED del canvas
    // Tip: Serial.println("OLED:Encontrados: " + String(encontrados));


  }
}

void loop() {
  // TODO 4: En el loop, mostrá un contador que sube cada segundo
  // Se debe ver el número cambiando en la OLED del canvas
  static int contador = 0;
  contador++;
  Serial.println("OLED:CLR");
  // TODO: Mostrá "Tick: " + String(contador) en la OLED


  delay(1000);
}`,
  objectives: [
    { id: 'obj-wire-begin', label: 'Iniciar bus I2C con Wire.begin()', required: true },
    { id: 'obj-oled-init',  label: 'OLED del canvas muestra "I2C iniciado"', required: true },
    { id: 'obj-oled-data',  label: 'OLED del canvas muestra datos cambiantes (contador)', required: true },
    { id: 'obj-scanner',    label: 'Scanner I2C ejecutado (loop de 1 a 127)', required: true },
    { id: 'obj-oled-multi', label: 'OLED muestra más de 3 líneas distintas en secuencia', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    if (oledText.includes('iniciado') || oledText.includes('I2C')) _synthFlag('wire_begin', true);
    if (oledText.length > 5) _synthFlag('oled_shows', true);
    // Check for changing data (numbers in oled text)
    if (/\d+/.test(oledText) && vars.sim_time > 2000) _synthFlag('oled_data', true);
    // Scanner: wire.endTransmission implies Wire.beginTransmission was called
    if (vars.sim_time > 500) _synthFlag('scanner_ok', true);
    // Multiple distinct OLED states
    const sf = S._synthState._flags;
    sf._oled_states = sf._oled_states || {};
    sf._oled_states[oledText.slice(0,20)] = true;
    const stateCount = Object.keys(sf._oled_states).length;
    return {
      'obj-wire-begin': !!(flags.wire_begin),
      'obj-oled-init':  !!(flags.oled_shows),
      'obj-oled-data':  !!(flags.oled_data),
      'obj-scanner':    !!(flags.scanner_ok),
      'obj-oled-multi': stateCount >= 3,
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — OLED: Pantalla con SSD1306
// Pedagogía: comunicación I2C real, framebuffer, display educativo
// La OLED del canvas muestra exactamente lo que el sketch imprime.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-oled'] = {
  id: 'u0-oled',
  name: 'U0.15 — OLED: Pantalla I2C',
  description: 'La pantalla OLED SSD1306 (128×64px) se conecta por I2C. El robot puede mostrar valores de sensores, estados y mensajes. Usa Serial.println("OLED:texto") para ver en el canvas.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: true,
    oledLines: ['OLED lista'],
    description: 'La OLED del canvas simula la pantalla SSD1306 real. Escribe Serial.println("OLED:texto") para mostrar. "OLED:CLR" limpia la pantalla.',
  },
  sketch:
`// ━━━ U0.15 — OLED SSD1306 ━━━
// La OLED SSD1306 se comunica por I2C (dirección 0x3C).
// Librería real: Adafruit_SSD1306 o U8g2
//
// En la simulación ROBOLAB:
//   Serial.println("OLED:texto")  → muestra en la OLED del canvas
//   Serial.println("OLED:CLR")   → limpia la pantalla
//
// La OLED tiene 128×64 pixels. En modo texto: 21 cols × 8 filas.
// En modo gráfico se puede dibujar líneas, rectángulos y círculos.
//
// IMPORTANTE: en el robot real, cada print() necesita display.display()
// para que se vea. La simulación lo hace automáticamente.

#include <Wire.h>

#define SENSOR  A0
#define STBY    6
#define AIN1    5
#define AIN2    4
#define PWMA    3

void mostrarEstado(int sensor, bool moviendo) {
  // TODO 1: Limpiar la OLED antes de escribir nuevo contenido
  // Serial.println("OLED:CLR");
  ???;

  // TODO 2: Mostrar el valor del sensor en la OLED
  // Tip: Serial.println("OLED:Sensor: " + String(sensor));
  ???;

  // TODO 3: Mostrar si el robot está en movimiento o parado
  // Tip: Serial.println("OLED:" + String(moviendo ? "MOVIENDO" : "PARADO"));
  ???;
}

void setup() {
  Serial.begin(9600);
  Wire.begin();
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  Serial.println("OLED:ROBOLAB V1");
  Serial.println("OLED:Robot listo");
  delay(1000);
}

void loop() {
  int sensor = analogRead(SENSOR);
  bool hayObstaculo = (sensor < 400);

  if (hayObstaculo) {
    // Obstáculo cerca → parar y mostrar en OLED
    analogWrite(PWMA, 0);
    mostrarEstado(sensor, false);
  } else {
    // Campo libre → avanzar y mostrar en OLED
    digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,160);
    mostrarEstado(sensor, true);
  }

  delay(200);  // actualizar OLED ~5 veces por segundo
}`,
  objectives: [
    { id: 'obj-oled-clear', label: 'OLED se limpia con CLR antes de escribir', required: true },
    { id: 'obj-oled-sensor',label: 'OLED muestra el valor del sensor', required: true },
    { id: 'obj-oled-state', label: 'OLED muestra estado del robot (MOVIENDO/PARADO)', required: true },
    { id: 'obj-reactive',   label: 'Sistema reactivo: sensor → motor + OLED simultaneos', required: true },
    { id: 'obj-oled-live',  label: 'OLED actualiza en tiempo real (cambia con el sensor)', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    // CLR was called (oledLines resets to empty then refills)
    if (oled.length <= 3 && vars.sim_time > 300) _synthFlag('oled_clear', true);
    // Sensor value shown (number in oled text)
    if (/\d{2,4}/.test(oledText)) _synthFlag('oled_sensor', true);
    // State shown
    if (oledText.includes('MOVIENDO') || oledText.includes('PARADO') ||
        oledText.includes('CERCA') || oledText.includes('LIBRE')) {
      _synthFlag('oled_state', true);
    }
    // Reactive: motor changes AND oled updates
    if (flags.oled_sensor && (vars.motorA_fwd || vars.motorA_pwm === 0)) {
      _synthFlag('reactive_oled', true);
    }
    // Live: oled content changed at least 3 times
    const sf = S._synthState._flags;
    sf._oled_states = sf._oled_states || {};
    const oledKey = oledText.replace(/\d+/g, '#'); // normalize numbers
    sf._oled_states[oledKey] = true;
    const live = Object.keys(sf._oled_states).length >= 3;
    return {
      'obj-oled-clear':  !!(flags.oled_clear),
      'obj-oled-sensor': !!(flags.oled_sensor),
      'obj-oled-state':  !!(flags.oled_state),
      'obj-reactive':    !!(flags.reactive_oled),
      'obj-oled-live':   live,
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — TOF: Sensor VL53L0X (Time of Flight)
// Pedagogía: I2C avanzado, precisión mm, comparar con HC-SR04
// El TOF es más preciso y rápido que el HC-SR04 para distancias cortas.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-tof'] = {
  id: 'u0-tof',
  name: 'U0.16 — TOF: Sensor VL53L0X',
  description: 'El VL53L0X mide distancia por tiempo de vuelo de luz láser infrarroja (no sonido). Se comunica por I2C. Mide en milímetros con alta precisión y sin punto muerto a 2cm.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: true, showHCSR04: false,
    oledLines: ['TOF no iniciado'],
    description: 'El VL53L0X usa I2C (A4=SDA, A5=SCL, dirección 0x29). La OLED muestra la distancia en mm. Sin punto muerto: detecta desde 0mm.',
  },
  sketch:
`// ━━━ U0.16 — TOF VL53L0X ━━━
// VL53L0X = sensor Time of Flight por luz infrarroja (laser)
// Ventajas sobre HC-SR04:
//   + Mide en MILÍMETROS (precisión ~1mm vs ~5cm del HC-SR04)
//   + Sin punto muerto (detecta desde 0mm)
//   + No afectado por superficies inclinadas (luz, no sonido)
//   + Mucho más compacto
//   + Mismo bus I2C (A4/A5) — comparte cable con la OLED
//
// Librería real: Adafruit_VL53L0X
// Dirección I2C: 0x29 (fija, no modificable)
//
// En la SIMULACIÓN ROBOLAB:
//   El sensor TOF se simula con el mismo modelo físico del HC-SR04
//   pero con mayor precisión (resultado en mm).
//   Usar Serial.println("TOF_MM:" + distancia_mm) para visualizar.

#include <Wire.h>

#define LED    10
#define STBY    6
#define AIN1    5
#define AIN2    4
#define PWMA    3
#define UMBRAL_MM 200   // parar a 200mm = 20cm

// Simular lectura TOF (en robot real: vl53.rangingTest(&measure, false))
long leerTOF() {
  // En la simulación, el sensor TOF está disponible via pulseIn en A3
  // igual que HC-SR04 pero interpretamos el resultado en mm.
  // ROBOLAB inyecta la distancia física real del obstáculo.
  // El sketch usa esta función como si fuera la librería real.
  long us = pulseIn(A3, HIGH);
  if (us == 0) return 2000; // sin obstáculo → 2 metros
  return (us / 58) * 10;   // cm → mm (multiplicar x 10)
}

void setup() {
  Serial.begin(9600);

  // TODO 1: Iniciá el bus I2C
  ???;

  pinMode(LED,OUTPUT);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);

  Serial.println("OLED:VL53L0X TOF");
  Serial.println("OLED:I2C: 0x29");
  Serial.println("TOF iniciado");
}

void loop() {
  // TODO 2: Leé la distancia con leerTOF()
  long distancia_mm = ???;

  // Mostrar en Serial y OLED
  Serial.print("TOF: "); Serial.print(distancia_mm); Serial.println(" mm");
  Serial.println("OLED:CLR");
  // TODO 3: Mostrá la distancia en la OLED
  // Tip: Serial.println("OLED:" + String(distancia_mm) + " mm");
  ???;

  // TODO 4: Si distancia < UMBRAL_MM → parar, sino avanzar
  if (distancia_mm < UMBRAL_MM) {
    analogWrite(PWMA, 0);
    // TODO: encender LED y mostrar "OLED:PARADO" en la OLED
    ???;
  } else {
    digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,160);
    digitalWrite(LED, LOW);
    Serial.println("OLED:AVANZANDO");
  }

  delay(60);
}`,
  objectives: [
    { id: 'obj-i2c-init',   label: 'Iniciar I2C con Wire.begin()', required: true },
    { id: 'obj-tof-read',   label: 'Leer distancia TOF en mm', required: true },
    { id: 'obj-oled-tof',   label: 'OLED muestra distancia en mm', required: true },
    { id: 'obj-reactive',   label: 'Robot reacciona al TOF (para y avanza)', required: true },
    { id: 'obj-precision',  label: 'Umbral en mm observado (no en cm como HC-SR04)', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    if (vars.sim_time > 300) _synthFlag('i2c_init', true);
    // TOF reading: tof_mm comes from synthValidate hook
    if (vars.tof_mm !== null && vars.tof_mm !== undefined) _synthFlag('tof_read', true);
    // OLED shows mm (3-4 digit number followed by "mm")
    if (/\d{2,4}\s*mm/i.test(oledText) || /\d{3,4}/.test(oledText)) _synthFlag('oled_tof', true);
    // Reactive
    if ((vars.motorA_pwm === 0 || vars.motorA_fwd) && flags.tof_read) _synthFlag('reactive', true);
    // mm precision: value that would be odd in cm (e.g. 150mm = 15cm — suggests mm unit)
    if (vars.tof_mm && vars.tof_mm > 0 && vars.tof_mm < 300) _synthFlag('precision_mm', true);
    return {
      'obj-i2c-init':  !!(flags.i2c_init),
      'obj-tof-read':  !!(flags.tof_read),
      'obj-oled-tof':  !!(flags.oled_tof),
      'obj-reactive':  !!(flags.reactive),
      'obj-precision': !!(flags.precision_mm),
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0 EXT — SPI: Bus de Alta Velocidad
// Pedagogía: segundo bus, diferencia SPI vs I2C, uso con ADC externo
// SPI es más rápido que I2C pero usa más cables.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-spi'] = {
  id: 'u0-spi',
  name: 'U0.17 — SPI: Bus de Alta Velocidad',
  description: 'SPI usa 4 cables (SCLK, MOSI, MISO, CS) y es más rápido que I2C. Ideal para pantallas gráficas y ADCs de alta precisión. La ROBOARD usa D13=SCLK, D11=MOSI, D12=MISO, D10=CS.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: {
    showBtn: false, showDip: false, showOled: true,
    oledLines: ['SPI no iniciado'],
    description: 'SPI usa 4 cables: SCK(D13), MOSI(D11), MISO(D12), CS(D10). En la simulación se usa un ADC externo MCP3208 de 12 bits (equivalente al ADC del ESP32-C3).',
  },
  sketch:
`// ━━━ U0.17 — Bus SPI ━━━
// SPI = Serial Peripheral Interface
//
// DIFERENCIA I2C vs SPI:
//   I2C: 2 cables (SDA+SCL), múltiples dispositivos, más lento (~400kHz)
//   SPI: 4 cables (SCLK+MOSI+MISO+CS), uno a la vez, más rápido (~10MHz)
//
// PINES SPI en ROBOARD (Arduino Nano compatible):
//   D13 = SCLK  (reloj — el maestro lo controla)
//   D11 = MOSI  (Master Out Slave In — datos hacia el periférico)
//   D12 = MISO  (Master In Slave Out — datos desde el periférico)
//   D10 = CS/SS (Chip Select — LOW = dispositivo activo)
//
// Ejemplo: MCP3208 — ADC externo de 12 bits con SPI
//   Permite leer hasta 8 canales analógicos de 12 bits (0-4095)
//   Ideal para FRANKY (que ya tiene 12-bit ADC interno)
//   En ROBOARD extiende los 10-bit (0-1023) a 12-bit (0-4095)

#include <SPI.h>

#define CS_PIN  10   // Chip Select del MCP3208

// Leer canal analógico del MCP3208 via SPI
int leerMCP3208(int canal) {
  // Protocolo SPI del MCP3208:
  // 1. CS LOW (seleccionar chip)
  // 2. Enviar: 00000001 (start bit)
  // 3. Enviar: 1000xxxx (modo single-ended, canal 0-7)
  // 4. Recibir 12 bits de resultado
  // 5. CS HIGH (deseleccionar)
  digitalWrite(CS_PIN, LOW);
  SPI.transfer(0x06 | (canal >> 2));           // start + modo + canal alto
  int msb = SPI.transfer((canal & 3) << 6);   // canal bajo
  int lsb = SPI.transfer(0x00);               // recibir bits bajos
  digitalWrite(CS_PIN, HIGH);
  return ((msb & 0x0F) << 8) | lsb;           // resultado 12 bits (0-4095)
}

void setup() {
  Serial.begin(9600);

  // TODO 1: Configurar CS_PIN como OUTPUT y ponerlo en HIGH (inactivo)
  ???;

  // TODO 2: Iniciar el bus SPI con SPI.begin()
  ???;

  // Velocidad y modo SPI para MCP3208
  SPI.beginTransaction(SPISettings(1000000, MSBFIRST, SPI_MODE0));

  Serial.println("OLED:CLR");
  Serial.println("OLED:SPI iniciado");
  Serial.println("OLED:MCP3208 listo");
  Serial.println("SPI iniciado — MCP3208 12-bit ADC");
}

void loop() {
  // TODO 3: Leer canal 0 del MCP3208
  int valor12bit = leerMCP3208(???);  // canal 0

  // El MCP3208 devuelve 0-4095 (12 bits)
  // Para comparar con analogRead() que da 0-1023 (10 bits):
  int valor10bit = valor12bit >> 2;  // dividir por 4 → equivalente a analogRead

  Serial.print("MCP3208 CH0: "); Serial.print(valor12bit);
  Serial.print(" (10bit equiv: "); Serial.print(valor10bit); Serial.println(")");

  Serial.println("OLED:CLR");
  // TODO 4: Mostrar el valor de 12 bits en la OLED
  ???;

  delay(200);
}`,
  objectives: [
    { id: 'obj-spi-init',   label: 'Iniciar SPI con SPI.begin()', required: true },
    { id: 'obj-cs-config',  label: 'CS_PIN configurado como OUTPUT en HIGH', required: true },
    { id: 'obj-spi-read',   label: 'Lectura SPI ejecutada (leerMCP3208 llamado)', required: true },
    { id: 'obj-oled-spi',   label: 'Valor leído aparece en la OLED del canvas', required: true },
    { id: 'obj-12bit',      label: 'Valor de 12 bits observado (0-4095 vs 0-1023)', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    // SPI init: infer from sim time (SPI.begin was called if sketch runs)
    if (vars.sim_time > 200) _synthFlag('spi_init', true);
    // CS config: HIGH then LOW transition inferred from D10 usage
    if (vars.sim_time > 100) _synthFlag('cs_config', true);
    // SPI read: A0 value proxied to simulate 12-bit ADC result
    if (vars.a0_raw > 0 || vars.sim_time > 500) _synthFlag('spi_read', true);
    // OLED shows a number
    if (/\d{2,4}/.test(oledText)) _synthFlag('oled_spi', true);
    // 12-bit value: look for numbers > 1023 in serial output (4095 range)
    if (/[3-9]\d{2,3}/.test(oledText) || vars.sim_time > 1000) _synthFlag('bit12', true);
    return {
      'obj-spi-init':  !!(flags.spi_init),
      'obj-cs-config': !!(flags.cs_config),
      'obj-spi-read':  !!(flags.spi_read),
      'obj-oled-spi':  !!(flags.oled_spi),
      'obj-12bit':     !!(flags.bit12),
    };
  },
};


// ══════════════════════════════════════════════════════════════════
// E0 — FRANKY BLOCKLY — Etapa 0 Primeros Pasos
// Equivalencia pedagógica de U0 pero usando FRANKY + Blockly.
// Mismo canvas, mismos periféricos, mismos objetivos.
// El estudiante programa con bloques visuales en lugar de C++.
// ══════════════════════════════════════════════════════════════════

// ── E0.1 — LED Onboard FRANKY (Blockly) ─────────────────────────
SYNTHETIC_CHALLENGES['e0-led-blink'] = {
  id: 'e0-led-blink',
  name: 'E0.1 — LED Onboard (Blockly)',
  description: 'Encendé el LED del FRANKY con bloques. GPIO8 tiene lógica invertida: LOW = encendido. Usá los bloques "LED encender" y "LED apagar" del panel.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],  // FRANKY onboard LED (amber/yellow)
    description: 'LED interno FRANKY en GPIO8. Lógica invertida: LOW enciende. Los bloques "LED encender/apagar" lo controlan directamente.',
  },
  // No sketch needed — Blockly workspace
  objectives: [
    { id: 'obj-led-on',    label: 'Encender el LED (bloque "LED encender")', required: true },
    { id: 'obj-led-off',   label: 'Apagar el LED (bloque "LED apagar")', required: true },
    { id: 'obj-led-blink', label: 'Parpadear el LED al menos 3 veces', required: false },
  ],
  validate: function(vars, flags) {
    // FRANKY: led_on comes from franky.getState().ledOn (injected in SIM_TICK FRANKY branch)
    if (vars.led_on)  _synthFlag('led_on_seen', true);
    if (!vars.led_on && flags.led_on_seen) _synthFlag('led_off_seen', true);
    if (vars.led_on && !flags._led_was_on) { S._synthState._flags._led_was_on = true; }
    if (!vars.led_on && flags._led_was_on) {
      S._synthState._flags._blink_count = (S._synthState._flags._blink_count || 0) + 1;
      S._synthState._flags._led_was_on = false;
    }
    return {
      'obj-led-on':    !!(flags.led_on_seen),
      'obj-led-off':   !!(flags.led_off_seen),
      'obj-led-blink': (S._synthState?._flags?._blink_count || 0) >= 3,
    };
  },
};

// ── E0.2 — GPIO Digital Salidas (Blockly) ───────────────────────
SYNTHETIC_CHALLENGES['e0-gpio-salida'] = {
  id: 'e0-gpio-salida',
  name: 'E0.2 — GPIO: Salidas Digitales (Blockly)',
  description: 'FRANKY tiene GPIO libres para conectar LEDs externos. Usá el bloque "GPIO digital" para encender pines en HIGH y LOW. Probá GPIO0 y GPIO1.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: false,
    extLeds: [{pin:'A0',color:'#18cc60'},{pin:'A1',color:'#3878ec'}],
    description: 'Bloques GPIO digital → HIGH/LOW controlan pines externos. Los LEDs aparecen en el canvas cuando el pin está en HIGH.',
  },
  objectives: [
    { id: 'obj-gpio-high', label: 'Poner un GPIO en HIGH (bloque GPIO digital → HIGH)', required: true },
    { id: 'obj-gpio-low',  label: 'Poner un GPIO en LOW', required: true },
    { id: 'obj-secuencia', label: 'Secuencia: encender y apagar al menos 2 pines', required: true },
    { id: 'obj-patron',    label: 'Crear un patrón con esperas (bloque Esperar)', required: false },
  ],
  validate: function(vars, flags) {
    const pins = (typeof eco !== 'undefined') ? eco.hal.getAllPins() : {};
    const a0 = !!(pins['A0']?.value);
    const a1 = !!(pins['A1']?.value);
    if (a0 || a1)          _synthFlag('gpio_high', true);
    if (!a0 && !a1 && flags.gpio_high) _synthFlag('gpio_low', true);
    if (flags.gpio_high && flags.gpio_low) {
      S._synthState._flags._seq = (S._synthState._flags._seq || 0) + 1;
      if (a0 !== S._synthState._flags._last_a0 || a1 !== S._synthState._flags._last_a1) {
        S._synthState._flags._transitions = (S._synthState._flags._transitions || 0) + 1;
      }
    }
    S._synthState._flags._last_a0 = a0;
    S._synthState._flags._last_a1 = a1;
    const trans = S._synthState._flags._transitions || 0;
    return {
      'obj-gpio-high': !!(flags.gpio_high),
      'obj-gpio-low':  !!(flags.gpio_low),
      'obj-secuencia': trans >= 3,
      'obj-patron':    trans >= 6,
    };
  },
};

// ── E0.3 — Sensor ADC (Blockly) ─────────────────────────────────
SYNTHETIC_CHALLENGES['e0-sensor-adc'] = {
  id: 'e0-sensor-adc',
  name: 'E0.3 — Sensor ADC: Leer Distancia (Blockly)',
  description: 'El bloque "Leer ADC 0" lee el sensor de distancia de FRANKY (0-4095, 12 bits). Usá el bloque "Si ADC0 >" para tomar decisiones.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: { showOled: false,
    description: 'Arrastrá el obstáculo rojo. El HUD inferior muestra ADC0 en tiempo real. En FRANKY el rango es 0-4095 (12-bit), 4x mayor que Arduino (0-1023).',
  },
  objectives: [
    { id: 'obj-adc-read',   label: 'Leer ADC0 con el bloque correspondiente', required: true },
    { id: 'obj-adc-near',   label: 'Detectar objeto cerca (ADC0 < 1400, equiv. ~350 en Arduino)', required: true },
    { id: 'obj-led-react',  label: 'LED reacciona al sensor (bloque Si ADC < umbral)', required: true },
    { id: 'obj-threshold',  label: 'Ajustar umbral manualmente (explorar valores)', required: false },
  ],
  validate: function(vars, flags) {
    // FRANKY ADC: adc0 in SIM_TICK FRANKY branch (0-4095)
    // vars.a0_raw is 0-1023 from ROBOARD sim, but for FRANKY it's scaled
    const adc = vars.adc0 || (vars.a0_raw * 4); // scale to 12-bit equivalent
    if (adc > 0 || vars.sim_time > 300) _synthFlag('adc_read', true);
    if (adc > 0 && adc < 1400)          _synthFlag('adc_near', true);
    if (flags.adc_near && vars.led_on)  _synthFlag('led_react', true);
    // Track different threshold buckets used
    const sf = S._synthState._flags;
    sf._adc_buckets = sf._adc_buckets || {};
    if (adc > 0) sf._adc_buckets[Math.floor(adc/200)] = true;
    const explored = Object.keys(sf._adc_buckets || {}).length >= 3;
    return {
      'obj-adc-read':  !!(flags.adc_read),
      'obj-adc-near':  !!(flags.adc_near),
      'obj-led-react': !!(flags.led_react),
      'obj-threshold': explored,
    };
  },
};

// ── E0.4 — Motores con Blockly ───────────────────────────────────
SYNTHETIC_CHALLENGES['e0-motores'] = {
  id: 'e0-motores',
  name: 'E0.4 — Motores: Adelante y Atrás (Blockly)',
  description: 'FRANKY tiene un bloque "Adelante vel X" que mueve ambos motores. Probá también "Girar izquierda", "Girar derecha" y "Parar". Controlá la velocidad (0-255).',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: { showOled: false,
    description: 'Bloques de motor: Adelante / Atrás / Girar izq / Girar der / Parar. La velocidad va de 0 a 255. Observá el robot moverse en el canvas.',
  },
  objectives: [
    { id: 'obj-adelante',  label: 'Robot avanza (bloque Adelante)', required: true },
    { id: 'obj-giro',      label: 'Robot gira (bloque Girar izquierda o derecha)', required: true },
    { id: 'obj-parar',     label: 'Robot para (bloque Parar motores)', required: true },
    { id: 'obj-velocidad', label: 'Probar al menos 2 velocidades distintas', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.forward_moved || vars.bloques_ran) _synthFlag('adelante', true);
    if (vars.turn_performed) _synthFlag('giro', true);
    if (flags.adelante && !vars.forward_moved && vars.sim_time > 200) _synthFlag('parar', true);
    // Track different speed values
    const sf = S._synthState._flags;
    sf._speeds = sf._speeds || {};
    if (vars.motorSpeed) sf._speeds[Math.floor(vars.motorSpeed/50)] = true;
    return {
      'obj-adelante':  !!(flags.adelante),
      'obj-giro':      !!(flags.giro),
      'obj-parar':     !!(flags.parar),
      'obj-velocidad': Object.keys(sf._speeds || {}).length >= 2,
    };
  },
};

// ── E0.5 — Decisiones con Sensor (Blockly) ──────────────────────
SYNTHETIC_CHALLENGES['e0-decision'] = {
  id: 'e0-decision',
  name: 'E0.5 — Decisiones: Si sensor... entonces (Blockly)',
  description: 'El bloque "Si ADC0 < umbral entonces" conecta el sensor con una acción. Combiná motor + sensor para que FRANKY reaccione al obstáculo.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: { showOled: false,
    description: 'Bloque "Si ADC0 < X entonces" ejecuta bloques internos cuando el sensor detecta. Probá: Si ADC0 < 1400 → Parar. De lo contrario → Adelante.',
  },
  objectives: [
    { id: 'obj-avanza',    label: 'FRANKY avanza cuando no hay obstáculo', required: true },
    { id: 'obj-para',      label: 'FRANKY para cuando detecta obstáculo (ADC0 < umbral)', required: true },
    { id: 'obj-reactivo',  label: 'Ciclo reactivo: avanza → para → avanza ≥ 2 veces', required: true },
    { id: 'obj-led-debug', label: 'LED indica el estado (encendido = obstáculo detectado)', required: false },
  ],
  validate: function(vars, flags) {
    const adc = vars.adc0 || (vars.a0_raw * 4);
    if (vars.forward_moved && adc >= 1400) _synthFlag('avanza', true);
    if (!vars.forward_moved && adc < 1400 && flags.avanza) _synthFlag('para', true);
    const sf = S._synthState._flags;
    if (!sf._state) sf._state = 'idle';
    if (vars.forward_moved && sf._state !== 'fwd') { sf._state = 'fwd'; }
    if (!vars.forward_moved && sf._state === 'fwd') {
      sf._state = 'stopped';
      sf._cycles = (sf._cycles || 0) + 1;
    }
    if (vars.forward_moved && sf._state === 'stopped') sf._state = 'fwd';
    if (flags.para && vars.led_on) _synthFlag('led_debug', true);
    return {
      'obj-avanza':    !!(flags.avanza),
      'obj-para':      !!(flags.para),
      'obj-reactivo':  (sf._cycles || 0) >= 2,
      'obj-led-debug': !!(flags.led_debug),
    };
  },
};

// ── E0.6 — Repetir y Explorar (Blockly) ─────────────────────────
SYNTHETIC_CHALLENGES['e0-repetir'] = {
  id: 'e0-repetir',
  name: 'E0.6 — Repetir: Secuencias y Figuras (Blockly)',
  description: 'El bloque "Repetir N veces" ejecuta una secuencia múltiples veces. Combiná Adelante + Girar + Repetir para que FRANKY trace figuras geométricas.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: { showOled: false,
    description: 'Bloque "Repetir N veces" + Adelante vel X + Esperar + Girar + Esperar → figura. 4 repeticiones de 90° = cuadrado aproximado.',
  },
  objectives: [
    { id: 'obj-avance',    label: 'FRANKY avanza en línea recta', required: true },
    { id: 'obj-giro',      label: 'FRANKY gira usando bloque girar', required: true },
    { id: 'obj-repetir',   label: 'Bloque Repetir utilizado (secuencia >= 3 ciclos)', required: true },
    { id: 'obj-figura',    label: 'Figura completa: avance+giro repetido 4 o más veces', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.forward_moved) _synthFlag('avance', true);
    if (vars.turn_performed) _synthFlag('giro', true);
    const sf = S._synthState._flags;
    // Count avance+giro sequences
    if (!sf._ls) sf._ls = 'idle';
    if (vars.forward_moved && sf._ls !== 'fwd') sf._ls = 'fwd';
    if (vars.turn_performed && sf._ls === 'fwd') {
      sf._ls = 'turn';
      sf._seqs = (sf._seqs || 0) + 1;
    }
    if (!vars.turn_performed && sf._ls === 'turn') sf._ls = 'idle';
    const seqs = sf._seqs || 0;
    return {
      'obj-avance':  !!(flags.avance),
      'obj-giro':    !!(flags.giro),
      'obj-repetir': seqs >= 3,
      'obj-figura':  seqs >= 4,
    };
  },
};


// ── Tutorial General — Cuaderno de Laboratorio ROBOLAB V1 ───────
const TUTORIAL_MD = `
# ROBOLAB V1 — Cuaderno de Laboratorio

## ¿Qué es ROBOLAB?

ROBOLAB es un laboratorio de robótica educativa en el navegador.
No es solo un simulador: es un puente entre el código y el hardware real.

**Plataformas:**
- **ROBOARD** — Arduino Nano compatible, C++
- **FRANKY** — ESP32-C3 con WiFi, Blockly visual o C++

## Cómo usar la plataforma

### Ciclo de trabajo
1. Tab Desafío → leer objetivo y criterios
2. Tab Código → completar los TODOs del sketch
3. Cargar (↑) → verificar sintaxis
4. Ejecutar (▶) → observar en el canvas
5. Teoría o Pistas (💡) si algo no funciona
6. Los objetivos se marcan ✓ en tiempo real

### Periféricos interactivos en el canvas
- **Botón BTN** (esquina superior derecha): click = presionar el pulsador físico
- **LEDs externos** (izquierda): se iluminan cuando el pin está en HIGH
- **Cono HC-SR04** (frente al robot): muestra distancia en tiempo real
- **Pantalla OLED** (panel superior izquierdo): Serial.println("OLED:texto")

## Progresión pedagógica

### Camino A — Primaria / Inicial
E0 Blockly → E0 Extendida → U1 en adelante

### Camino B — Secundaria Técnica
U0 C++ → U0 Extendida → U1 → U2 → U3 → FRANKY E1-E5

## Unidad 0 — Primeros Pasos

| Desafío | Concepto central |
|---------|-----------------|
| U0.1 LED Onboard | pinMode, digitalWrite, HIGH/LOW |
| U0.2 LEDs Externos | GPIO múltiple, salidas |
| U0.3 Pulsador | digitalRead, INPUT_PULLUP |
| U0.4 Motor A | TB6612FNG, STBY, PWM |
| U0.5 Sensor Analógico | analogRead, 0-1023, umbral |
| U0.6 Sistema Reactivo | if/else, sensor→motor |
| U0.7 DIP-Switch | configuración de hardware |
| U0.8 PWM | duty cycle, analogWrite 0-255 |
| U0.9 Mapeo Analógico | map(), constrain() |
| U0.10 Movimiento Geométrico | tiempo = distancia/velocidad |
| U0.11 Evasión | sistema reactivo completo |
| U0.12 HC-SR04 | tiempo de vuelo, pulseIn |
| U0.13 Sharp vs HC-SR04 | decisión de diseño |
| U0.14 I2C Bus | Wire, múltiples periféricos |
| U0.15 OLED Display | SSD1306, visualización |
| U0.16 TOF VL53L0X | distancia en mm, I2C avanzado |
| U0.17 Bus SPI | MCP3208, ADC externo 12-bit |

## Prácticas complementarias

Actividades NO obligatorias para ampliar el laboratorio:

- **Semáforo**: verde 5s → amarillo 2s → rojo 5s → repetir
- **Sirena**: LED parpadea acelerando (delay cada vez menor)
- **Ruleta**: LEDs externos encendiéndose en ciclo
- **Botón peatonal**: LED verde fijo hasta presionar BTN → ciclo rojo→verde
- **Freno proporcional**: más cerca el obstáculo → frena más rápido
- **Monitor OLED**: pantalla muestra A0, A1 y distancia en tiempo real

## Transferencia simulación → robot real

| Aspecto | Simulación | Robot real |
|---------|-----------|-----------|
| Sharp IR | valor exacto | varía ±15% por reflectividad |
| HC-SR04 | sin punto muerto | <2cm no detecta |
| Calibración | no necesaria | ajustar umbral por robot |
| Ruido | ninguno | capacitores de desacoplamiento |
| Motores | idénticos | diferencias físicas entre ruedas |

**Protocolo:** simular → calibrar umbrales → cargar al robot → ajustar según hardware real.

**Errores frecuentes en robot real:**
- No reacciona → umbral incorrecto, calibrar
- Motor al revés → cambiar AIN1/AIN2
- Oscilación → KP demasiado alto en PD
- HC-SR04 da 999 → verificar TRIG/ECHO

## Hardware

### ROBOARD (Arduino Nano)
- Motor driver: TB6612FNG (A: D3/D4/D5/D6, B: D7/D8/D9)
- LED: D10 (HIGH=encendido), BTN: D12 (pull-up, LOW=presionado)
- DIP-switch: D11 y D2 (pull-up), Sharp IR: A0, HC-SR04: TRIG=D12/ECHO=A3
- I2C: A4(SDA)/A5(SCL), LEDs externos: A0-A5

### FRANKY (ESP32-C3)
- ADC: 12-bit (0-4095), LED: GPIO8 (LOW=encendido), BTN: GPIO9
- I2C: GPIO6(SDA)/GPIO7(SCL), SPI: GPIO20/21/1/10
- Pines libres: GPIO0, GPIO1, GPIO6, GPIO7, GPIO10, GPIO20, GPIO21

### Sensores
- Sharp GP2Y0A21: IR analógico 10-80cm, A0
- HC-SR04: ultrasónico 2-400cm, TRIG/ECHO
- VL53L0X: TOF láser 0-2000mm, I2C 0x29
- QTR-RC / CNY70 / TCRT5000: reflectancia para seguidor de línea

## Para docentes

### Vista Docente (botón 👨‍🏫)
- Tabla de progreso por desafío (✓/○)
- Indicadores: exploración, persistencia, autonomía, errores, pistas
- Narrativa de sesión: qué hizo el estudiante y señales pedagógicas
- Notas libres (persisten entre sesiones)
- Exportar JSON para registro o análisis

### Uso en clase
- 45 min: U0.1 + U0.2 + exploración libre de LEDs
- 90 min: U0.1 a U0.6 completos con cierre comparativo
- Proyecto integrador: U0.11 evasión → calibrar en robot real
- Evaluación: exportar JSON de progreso al final de la unidad

## Licencia

ROBOLAB V1 — Plataforma Educativa de Robótica.
Desarrollado por Martín Entraigas — MDE. Electrónica que impulsa proyectos.
Uso gratuito para instituciones educativas públicas.
Uso comercial o privado requiere autorización del autor.
martinentraigas07@gmail.com
`;


// ══════════════════════════════════════════════════════════════════
// E0 EXTENDIDA — Desafíos avanzados FRANKY + Blockly
// Equivalencia pedagógica de U0 Extendida para FRANKY/Blockly
// ══════════════════════════════════════════════════════════════════

// ── E0.7 — PWM: Brillo y Velocidad (Blockly) ────────────────────
SYNTHETIC_CHALLENGES['e0-pwm'] = {
  id: 'e0-pwm',
  blocklyToolbox: 'e0ext',
  name: 'E0.7 — PWM: Brillo y Velocidad (Blockly)',
  description: 'PWM controla la potencia variando el tiempo en HIGH. En FRANKY el bloque "Motor vel X" ya usa PWM internamente. Experimentá con distintas velocidades y observá la diferencia.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'Probá velocidades diferentes: lento (50-100), medio (150), rápido (220-255). El LED amarillo responde a los bloques LED encender/apagar.',
  },
  objectives: [
    { id: 'obj-vel-baja',   label: 'Robot se mueve a velocidad baja (< 120)', required: true },
    { id: 'obj-vel-alta',   label: 'Robot se mueve a velocidad alta (> 180)', required: true },
    { id: 'obj-dos-vel',    label: 'Al menos 2 velocidades distintas usadas en secuencia', required: true },
    { id: 'obj-led-pwm',    label: 'LED usado junto con variación de velocidad', required: false },
  ],
  validate: function(vars, flags) {
    const pwm = vars.motorA_pwm || 0;
    const sf = S._synthState._flags;
    sf._speeds = sf._speeds || {};
    if (pwm > 0 && pwm < 120)  { _synthFlag('vel_baja', true); sf._speeds['low'] = true; }
    if (pwm > 180)              { _synthFlag('vel_alta', true); sf._speeds['high'] = true; }
    if (pwm > 120 && pwm < 180) { sf._speeds['mid'] = true; }
    const speeds = Object.keys(sf._speeds || {}).length;
    if (vars.led_on && speeds >= 2) _synthFlag('led_pwm', true);
    return {
      'obj-vel-baja':  !!(flags.vel_baja),
      'obj-vel-alta':  !!(flags.vel_alta),
      'obj-dos-vel':   speeds >= 2,
      'obj-led-pwm':   !!(flags.led_pwm),
    };
  },
};

// ── E0.8 — Movimiento Geométrico (Blockly) ───────────────────────
SYNTHETIC_CHALLENGES['e0-movimiento'] = {
  id: 'e0-movimiento',
  blocklyToolbox: 'e0ext',
  name: 'E0.8 — Movimiento Geométrico (Blockly)',
  description: 'Con bloques Adelante + Esperar + Girar + Esperar + Repetir podés trazar figuras geométricas. 4 repeticiones de 90° = cuadrado. ¿Podés trazar un triángulo?',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: { showOled: false,
    description: 'Bloques: Adelante + Esperar + Girar der/izq + Esperar → Repetir N veces. Ajustá los tiempos de espera para calibrar los ángulos.',
  },
  objectives: [
    { id: 'obj-avanza',    label: 'FRANKY avanza en línea recta', required: true },
    { id: 'obj-gira',      label: 'FRANKY gira usando bloque girar', required: true },
    { id: 'obj-secuencia', label: 'Secuencia avance+giro repetida ≥ 3 veces', required: true },
    { id: 'obj-figura',    label: 'Figura completa: avance+giro ≥ 4 veces (cuadrado)', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.forward_moved && vars.motorA_pwm > 0) _synthFlag('avanza', true);
    if (vars.turn_performed) _synthFlag('gira', true);
    const sf = S._synthState._flags;
    if (!sf._mv_state) sf._mv_state = 'idle';
    if (vars.forward_moved && sf._mv_state !== 'fwd') sf._mv_state = 'fwd';
    if (vars.turn_performed && sf._mv_state === 'fwd') {
      sf._mv_state = 'turn';
      sf._seqs = (sf._seqs || 0) + 1;
    }
    if (!vars.forward_moved && !vars.turn_performed) sf._mv_state = 'idle';
    const seqs = sf._seqs || 0;
    return {
      'obj-avanza':    !!(flags.avanza),
      'obj-gira':      !!(flags.gira),
      'obj-secuencia': seqs >= 3,
      'obj-figura':    seqs >= 4,
    };
  },
};

// ── E0.9 — Evasión Reactiva Completa (Blockly) ──────────────────
SYNTHETIC_CHALLENGES['e0-evasion'] = {
  id: 'e0-evasion',
  blocklyToolbox: 'e0ext',
  name: 'E0.9 — Evasión: Robot Reactivo (Blockly)',
  description: 'FRANKY avanza y cuando detecta un obstáculo (ADC0 < umbral) retrocede y gira. Es el primer comportamiento reactivo completo: percibir → decidir → actuar.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'Arrastrá el obstáculo hacia FRANKY. Cuando el ADC0 supera el umbral, el robot debe evadir. El LED amarillo puede usarse para indicar detección.',
  },
  objectives: [
    { id: 'obj-avanza',    label: 'FRANKY avanza cuando no hay obstáculo', required: true },
    { id: 'obj-evade',     label: 'FRANKY retrocede o gira al detectar obstáculo', required: true },
    { id: 'obj-ciclo',     label: 'Ciclo reactivo completo ≥ 2 veces (avanza → evade → avanza)', required: true },
    { id: 'obj-led-debug', label: 'LED indica estado (encendido al detectar)', required: false },
  ],
  validate: function(vars, flags) {
    const adc = vars.adc0 || (vars.a0_raw * 4);
    if (vars.forward_moved && adc < 1400) _synthFlag('avanza', true);
    if ((vars.turn_performed || vars.motorA_rev) && adc >= 1400) _synthFlag('evade', true);
    const sf = S._synthState._flags;
    if (!sf._ev_state) sf._ev_state = 'idle';
    if (vars.forward_moved && sf._ev_state !== 'fwd') sf._ev_state = 'fwd';
    if ((vars.turn_performed || vars.motorA_rev) && sf._ev_state === 'fwd') {
      sf._ev_state = 'evading';
      sf._cycles = (sf._cycles || 0) + 1;
    }
    if (vars.forward_moved && sf._ev_state === 'evading') sf._ev_state = 'fwd';
    if (flags.evade && vars.led_on) _synthFlag('led_debug', true);
    return {
      'obj-avanza':    !!(flags.avanza),
      'obj-evade':     !!(flags.evade),
      'obj-ciclo':     (sf._cycles || 0) >= 2,
      'obj-led-debug': !!(flags.led_debug),
    };
  },
};


// ── E0.10 — HC-SR04 Ultrasónico (Blockly) ───────────────────────
SYNTHETIC_CHALLENGES['e0-ultrasonido'] = {
  id: 'e0-ultrasonido',
  blocklyToolbox: 'e0ext',
  name: 'E0.10 — HC-SR04: Sensor Ultrasónico (Blockly)',
  description: 'El HC-SR04 mide distancia por tiempo de vuelo del sonido. En FRANKY se lee como ADC ch1. El cono azul del canvas muestra el haz y la distancia en cm en tiempo real.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: true,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'Cono azul-verde = haz HC-SR04. La OLED muestra telemetría en tiempo real. Usá ADC ch0 en tus bloques para leer la distancia.',
  },
  objectives: [
    { id: 'obj-sensor-read',  label: 'ADC leído (bloque Leer ADC en programa)', required: true },
    { id: 'obj-cone-visible', label: 'Cono HC-SR04 visible y midiendo distancia', required: true },
    { id: 'obj-oled-telem',   label: 'OLED muestra telemetría (distancia en tiempo real)', required: true },
    { id: 'obj-reactivo',     label: 'Robot reacciona según distancia detectada', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.sim_time > 500) _synthFlag('sensor_read', true);
    if (S._periph?.hcsrDist !== null && S._periph?.hcsrDist !== undefined) _synthFlag('cone_visible', true);
    const oled = S._periph?.oledLines || [];
    if (oled.some(function(l){ return /DIST|dist|cm/.test(l); })) _synthFlag('oled_telem', true);
    if (vars.hcsr04_near && (vars.turn_performed || vars.motorA_rev)) _synthFlag('reactivo', true);
    return {
      'obj-sensor-read':  !!(flags.sensor_read),
      'obj-cone-visible': !!(flags.cone_visible),
      'obj-oled-telem':   !!(flags.oled_telem),
      'obj-reactivo':     !!(flags.reactivo),
    };
  },
};

// ── E0.11 — Comparar Sharp vs HC-SR04 (Blockly) ─────────────────
SYNTHETIC_CHALLENGES['e0-comparar'] = {
  id: 'e0-comparar',
  blocklyToolbox: 'e0ext',
  name: 'E0.11 — Sharp IR vs HC-SR04 (Blockly)',
  description: 'Sharp IR (ADC ch0) y HC-SR04 miden de forma diferente. Sharp es más rápido pero impreciso en cm. HC-SR04 da distancia real. Observá la diferencia con el mismo obstáculo.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: true,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'El cono muestra HC-SR04. La OLED muestra A0 (Sharp) y DIST (HC-SR04). Mové el obstáculo y observá cómo cada sensor responde diferente.',
  },
  objectives: [
    { id: 'obj-sharp-used',  label: 'Sharp IR (ADC ch0) leído y usado en decisión', required: true },
    { id: 'obj-hcsr-active', label: 'HC-SR04 activo (cono visible midiendo)', required: true },
    { id: 'obj-oled-ambos',  label: 'OLED muestra datos de ambos sensores', required: true },
    { id: 'obj-diferencia',  label: 'Robot ejecutado con obstáculo en distintas posiciones', required: false },
  ],
  validate: function(vars, flags) {
    const adc = vars.adc0 || (vars.a0_raw * 4);
    if (adc > 0 && vars.sim_time > 300) _synthFlag('sharp_used', true);
    if (S._periph?.hcsrDist !== null && S._periph?.hcsrDist !== undefined) _synthFlag('hcsr_active', true);
    const oled = S._periph?.oledLines || [];
    if (oled.some(function(l){ return /A0|DIST/i.test(l); })) _synthFlag('oled_ambos', true);
    const sf = S._synthState._flags;
    sf._hcsr_positions = sf._hcsr_positions || {};
    if (S._periph?.hcsrDist) sf._hcsr_positions[Math.floor(S._periph.hcsrDist/15)] = true;
    const positions = Object.keys(sf._hcsr_positions).length;
    return {
      'obj-sharp-used':  !!(flags.sharp_used),
      'obj-hcsr-active': !!(flags.hcsr_active),
      'obj-oled-ambos':  !!(flags.oled_ambos),
      'obj-diferencia':  positions >= 3,
    };
  },
};

// ── E0.12 — OLED SSD1306 con Telemetría (Blockly) ───────────────
SYNTHETIC_CHALLENGES['e0-oled'] = {
  id: 'e0-oled',
  blocklyToolbox: 'e0ext',
  name: 'E0.12 — OLED: Pantalla de Telemetría (Blockly)',
  description: 'La OLED SSD1306 en FRANKY muestra datos en tiempo real. El simulador la actualiza automáticamente con velocidad, sensor y distancia mientras ejecutás tu programa.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'La OLED del canvas muestra telemetría FRANKY: A0 (sensor), VEL (velocidad), DIST (distancia). Ejecutá un programa reactivo y observá la pantalla.',
  },
  objectives: [
    { id: 'obj-oled-on',     label: 'OLED visible con datos en tiempo real', required: true },
    { id: 'obj-motor-data',  label: 'OLED muestra velocidad variando al mover el robot', required: true },
    { id: 'obj-sensor-data', label: 'OLED muestra sensor A0 cambiando con obstáculo', required: true },
    { id: 'obj-reactivo',    label: 'Datos OLED + comportamiento reactivo simultáneos', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    if (oled.length > 0 && vars.sim_time > 300) _synthFlag('oled_on', true);
    if (/VEL:\s*[1-9]/.test(oledText) && vars.sim_time > 500) _synthFlag('motor_data', true);
    if (/A0:\s*[0-9]/.test(oledText)) _synthFlag('sensor_data', true);
    if (flags.motor_data && flags.sensor_data && vars.turn_performed) _synthFlag('reactivo', true);
    return {
      'obj-oled-on':     !!(flags.oled_on),
      'obj-motor-data':  !!(flags.motor_data),
      'obj-sensor-data': !!(flags.sensor_data),
      'obj-reactivo':    !!(flags.reactivo),
    };
  },
};

// ── E0.13 — I2C Bus (Blockly + FRANKY) ──────────────────────────
SYNTHETIC_CHALLENGES['e0-i2c'] = {
  id: 'e0-i2c',
  blocklyToolbox: 'e0ext',
  name: 'E0.13 — I2C: Bus de Periféricos (Blockly)',
  description: 'I2C conecta múltiples dispositivos con 2 cables (SDA+SCL). En FRANKY: GPIO6=SDA, GPIO7=SCL. La OLED SSD1306 y el sensor TOF usan I2C. El canvas muestra la telemetría I2C.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'La OLED (I2C 0x3C) aparece en el canvas. Explorá los GPIOs disponibles con bloques DOUT. En FRANKY los pines I2C son GPIO6 (SDA) y GPIO7 (SCL).',
  },
  objectives: [
    { id: 'obj-oled-i2c',   label: 'OLED activa mostrando datos (comunicación I2C)', required: true },
    { id: 'obj-gpio-exp',   label: 'GPIOs explorados con bloques DOUT', required: true },
    { id: 'obj-programa',   label: 'Programa ejecutado por al menos 3 segundos', required: true },
    { id: 'obj-led-plus',   label: 'LED + OLED activos simultáneamente', required: false },
  ],
  validate: function(vars, flags) {
    const oled = S._periph?.oledLines || [];
    if (oled.length > 0 && vars.sim_time > 300) _synthFlag('oled_i2c', true);
    // GPIO exploration: check if DOUT was used (motor moves = DOUT or ADE used)
    if (vars.motor_moved || vars.sim_time > 1000) _synthFlag('gpio_exp', true);
    if (vars.sim_time >= 3000) _synthFlag('programa', true);
    if (flags.oled_i2c && vars.led_on) _synthFlag('led_plus', true);
    return {
      'obj-oled-i2c': !!(flags.oled_i2c),
      'obj-gpio-exp': !!(flags.gpio_exp),
      'obj-programa': !!(flags.programa),
      'obj-led-plus': !!(flags.led_plus),
    };
  },
};

// ── E0.14 — TOF VL53L0X (Blockly) ───────────────────────────────
SYNTHETIC_CHALLENGES['e0-tof'] = {
  id: 'e0-tof',
  blocklyToolbox: 'e0ext',
  name: 'E0.14 — TOF VL53L0X: Distancia mm (Blockly)',
  description: 'El VL53L0X mide distancia por tiempo de vuelo de luz infrarroja. Más preciso que el HC-SR04. Se comunica por I2C (0x29). En FRANKY la OLED muestra la distancia en mm.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: true,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'El cono azul simula el haz TOF (más preciso, sin punto muerto). La OLED muestra DIST en mm (x10 respecto al HC-SR04). Programá un robot que reaccione a < 200mm.',
  },
  objectives: [
    { id: 'obj-tof-active',  label: 'TOF activo: cono visible, OLED muestra distancia', required: true },
    { id: 'obj-mm-reaccion', label: 'Robot reacciona a distancia corta (equivale a < 20cm)', required: true },
    { id: 'obj-oled-mm',     label: 'OLED muestra datos de distancia con precisión', required: true },
    { id: 'obj-sin-muerto',  label: 'Robot detecta obstáculo a menos de 5cm (sin punto muerto)', required: false },
  ],
  validate: function(vars, flags) {
    if (S._periph?.hcsrDist !== null && S._periph?.oledLines?.length > 0) _synthFlag('tof_active', true);
    if (vars.hcsr04_near && (vars.turn_performed || !vars.forward_moved)) _synthFlag('mm_reaccion', true);
    const oled = S._periph?.oledLines || [];
    if (oled.some(function(l){ return /DIST|mm|cm/i.test(l); })) _synthFlag('oled_mm', true);
    const dist = S._periph?.hcsrDist;
    if (dist !== null && dist !== undefined && dist < 5) _synthFlag('sin_muerto', true);
    return {
      'obj-tof-active':  !!(flags.tof_active),
      'obj-mm-reaccion': !!(flags.mm_reaccion),
      'obj-oled-mm':     !!(flags.oled_mm),
      'obj-sin-muerto':  !!(flags.sin_muerto),
    };
  },
};

// ── E0.15 — SPI: Bus de Alta Velocidad (Blockly) ─────────────────
SYNTHETIC_CHALLENGES['e0-spi'] = {
  id: 'e0-spi',
  blocklyToolbox: 'e0ext',
  name: 'E0.15 — SPI: Bus de Alta Velocidad (Blockly)',
  description: 'SPI usa 4 cables (SCLK, MOSI, MISO, CS) y es más rápido que I2C. En FRANKY los pines SPI son GPIO20/21/1/10. Explorá los GPIOs libres y observá la OLED con telemetría.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'La OLED muestra la telemetría FRANKY (equivalente a un ADC SPI externo). Explorá los pines disponibles con DOUT. SPI: GPIO20=SCLK, GPIO21=MOSI, GPIO1=MISO.',
  },
  objectives: [
    { id: 'obj-gpio-libre',  label: 'GPIO libre explorado con bloque DOUT', required: true },
    { id: 'obj-oled-telm',   label: 'OLED muestra telemetría en tiempo real', required: true },
    { id: 'obj-sensor-adc',  label: 'ADC leído y usado en al menos una decisión', required: true },
    { id: 'obj-integracion', label: 'Programa integra motor + sensor + LED + OLED activos', required: false },
  ],
  validate: function(vars, flags) {
    // GPIO exploration via motor movement (motor uses GPIO pins)
    if (vars.motor_moved && vars.sim_time > 500) _synthFlag('gpio_libre', true);
    const oled = S._periph?.oledLines || [];
    if (oled.length > 0 && vars.sim_time > 300) _synthFlag('oled_telm', true);
    if (vars.adc0 > 0 || vars.a0_raw > 0) _synthFlag('sensor_adc', true);
    if (flags.gpio_libre && flags.oled_telm && flags.sensor_adc && vars.led_on) _synthFlag('integracion', true);
    return {
      'obj-gpio-libre':  !!(flags.gpio_libre),
      'obj-oled-telm':   !!(flags.oled_telm),
      'obj-sensor-adc':  !!(flags.sensor_adc),
      'obj-integracion': !!(flags.integracion),
    };
  },
};

// ── E0.16 — Mapeo Analógico (Blockly) ────────────────────────────
SYNTHETIC_CHALLENGES['e0-mapeo'] = {
  id: 'e0-mapeo',
  blocklyToolbox: 'e0ext',
  name: 'E0.16 — Mapeo: Sensor controla Velocidad (Blockly)',
  description: 'El sensor (ADC 0-4095) controla la velocidad del motor proporcionalmente. Más lejos el obstáculo → más rápido. Más cerca → más lento. Usá VAR_SET e IF_GT/IF_LT para crear rangos.',
  platformId: 'FRANKY', interactionMode: 'bloques',
  scenarioId: 'single-obstacle',
  periph: {
    showOled: true, showHCSR04: false,
    extLeds: [{pin:'GPIO8', color:'#fdd835'}],
    description: 'La OLED muestra A0 y VEL. Mové el obstáculo y observá cómo la velocidad debería cambiar según la distancia. Creá al menos 2 rangos de velocidad con Si-Sino.',
  },
  objectives: [
    { id: 'obj-adc-mapeo',  label: 'ADC leído y usado para determinar velocidad', required: true },
    { id: 'obj-vel-varia',  label: 'Motor usa al menos 2 velocidades distintas según sensor', required: true },
    { id: 'obj-oled-mapa',  label: 'OLED muestra A0 y VEL cambiando en tiempo real', required: true },
    { id: 'obj-proporcional',label: 'Velocidad varía en 3 o más rangos (mapeada proporcionalmente)', required: false },
  ],
  validate: function(vars, flags) {
    const adc = vars.adc0 || (vars.a0_raw * 4);
    if (adc > 0 && vars.sim_time > 300) _synthFlag('adc_mapeo', true);
    const sf = S._synthState._flags;
    sf._speed_bands = sf._speed_bands || {};
    const pwm = vars.motorA_pwm || 0;
    if (pwm > 0   && pwm < 100) sf._speed_bands['low'] = true;
    if (pwm >= 100 && pwm < 180) sf._speed_bands['mid'] = true;
    if (pwm >= 180) sf._speed_bands['high'] = true;
    const bands = Object.keys(sf._speed_bands).length;
    if (bands >= 2) _synthFlag('vel_varia', true);
    const oled = S._periph?.oledLines || [];
    const oledText = oled.join(' ');
    if (/A0|VEL/i.test(oledText)) _synthFlag('oled_mapa', true);
    return {
      'obj-adc-mapeo':    !!(flags.adc_mapeo),
      'obj-vel-varia':    !!(flags.vel_varia),
      'obj-oled-mapa':    !!(flags.oled_mapa),
      'obj-proporcional': bands >= 3,
    };
  },
};


const CH_DB = buildChallengeDB();

function getChallenge(id) {
  // Try ContentRegistry first (canonical), then local DB, then synthetic, then null
  return eco.content.getChallenge(id) || CH_DB.get(id) || SYNTHETIC_CHALLENGES[id] || null;
}

