// ──────────────────────────────────────────────────────────────────
// U0.4 — Un Motor (Motor A)
// ROBOARD: TB6612FNG — STBY(D6), AIN1(D5), AIN2(D4), PWMA(D3)
// Pedagogía: driver, dirección, PWM, un solo motor
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-un-motor'] = {
  id: 'u0-un-motor',
  name: 'U0.4 — Un Motor Adelante',
  description: 'Activá el Motor A hacia adelante. El driver TB6612FNG necesita 4 señales: STBY, AIN1, AIN2 y PWMA. Completá cada TODO.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  periph: null,
  sketch:
`// ━━━ U0.4 — Un Motor Adelante ━━━
// El Motor A del driver TB6612FNG necesita:
//
//   D6  STBY = HIGH  → habilitar el driver (sin esto nada funciona)
//   D5  AIN1 = HIGH  → dirección: adelante
//   D4  AIN2 = LOW   → dirección: adelante (opuesto a AIN1)
//   D3  PWMA = 0-255 → velocidad (PWM, 0=parado, 255=máximo)
//
// Motor B (D7,D8,D9) no se usa en este desafío.

#define STBY  6
#define AIN1  5
#define AIN2  4
#define PWMA  3

void setup() {
  Serial.begin(9600);

  // TODO 1: Configurá STBY, AIN1, AIN2, PWMA como OUTPUT


  // TODO 2: Habilitá el driver (STBY = HIGH)
  // Sin esto el driver está en modo standby y los motores no responden.


  Serial.println("Driver configurado");
}

void loop() {
  // TODO 3: Configurá la dirección: AIN1=HIGH, AIN2=LOW


  // TODO 4: Configurá la velocidad: analogWrite(PWMA, 200)
  // Probá con 100, 150, 200, 255. ¿Notás diferencia en el canvas?


  Serial.print("Motor A PWM: ");
  Serial.println(200);
  delay(100);
}`,
  objectives: [
    { id: 'obj-stby',     label: 'Habilitar driver TB6612FNG (D6=HIGH)', required: true },
    { id: 'obj-dir-set',  label: 'Configurar dirección Motor A (AIN1=H, AIN2=L)', required: true },
    { id: 'obj-motor-on', label: 'Motor A girando (PWMA > 0 con dirección)', required: true },
    { id: 'obj-pwm-var',  label: 'Variar velocidad PWM (cambiar el valor)', required: false },
  ],
  validate: function(vars, flags) {
    if (vars.stby_high) _synthFlag('stby_ok', true);
    if (vars.motorA_fwd && vars.stby_high) _synthFlag('dir_ok', true);
    if (vars.motorA_fwd && vars.motorA_pwm > 0 && vars.stby_high) {
      _synthFlag('motor_on', true);
      // Track PWM values seen to detect variation
      const seen = S._synthState._flags._pwm_vals = S._synthState._flags._pwm_vals || {};
      seen[vars.motorA_pwm] = true;
    }
    const pwmVaried = Object.keys(S._synthState?._flags?._pwm_vals||{}).length >= 2;
    return {
      'obj-stby':     !!(flags.stby_ok),
      'obj-dir-set':  !!(flags.dir_ok),
      'obj-motor-on': !!(flags.motor_on),
      'obj-pwm-var':  pwmVaried,
    };
  },
};

