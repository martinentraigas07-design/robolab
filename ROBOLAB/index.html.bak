    }
    return {
      'obj-btn-read':  !!(flags.btn_read || flags.btn_released),
      'obj-btn-press': !!(flags.btn_read),
      'obj-led-react': !!(flags.led_reacts),
      'obj-toggle':    (S._synthState?._flags?._press_ticks||0) >= 3,
    };
  },
};

