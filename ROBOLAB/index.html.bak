  'fk-patrulla':            'concept_maquina_estados',
  'fk-minisumo-config':     'concept_qtr_sensor',
  'fk-seguidor-2sensor':    'concept_control_proporcional',
  'fk-minisumo-pd':         'concept_control_pd',
};

// ── SKETCH OVERRIDES — starter code pedagógico garantizado ────────
// Se usa cuando ch.sketch está vacío o null en el bundle.
// Cada sketch tiene TODO comments que guían al alumno paso a paso.
const SKETCH_OVERRIDES = {
  'u1-explorar-motores': `// ━━━ U1.1 — Explorar los Motores ━━━
// Objetivo: activar AMBOS motores hacia adelante.
// Motor A (Izquierdo): PWMA=D3  AIN1=D5  AIN2=D4
// Motor B (Derecho):   PWMB=D9  BIN1=D7  BIN2=D8
// Driver TB6612FNG necesita STBY (D6) = HIGH para funcionar.

void setup() {
  Serial.begin(9600);
  // Habilitar driver
  pinMode(6, OUTPUT);
  digitalWrite(6, HIGH);   // STBY = HIGH → driver activo
  // Configurar Motor A
  pinMode(3, OUTPUT);       // PWMA
  pinMode(4, OUTPUT);       // AIN2
  pinMode(5, OUTPUT);       // AIN1
  // TODO: configurar pines del Motor B (D9, D7, D8)
}

void loop() {
  // Motor A → ADELANTE: AIN1=HIGH, AIN2=LOW
  digitalWrite(5, HIGH);   // AIN1
  digitalWrite(4, LOW);    // AIN2
  analogWrite(3, 200);     // PWMA — velocidad 0-255

  // TODO: activar Motor B hacia adelante
  // (misma lógica: BIN1=HIGH, BIN2=LOW, analogWrite(PWMB, vel))

  Serial.print("Motor A PWM: ");
  Serial.println(200);
  delay(100);
}`,

  'u1-reactivo-parar': `// ━━━ U1.2 — Reactivo: Parar al detectar obstáculo ━━━
// Sensor Sharp IR en A0: valor BAJO (~100) = objeto CERCA
// valor ALTO (~800) = campo libre

#define UMBRAL 350    // ajustar si necesario
#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

void avanzar() {
  digitalWrite(AIN1, HIGH); digitalWrite(AIN2, LOW); analogWrite(PWMA, 200);
  digitalWrite(BIN1, HIGH); digitalWrite(BIN2, LOW); analogWrite(PWMB, 200);
}
void parar() {
  analogWrite(PWMA, 0); analogWrite(PWMB, 0);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY, HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int distancia = analogRead(A0);
  Serial.println(distancia);
  if (distancia < UMBRAL) {
    parar();           // TODO: ¿qué más puede hacer el robot cuando para?
  } else {
    avanzar();
  }
  delay(50);
}`,

  'u1-reactivo-girar': `// ━━━ U1.3 — Reactivo: Girar al detectar ━━━
// En lugar de parar, el robot gira para esquivar el obstáculo.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6
#define UMBRAL 350

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sensor = analogRead(A0);
  if (sensor < UMBRAL) {
    // Obstáculo: girar derecha (Motor A reversa, Motor B adelante)
    digitalWrite(AIN1, LOW);  digitalWrite(AIN2, HIGH); analogWrite(PWMA, 180);
    digitalWrite(BIN1, HIGH); digitalWrite(BIN2, LOW);  analogWrite(PWMB, 180);
    delay(300);
  } else {
    // Libre: avanzar
    // TODO: implementar avanzar()
  }
}`,

  'u2-millis-no-delay': `// ━━━ U2.2 — Temporizado sin delay() ━━━
// delay() bloquea TODO el programa mientras espera.
// millis() permite hacer múltiples tareas simultáneas.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define STBY 6

unsigned long prevMs = 0;
const long INTERVALO = 500;   // ms entre cambios
bool motorOn = false;

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
}

void loop() {
  unsigned long ahora = millis();

  if (ahora - prevMs >= INTERVALO) {
    prevMs = ahora;
    motorOn = !motorOn;

    if (motorOn) {
      digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);
      analogWrite(PWMA, 200);
      Serial.println("Motor ON");
    } else {
      analogWrite(PWMA, 0);
      Serial.println("Motor OFF");
    }
  }

  // El robot puede leer sensores aquí SIN BLOQUEAR:
  int sensor = analogRead(A0);
  // TODO: usar el sensor mientras el motor alterna
}`,

  'u3-minisumo-borde': `// ━━━ U3.2 — Minisumo: Detectar el Borde ━━━
// Sensor QTR en A0: ALTO (~900) = borde blanco
//                   BAJO  (~80) = tatami negro

#define UMBRAL 700
#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

void avanzar() {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,200);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,200);
}
void retroceder() {
  // TODO: implementar retroceso
}
void girar() {
  // TODO: implementar giro (un motor adelante, otro atrás)
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int qtr = analogRead(A0);
  Serial.print("QTR: "); Serial.println(qtr);

  if (qtr > UMBRAL) {
    // Borde detectado — retroceder y girar
    retroceder(); delay(250);
    girar();      delay(200);
  } else {
    avanzar();
  }
  delay(20);
}`,

  'ms-mantenerse-en-ring': `// ━━━ Minisumo Nv.1 — Mantenerse en el Ring ━━━
// OBJETIVO: avanzar hacia el oponente y EMPUJARLO fuera del ring.
// Sensor borde QTR en A0: ALTO (~900) = borde blanco → escapar
// Sensor distancia IR en A1: BAJO (<350) = oponente cerca → atacar
// STBY (D6) = HIGH habilita el driver TB6612FNG — SIEMPRE necesario.

#define QTR_PIN    A0    // QTR reflectancia — borde blanco=ALTO
#define DIST_PIN   A1    // Sharp IR distancia — cerca=BAJO
#define UMBRAL_BORDE  700  // QTR > 700 → borde detectado
#define UMBRAL_ATAQUE 400  // Sharp < 400 → oponente cerca, atacar

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

// ── Funciones de movimiento ─────────────────────────────────────
void avanzar(int vel) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,vel);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,vel);
}
void retroceder(int vel) {
  digitalWrite(AIN1,LOW); digitalWrite(AIN2,HIGH); analogWrite(PWMA,vel);
  digitalWrite(BIN1,LOW); digitalWrite(BIN2,HIGH); analogWrite(PWMB,vel);
}
void girarDerecha(int vel) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,vel);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,vel);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);  // habilitar driver
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
  delay(300);
  Serial.println("Minisumo Nv.1 listo");
}

void loop() {
  int borde = analogRead(QTR_PIN);   // QTR: ALTO=borde blanco
  int dist  = analogRead(DIST_PIN);  // Sharp IR: BAJO=cerca

  Serial.print("QTR:"); Serial.print(borde);
  Serial.print(" IR:"); Serial.println(dist);

  // 1. PRIORIDAD: evitar caerse del ring
  if (borde > UMBRAL_BORDE) {
    retroceder(220);
    delay(250);
    girarDerecha(200);
    delay(200);
    return;
  }

  // 2. ATACAR: empujar al oponente si está cerca
  if (dist < UMBRAL_ATAQUE) {
    avanzar(255);   // velocidad máxima para empujar
  } else {
    // 3. BUSCAR: avanzar despacio buscando oponente
    avanzar(180);
  }
  delay(20);
}`,

  'lf-pista-recta': `// ━━━ Seguidor de Línea Nv.1 — Pista Recta ━━━
// Sensor QTR en A0: ALTO (>600) = sobre línea negra
//                   BAJO        = fondo blanco/claro

#define QTR A0
#define UMBRAL 600
#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6
#define VEL 180

void setMotorA(int vel) {  // vel: -255 a 255
  if (vel > 0) { digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,vel); }
  else         { digitalWrite(AIN1,LOW);  digitalWrite(AIN2,HIGH); analogWrite(PWMA,-vel); }
}
void setMotorB(int vel) {
  if (vel > 0) { digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW);  analogWrite(PWMB,vel); }
  else         { digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,-vel); }
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int s = analogRead(QTR);
  Serial.println(s);
  if (s > UMBRAL) {
    // Sobre la línea: avanzar recto
    setMotorA(VEL); setMotorB(VEL);
  } else {
    // Fuera de línea: girar buscándola
    // TODO: ¿girar izquierda o derecha? ¿Recordar el último lado?
    setMotorA(VEL); setMotorB(-VEL);  // girar derecha
  }
  delay(10);
}`,

  // E5.2 — fk-minisumo-pd uses ROBOARD pins because the VM runs Arduino C++.
  // The bundle sketch uses ESP32 pins (2,3,4,5) which don't have PWM in ROBOARD HAL.
  // This override uses correct ROBOARD TB6612FNG pin mapping.
  'fk-minisumo-pd': `// ━━━ E5.2 — Minisumo con Control PD ━━━
// Plataforma: ROBOARD (simulación Arduino)
// Pines: TB6612FNG — Motor A (D3,D4,D5), Motor B (D7,D8,D9), STBY (D6)
// Sensores: QTR borde en A0 (~900=borde), Sharp oponente en A1 (~100=cerca)

#define PWMA 3   // Motor A — velocidad (PWM)
#define AIN1 5   // Motor A — dirección adelante=HIGH
#define AIN2 4   // Motor A — dirección (opuesto a AIN1)
#define PWMB 9   // Motor B — velocidad (PWM)
#define BIN1 7   // Motor B — dirección
#define BIN2 8
#define STBY 6   // Driver habilitado cuando HIGH

#define ADC_BORDE   A0   // QTR: ALTO=borde blanco (~900)
#define ADC_OPONENTE A1  // Sharp IR: BAJO=oponente cerca (~100)

#define UMBRAL_BORDE   700   // QTR > 700 → borde detectado
#define UMBRAL_OPONEN  350   // Sharp < 350 → oponente detectado
#define VEL_BASE       180
#define KP 0.04f
#define KD 0.02f

int errorAnterior = 0;  // para el término derivativo

void motorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void motorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}
void move(int vA, int vB) { motorA(vA); motorB(vB); }

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
  delay(300);
  Serial.println("Minisumo PD listo");
}

void loop() {
  int borde    = analogRead(ADC_BORDE);
  int oponente = analogRead(ADC_OPONENTE);

  Serial.print("Borde:"); Serial.print(borde);
  Serial.print(" Opon:"); Serial.println(oponente);

  // 1. PRIORIDAD: evitar borde
  if (borde > UMBRAL_BORDE) {
    move(-200, -200); delay(150);   // retroceder
    move(200,  -200); delay(300);   // girar
    return;
  }

  // 2. OPONENTE: atacar con control PD
  if (oponente < UMBRAL_OPONEN) {
    // Control PD: error = diferencia entre sensores laterales
    // TODO: para PD completo agregar sensor lateral (A2)
    int error = 0;  // sin error lateral → avanzar recto
    int deriv = error - errorAnterior;
    int corr  = (int)(KP * error + KD * deriv);
    errorAnterior = error;
    move(255 - corr, 255 + corr);
  } else {
    // Buscar oponente girando
    move(160, -160);
  }
  delay(10);
}`,

  // ms-buscar-atacar: uses analogRead for distance approximation (safe, no pulseIn tight loops)
  'ms-buscar-atacar': `// ━━━ Minisumo LNR — Buscar y Atacar ━━━
// Estrategia: buscar oponente girando, luego atacar a velocidad máxima
// Sensor distancia en A1 (Sharp IR): BAJO (<350) = oponente cerca
// Sensor borde en A0 (QTR):          ALTO (>700) = borde blanco

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6
#define BORDE_PIN    A0
#define DIST_PIN     A1
#define UMBRAL_BORDE 700
#define UMBRAL_ATAQUE 350

void avanzar(int vel) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,vel);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,vel);
}
void retroceder(int vel) {
  digitalWrite(AIN1,LOW); digitalWrite(AIN2,HIGH); analogWrite(PWMA,vel);
  digitalWrite(BIN1,LOW); digitalWrite(BIN2,HIGH); analogWrite(PWMB,vel);
}
void girarDerecha(int vel) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,vel);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,vel);
}
void parar() { analogWrite(PWMA,0); analogWrite(PWMB,0); }

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
  delay(500);
}

void loop() {
  int borde   = analogRead(BORDE_PIN);
  int distIR  = analogRead(DIST_PIN);

  Serial.print("Borde:"); Serial.print(borde);
  Serial.print(" Dist:"); Serial.println(distIR);

  // 1. Prioridad: evitar el borde blanco
  if (borde > UMBRAL_BORDE) {
    retroceder(200); delay(300);
    girarDerecha(200); delay(400);
    return;
  }

  // 2. Atacar si hay oponente cerca
  if (distIR < UMBRAL_ATAQUE && distIR > 0) {
    avanzar(255);  // máxima velocidad para empujar
  } else {
    // 3. Buscar: girar buscando oponente
    girarDerecha(160);
  }
  delay(20);
}`,

  // E5.1 — fk-seguidor-2sensor: dos sensores QTR con control PD
  'fk-seguidor-2sensor': `// ━━━ E5.1 — Seguidor 2 Sensores con PD ━━━
// Plataforma: ROBOARD  |  Sensores: QTR izquierdo A0, QTR derecho A1
// ~900=sobre línea  ~80=fondo blanco  |  Umbral: 600

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

#define QTR_IZQ A0   // sensor izquierdo
#define QTR_DER A1   // sensor derecho
#define UMBRAL  600   // >600: sobre línea
#define VEL_BASE 180
#define KP 0.5f
#define KD 0.2f

int errorAnterior = 0;

void setMotorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void setMotorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sL = analogRead(QTR_IZQ);
  int sR = analogRead(QTR_DER);

  // Error: positivo = desvío derecha (sR mayor), negativo = desvío izquierda
  int error    = sR - sL;
  int deriv    = error - errorAnterior;
  int corr     = (int)(KP * error + KD * deriv);
  errorAnterior = error;

  setMotorA(constrain(VEL_BASE - corr, -255, 255));
  setMotorB(constrain(VEL_BASE + corr, -255, 255));

  Serial.print("L:"); Serial.print(sL);
  Serial.print(" R:"); Serial.print(sR);
  Serial.print(" err:"); Serial.println(error);
  delay(10);
}`,

  'u2-secuencia-tiempos': `// ━━━ U2.1 — Secuencia con Tiempos ━━━
// El microcontrolador ejecuta instrucciones en orden, una por una.
// delay(ms) hace esperar el programa N milisegundos.
// La SECUENCIA y los TIEMPOS determinan el comportamiento del robot.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  // Paso 1: Avanzar 2 segundos
  Serial.println("▶ Avanzando 2s");
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW); analogWrite(PWMA,200);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW); analogWrite(PWMB,200);
  delay(2000);

  // Paso 2: Girar 1 segundo (Motor A adelante, Motor B atrás)
  Serial.println("↺ Girando 1s");
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,200);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,200);
  delay(1000);

  // TODO: ¿Qué figura geométrica traza el robot si hacés esto 4 veces?
  // Cambiar delay(1000) a delay(750) → ¿cambia la figura?
}`,

  'u2-seguir-pared': `// ━━━ U2.3 — Seguir la Pared ━━━
// Control proporcional: error = distancia_actual - distancia_deseada
// Si error > 0: muy lejos → acercarse
// Si error < 0: muy cerca → alejarse

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

#define DISTANCIA_DESEADA 350  // A0 objetivo (ajustar según distancia real deseada)
#define KP 0.4f                // Ganancia proporcional — subir si reacciona lento

void motorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void motorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sensor = analogRead(A0);
  int error   = sensor - DISTANCIA_DESEADA;
  int corr    = (int)(KP * error);

  Serial.print("A0:"); Serial.print(sensor);
  Serial.print(" err:"); Serial.print(error);
  Serial.print(" corr:"); Serial.println(corr);

  // Motor A: velocidad base + corrección lateral
  int velA = constrain(160 + corr, 0, 255);
  int velB = constrain(160 - corr, 0, 255);  // B opuesto para seguir pared
  motorA(velA); motorB(velB);
  delay(20);
}`,

  'u3-calibrar-ir': `// ━━━ U3.1 — Calibración del Sensor IR ━━━
// Los sensores analógicos varían entre unidades físicas.
// Calibrar = aprender los valores REALES de TU sensor.
// OBJETIVO: anotar el valor mínimo (objeto cerca) y máximo (campo libre)
// para después calcular un umbral confiable.

void setup() {
  Serial.begin(9600);
  Serial.println("=== Calibración Sharp IR ===");
  Serial.println("1. Mantenés el campo libre → anotá el valor MÁXIMO");
  Serial.println("2. Acercás el obstáculo al máximo → anotás el MÍNIMO");
  Serial.println("3. UMBRAL = (MAX + MIN) / 2");
}

void loop() {
  int sensor = analogRead(A0);
  Serial.print("A0: "); Serial.print(sensor);

  // Interpretación en tiempo real
  if      (sensor < 200) Serial.println(" ← MUY CERCA");
  else if (sensor < 400) Serial.println(" ← CERCA");
  else if (sensor < 650) Serial.println(" ← MEDIO");
  else                   Serial.println(" ← LIBRE");

  delay(100);
}`,

  'u3-minisumo-atacar': `// ━━━ U3.3 — Minisumo: Detectar y Atacar ━━━
// HC-SR04 (ultrasónico) en pin A3 para detectar el oponente.
// Cuando está cerca: atacar a full speed.
// Cuando no hay oponente: buscar girando.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6
#define QTR_PIN  A0   // borde blanco: ALTO (~900)
#define HC_ECHO  A3   // eco del HC-SR04

#define UMBRAL_BORDE  700  // QTR > 700 → borde
#define UMBRAL_ATAQUE  20  // distancia en cm para atacar

void avanzar(int v) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,v);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW);  analogWrite(PWMB,v);
}
void retroceder(int v) {
  digitalWrite(AIN1,LOW); digitalWrite(AIN2,HIGH); analogWrite(PWMA,v);
  digitalWrite(BIN1,LOW); digitalWrite(BIN2,HIGH); analogWrite(PWMB,v);
}
void girar(int v) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,v);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,v);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int borde = analogRead(QTR_PIN);
  long us    = pulseIn(HC_ECHO, HIGH);
  int  cm    = us / 58;
  Serial.print("QTR:"); Serial.print(borde);
  Serial.print(" dist:"); Serial.print(cm); Serial.println("cm");

  if (borde > UMBRAL_BORDE) {
    retroceder(220); delay(250);
    girar(200);      delay(300);
    return;
  }
  if (cm > 0 && cm < UMBRAL_ATAQUE) {
    avanzar(255);  // ¡ATACAR!
  } else {
    girar(160);    // buscar
  }
}`,

  'u3-minisumo-estrategia': `// ━━━ U3.4 — Minisumo: Máquina de Estados ━━━
// Una máquina de estados organiza comportamientos complejos.
// El robot alterna entre BUSCAR, ATACAR y ESCAPAR.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

enum Estado { BUSCAR, ATACAR, ESCAPAR };
Estado estado = BUSCAR;

void avanzar(int v) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,v);
  digitalWrite(BIN1,HIGH); digitalWrite(BIN2,LOW);  analogWrite(PWMB,v);
}
void retroceder(int v) {
  digitalWrite(AIN1,LOW); digitalWrite(AIN2,HIGH); analogWrite(PWMA,v);
  digitalWrite(BIN1,LOW); digitalWrite(BIN2,HIGH); analogWrite(PWMB,v);
}
void girar(int v) {
  digitalWrite(AIN1,HIGH); digitalWrite(AIN2,LOW);  analogWrite(PWMA,v);
  digitalWrite(BIN1,LOW);  digitalWrite(BIN2,HIGH); analogWrite(PWMB,v);
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int borde    = analogRead(A0);   // QTR: >700=borde
  int oponente = analogRead(A1);   // Sharp IR: <350=oponente cerca

  switch (estado) {
    case BUSCAR:
      Serial.println("↺ BUSCAR");
      girar(160);
      if (oponente < 350) estado = ATACAR;
      if (borde > 700)    estado = ESCAPAR;
      break;

    case ATACAR:
      Serial.println("▶ ATACAR");
      avanzar(255);
      if (oponente >= 350) estado = BUSCAR;
      if (borde > 700)     estado = ESCAPAR;
      break;

    case ESCAPAR:
      Serial.println("◀ ESCAPAR");
      retroceder(220); delay(200);
      girar(200);      delay(300);
      estado = BUSCAR;
      break;
  }
  delay(20);
}`,

  'u3-seguidor-linea': `// ━━━ U3.5 — Seguidor de Línea Básico ━━━
// Sensor QTR en A0: línea negra sobre fondo blanco.
// ALTO (~900): sobre la línea negra
// BAJO  (~80): sobre el fondo blanco

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6
#define QTR A0
#define UMBRAL 600  // >600: sobre línea negra

void setMotorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void setMotorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int s = analogRead(QTR);
  Serial.print("QTR:"); Serial.println(s);

  if (s > UMBRAL) {
    // Sobre la línea: avanzar recto
    setMotorA(180); setMotorB(180);
  } else {
    // Fuera de línea: girar buscándola
    // TODO: ¿girar izquierda o derecha? ¿Cómo recordar el último lado?
    setMotorA(180); setMotorB(-180);
  }
  delay(10);
}`,

  'u3-seguidor-pd': `// ━━━ U3.6 — Seguidor con Control PD ━━━
// Control Proporcional: corrige según el error actual.
// Control Derivativo: anticipa la corrección usando la TENDENCIA del error.
// Sensor izquierdo: A0, sensor derecho: A1

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

#define VEL_BASE 180
#define KP 0.5f   // subir si no corrige → bajar si oscila
#define KD 0.2f   // subir para amortiguar oscilaciones

int errorAnterior = 0;

void setMotorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void setMotorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sL = analogRead(A0);   // sensor izquierdo
  int sR = analogRead(A1);   // sensor derecho
  int error    = sR - sL;
  int derivada = error - errorAnterior;
  int corr     = (int)(KP * error + KD * derivada);
  errorAnterior = error;

  Serial.print("L:"); Serial.print(sL);
  Serial.print(" R:"); Serial.print(sR);
  Serial.print(" err:"); Serial.println(error);

  setMotorA(constrain(VEL_BASE - corr, -255, 255));
  setMotorB(constrain(VEL_BASE + corr, -255, 255));
  delay(10);
}`,

  'u3-seguidor-qtr8': `// ━━━ U3.7 — Seguidor con QTR-8 Array ━━━
// 8 sensores de reflectancia en línea.
// Posición de la línea = promedio ponderado de las 8 lecturas.
// Posición 0=extremo izquierdo, 7000=extremo derecho, 3500=centro

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

const int PINES_QTR[8] = {A0,A1,A2,A3,A4,A5,A6,A7};
#define VEL_BASE 180
#define KP 0.08f
#define KD 0.05f

int errorAnterior = 0;

void setMotorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void setMotorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  long suma = 0, total = 0;
  for(int i=0;i<8;i++){
    int v = analogRead(PINES_QTR[i]);
    suma  += (long)v * i * 1000;
    total += v;
  }
  int pos = total > 0 ? (int)(suma / total) : 3500;  // 0-7000, centro=3500
  int error    = pos - 3500;  // error respecto al centro
  int derivada = error - errorAnterior;
  int corr     = (int)(KP * error + KD * derivada);
  errorAnterior = error;

  Serial.print("pos:"); Serial.print(pos); Serial.print(" err:"); Serial.println(error);
  setMotorA(constrain(VEL_BASE - corr, -255, 255));
  setMotorB(constrain(VEL_BASE + corr, -255, 255));
  delay(10);
}`,

  'lf-curvas': `// ━━━ LNR — Seguidor de Línea en Curvas ━━━
// Las curvas requieren reacción más rápida y correcciones más fuertes.
// El término D anticipa el cambio ANTES de que ocurra.
// Ajustar KP y KD iterativamente observando el comportamiento.

#define PWMA 3
#define AIN1 5
#define AIN2 4
#define PWMB 9
#define BIN1 7
#define BIN2 8
#define STBY 6

#define VEL_BASE 200
#define KP 0.6f   // más alto que en pista recta — curvas necesitan más corrección
#define KD 0.4f   // amortiguación para no sobrepasar

int errorAnterior = 0;

void setMotorA(int vel) {
  if(vel>=0){digitalWrite(AIN1,HIGH);digitalWrite(AIN2,LOW);analogWrite(PWMA,constrain(vel,0,255));}
  else{digitalWrite(AIN1,LOW);digitalWrite(AIN2,HIGH);analogWrite(PWMA,constrain(-vel,0,255));}
}
void setMotorB(int vel) {
  if(vel>=0){digitalWrite(BIN1,HIGH);digitalWrite(BIN2,LOW);analogWrite(PWMB,constrain(vel,0,255));}
  else{digitalWrite(BIN1,LOW);digitalWrite(BIN2,HIGH);analogWrite(PWMB,constrain(-vel,0,255));}
}

void setup() {
  Serial.begin(9600);
  pinMode(STBY,OUTPUT); digitalWrite(STBY,HIGH);
  pinMode(PWMA,OUTPUT); pinMode(AIN1,OUTPUT); pinMode(AIN2,OUTPUT);
  pinMode(PWMB,OUTPUT); pinMode(BIN1,OUTPUT); pinMode(BIN2,OUTPUT);
}

void loop() {
  int sL = analogRead(A0);
  int sR = analogRead(A1);
  int error    = sR - sL;
  int derivada = error - errorAnterior;
  int corr     = (int)(KP * error + KD * derivada);
  errorAnterior = error;

  Serial.print("L:"); Serial.print(sL);
  Serial.print(" R:"); Serial.print(sR);
  Serial.print(" corr:"); Serial.println(corr);

  setMotorA(constrain(VEL_BASE - corr, -255, 255));
  setMotorB(constrain(VEL_BASE + corr, -255, 255));
  delay(8);  // loop más rápido para reaccionar a curvas cerradas
}`,

};

function getChallengeSketch(id) {
  // For synthetic challenges, return the sketch defined inline
  if (SYNTHETIC_CHALLENGES[id]?.sketch) return SYNTHETIC_CHALLENGES[id].sketch;
  const ch = getChallenge(id);
  if (!ch) return '';
  // For minisumo and LNR challenges: our SKETCH_OVERRIDES take PRIORITY over the bundle.
  // The bundle sketches for these challenges may use HC-SR04 with patterns that
  // cause the VM to run tight loops (e.g., waiting for echo pulse), which freezes
  // the page. Our overrides use safe analogRead() patterns instead.
  const OVERRIDE_PRIORITY = [
    'ms-mantenerse-en-ring','ms-buscar-atacar',
    'u3-minisumo-borde','u3-minisumo-atacar','u3-minisumo-estrategia',
    'fk-minisumo-pd','fk-seguidor-2sensor',
  ];
  if (OVERRIDE_PRIORITY.includes(id) && SKETCH_OVERRIDES[id]) {
    return SKETCH_OVERRIDES[id];
  }
  // Default: bundle sketch first (student may have improved it), then our override
  if (ch.sketch && typeof ch.sketch === 'string' && ch.sketch.trim()) return ch.sketch;
  return SKETCH_OVERRIDES[id] || '';
}

// ── MANUAL CONTENT — contenido pedagógico garantizado ─────────────
// Fallback independiente del bundle. Se combina con sections del bundle.
// Si el bundle tiene body vacío → se usa este contenido.
const MANUAL_CONTENT = {
  'puente-h': {
    title: 'Control de Motores — TB6612FNG',
    body: `PINES DEL DRIVER (ROBOARD):
  PWMA  D3  — velocidad Motor A (analogWrite 0-255)
  AIN1  D5  — dirección Motor A (HIGH = adelante)
  AIN2  D4  — dirección Motor A (LOW  = adelante)
  STBY  D6  — habilitar driver  (SIEMPRE HIGH)
  PWMB  D9  — velocidad Motor B (analogWrite 0-255)
  BIN1  D7  — dirección Motor B (HIGH = adelante)
  BIN2  D8  — dirección Motor B (LOW  = adelante)

ADELANTE (ambos motores):
  digitalWrite(6, HIGH); // STBY habilitado — sin esto nada funciona
  digitalWrite(5, HIGH); digitalWrite(4, LOW);  // AIN1=H, AIN2=L
  analogWrite(3, 200);   // PWMA — velocidad 0 a 255
  digitalWrite(7, HIGH); digitalWrite(8, LOW);  // BIN1=H, BIN2=L
  analogWrite(9, 200);   // PWMB — velocidad 0 a 255

REVERSA: invertir AIN1/AIN2 y BIN1/BIN2
GIRAR: un motor adelante, el otro en reversa o detenido
FRENAR: analogWrite(3,0) y analogWrite(9,0)

¿CÓMO PROBARLO?
  1. Cargá el sketch (↑ Cargar)
  2. Presioná ▶ Ejecutar
  3. Abrí el tab Hardware → mirá Motor A y Motor B
  4. Si el robot no avanza: verificá que STBY=HIGH (D6)`,
    context: {
      'u1-explorar-motores': '→ En este desafío: Motor A ya está configurado en el starter code. Completá Motor B en los TODO.',
      'u1-reactivo-parar':   '→ Las funciones avanzar() y parar() ya están. Ajustá el umbral UMBRAL según la distancia deseada.',
      'u1-reactivo-girar':   '→ Para girar: Motor A adelante + Motor B reversa (o viceversa). Duracion ~300ms.',
    }
  },
  'sharp-ir': {
    title: 'Sensor Sharp GP2Y0A21 — Distancia IR',
    body: `CONEXIÓN: Salida analógica → Pin A0
LECTURA:  analogRead(A0) devuelve 0 a 1023

INTERPRETACIÓN DE VALORES:
  ~100-200  = objeto muy cercano (<10 cm)
  ~300-450  = objeto a 15-25 cm  ← umbral típico aquí
  ~600-800  = objeto lejos (>40 cm)
  ~900+     = campo libre, sin obstáculo

UMBRAL RECOMENDADO: 350 detecta obstáculos a ~20 cm

¿POR QUÉ EL VALOR BAJA CUANDO HAY OBSTÁCULO?
  El sensor emite IR y mide el ángulo de reflexión.
  Objeto cercano → ángulo grande → voltaje mayor → A0 BAJO.
  La relación no es lineal (curva inversa).

¿CÓMO PROBARLO EN LA SIMULACIÓN?
  1. Ejecutá cualquier sketch con Serial.begin(9600)
  2. Mirá el HUD inferior izquierdo → "A0 Sharp"
  3. Arrastrá el obstáculo rojo hacia el robot
  4. El valor de A0 debería BAJAR cuando el obstáculo se acerca
  5. El robot se pone en rojo cuando A0 < 350`,
    context: {
      'u1-reactivo-parar': '→ if (analogRead(A0) < UMBRAL) → parar. Ajustá UMBRAL entre 300 y 500.',
      'u1-reactivo-girar': '→ Mismo sensor. Ahora el robot gira en vez de parar al detectar el obstáculo.',
      'u2-seguir-pared':   '→ El robot mantiene distancia fija. Si A0 < umbral: aleja. Si A0 > umbral: acerca.',
    }
  },
  'qtr': {
    title: 'Sensor QTR — Reflectancia (Línea y Borde)',
    body: `CONEXIÓN: Salida analógica → A0 (o A6 en algunos challenges)
LECTURA:  analogRead(A0) devuelve 0 a 1023

VALORES (opuesto al Sharp IR):
  ~900  = superficie CLARA (borde blanco, fondo claro)
  ~80   = superficie OSCURA (tatami negro, línea negra)

UMBRAL RECOMENDADO: 700 separa blanco de negro

DIFERENCIA CLAVE CON SHARP IR:
  • QTR mide REFLECTANCIA (luz reflejada), no distancia.
  • En minisumo: tatami negro = BAJO, borde blanco = ALTO.
  • En seguidor:  línea negra  = ALTO, fondo blanco = BAJO.
  • El comportamiento parece invertido pero tiene sentido:
    más reflectancia → más luz → valor más alto.

¿CÓMO PROBARLO?
  1. Cargá un challenge minisumo o seguidor de línea
  2. Ejecutá y mirá el HUD: "A0 QTR"
  3. El indicador se pone ROJO cuando detecta el borde/línea
  4. Arrastrá el robot hasta el borde del ring → A0 sube`,
    context: {
      'u3-minisumo-borde':    '→ Si (qtr > 700): BORDE detectado → retroceder y girar.',
      'ms-mantenerse-en-ring':'→ El pin es A6 (solo analógico en Arduino). Umbral = 700.',
      'lf-pista-recta':       '→ En seguidor de línea: línea negra = ALTO (~900). Fondo blanco = BAJO (~80).',
    }
  },
  'millis': {
    title: 'Temporizado sin delay() — millis()',
    body: `¿POR QUÉ delay() ES PROBLEMÁTICO?
  delay(1000) bloquea TODO el programa por 1 segundo.
  Durante ese segundo: el robot NO puede leer sensores,
  no puede reaccionar a obstáculos, no puede hacer nada.
  Resultado: robot ciego mientras espera.

LA SOLUCIÓN — millis():
  unsigned long prevMs  = 0;
  const long    INTERVALO = 500;  // ms entre acciones

  void loop() {
    unsigned long ahora = millis();
    if (ahora - prevMs >= INTERVALO) {
      prevMs = ahora;
      // ejecutar acción periódica aquí
    }
    // El robot puede leer sensores sin bloquear:
    int sensor = analogRead(A0);
    if (sensor < 350) { /* reaccionar */ }
  }

millis() devuelve ms transcurridos desde que arrancó.
La diferencia (ahora - prevMs) es el tiempo transcurrido.

MÚLTIPLES TIMERS:
  Podés tener varios prevMs independientes para
  diferentes acciones en el mismo loop().

¿CÓMO PROBARLO?
  1. Cargá el starter code del challenge u2-millis
  2. Ejecutá y mirá el Serial Monitor
  3. Deberías ver "ON" / "OFF" alternando cada 500ms
  4. El robot no debe "congelarse" entre cambios`,
    context: {
      'u2-millis-no-delay':    '→ El starter code ya tiene la estructura. Completá las acciones en motorOn y motorOff.',
      'ms-mantenerse-en-ring': '→ Usá millis() para temporizar el retroceso+giro de escape sin bloquear el sensor.',
    }
  },
  'control-pd': {
    title: 'Control Proporcional y PD — Seguidor de Línea',
    body: `CONTROL ON/OFF (simple pero ineficiente):
  if (sensor > umbral) girar_derecha();
  else                  girar_izquierda();
  → El robot zigzaguea mucho, velocidad baja.

CONTROL PROPORCIONAL (P):
  int error   = sensorIzq - sensorDer;  // diferencia
  int velA    = VEL_BASE - Kp * error;
  int velB    = VEL_BASE + Kp * error;
  → El robot gira más suave según cuánto se desvió.
  Kp típico: 0.3 a 1.5 para este simulador.

CONTROL PD (Proporcional + Derivativo):
  int error      = sensorIzq - sensorDer;
  int derivativo = error - errorAnterior;
  int velA       = VEL_BASE - (Kp*error + Kd*derivativo);
  int velB       = VEL_BASE + (Kp*error + Kd*derivativo);
  errorAnterior  = error;
  → Anticipa la corrección. Más estable en curvas.
  Kd típico: 0.1 a 0.8.

¿CÓMO CALIBRAR Kp y Kd?
  1. Empezar con Kp=0.5, Kd=0
  2. Aumentar Kp hasta que el robot siga la línea pero oscile
  3. Agregar Kd (0.1) hasta que las oscilaciones se amortigüen
  4. Repetir hasta lograr seguimiento suave`,
