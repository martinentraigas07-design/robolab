  objectives: [
    { id: 'obj-moved',    label: 'Robot avanza (Motor A activo)', required: true },
    { id: 'obj-stopped',  label: 'Robot para al detectar obstáculo', required: true },
    { id: 'obj-reactive', label: 'Ciclo reactivo completo (avanza ↔ para ≥ 2 veces)', required: true },
