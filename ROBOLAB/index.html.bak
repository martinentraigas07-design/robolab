  ],
  validate: function(vars, flags) {
    if (vars.motorA_fwd && vars.motorA_pwm > 0 && vars.stby_high) _synthFlag('moved_ok', true);
    if (flags.moved_ok && vars.motorA_pwm === 0 && vars.a0_raw < 350) _synthFlag('stopped_ok', true);
    if (flags.moved_ok && flags.stopped_ok) {
      S._synthState._flags._cycles = (S._synthState._flags._cycles||0);
      if (vars.motorA_fwd && vars.motorA_pwm > 0) {
        if (!S._synthState._flags._in_move) {
          S._synthState._flags._in_move = true;
          S._synthState._flags._cycles++;
        }
      } else { S._synthState._flags._in_move = false; }
    }
    if (vars.motorA_pwm >= 150 && vars.motorA_fwd) _synthFlag('pwm200', true);
    const cycles = S._synthState?._flags?._cycles || 0;
    return {
      'obj-moved':    !!(flags.moved_ok),
      'obj-stopped':  !!(flags.stopped_ok),
      'obj-reactive': cycles >= 2,
      'obj-pwm200':   !!(flags.pwm200),
    };
  },
};


