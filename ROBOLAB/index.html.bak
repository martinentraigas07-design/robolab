};

// Merge MANUAL_CONTENT with bundle sections for _renderManual
function getManualSections() {
  const bundleSections = (A && A._MANUAL_SECTIONS) ? A._MANUAL_SECTIONS : [];
  const result = bundleSections.map(function(s) {
    var override = MANUAL_CONTENT[s.id];
    if (!override) return s;
    return {
      id: s.id,
      title: override.title || s.title,
      body: (s.body && s.body.trim()) ? s.body : override.body,
      _context: override.context || {},
    };
  });
  // Add sections that exist in MANUAL_CONTENT but not in bundle
  Object.keys(MANUAL_CONTENT).forEach(function(id) {
    if (!bundleSections.find(function(s){ return s.id===id; })) {
      result.push({
        id: id,
        title: MANUAL_CONTENT[id].title,
        body: MANUAL_CONTENT[id].body,
        _context: MANUAL_CONTENT[id].context || {},
      });
    }
  });
  return result;
}

// Scene descriptors come from RL.getScene() — see content/scenes/scene-library.js

// ══════════════════════════════════════════════════════════════
// SENSOR SIMULATION
// ══════════════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════════════
// QTR SENSOR SIMULATION
// Reflectance-based: returns high value (~900) for light surfaces,
// low value (~80) for dark surfaces.
// ══════════════════════════════════════════════════════════════

/**
 * qtrSample(robot, scene, offsetX, offsetY)
 * Simulates a QTR reflective sensor at an offset from robot center.
 * Returns: ~900 = white/light surface, ~80 = black/dark surface
 */
function qtrSample(r, scene, ox, oy) {
  if (!r || !scene) return 80;
  // Sensor position in world coords
  const sx = r.x + Math.cos(r.angle)*(10+(ox||0)) - Math.sin(r.angle)*(oy||0);
  const sy = r.y + Math.sin(r.angle)*(10+(ox||0)) + Math.cos(r.angle)*(oy||0);
  const W  = cvs.width || 800, H = cvs.height || 500;

  // Check if sensor is over any 'line' layer
  for (const layer of (scene.layers || [])) {
    if (layer.type === 'line') {
      if (isPointOnLine(sx, sy, layer, W, H)) {
        return 880 + Math.random() * 40;  // dark line = HIGH (black tape reflects poorly but QTR inverts)
      }
    }
  }
  // Default for line-follower: white background
  return 60 + Math.random() * 40;  // white background = LOW
}

/**
 * qtrRing(robot, scene)
 * For minisumo: detects if robot's front sensor is over the white border ring.
 * Returns: ~900 = white border, ~80 = black tatami
 */
function qtrRing(r, scene) {
  if (!r || !scene) return 80;
  const W = cvs.width || 800, H = cvs.height || 500;

  // Sensor position: front-center of robot
  const sx = r.x + Math.cos(r.angle) * 16;
  const sy = r.y + Math.sin(r.angle) * 16;

  for (const layer of (scene.layers || [])) {
    if (layer.type === 'ring' && layer.id === 'tatami') {
      const cx = layer.xf * W, cy = layer.yf * H;
      const r2 = layer.rf * Math.min(W, H);
      const dist = Math.sqrt((sx-cx)**2 + (sy-cy)**2);
      // Inside the ring (black tatami) = LOW
      // Near the white border stroke = HIGH
      // Outside = HIGH (also white/light)
      const borderWidth = (layer.strokeWidth || 6) * 1.5;
      if (dist < r2 - borderWidth) {
        return 60 + Math.random() * 30;   // black tatami = LOW
      } else {
        return 850 + Math.random() * 80;  // white border or outside = HIGH
      }
    }
  }
  return 80;
}

/**
 * hcsr04Sample(robot, obstacles)
 * Simulates HC-SR04 ultrasonic sensor returning time in microseconds.
 * In real hardware: time = 2 * distance_cm * 29.1 µs/cm
 * Returns 0 if no obstacle in range (equiv to timeout).
 * Range: effective 2cm–400cm, but pedagogy focuses on <50cm detection.
 */
function hcsr04Sample(r, obs) {
  if (!r || !obs) return 0;
  // Sensor shoots forward from robot center
  const dist_px = irRaycast(r, obs, 0, 0, 0); // pixels from robot front
  if (dist_px === Infinity || dist_px > 400) return 0; // out of range → timeout
  const dist_cm = Math.max(2, dist_px * 0.35); // rough px→cm conversion
  return Math.round(dist_cm * 58); // time_µs = distance_cm * 58µs/cm
}

/**
 * irRaycast — raw distance in pixels (no ADC conversion)
 */
function irRaycast(r, obs, ox, oy, ao) {
  const a  = r.angle + (ao||0);
  const sx = r.x + Math.cos(r.angle)*(14+(ox||0)) - Math.sin(r.angle)*(oy||0);
  const sy = r.y + Math.sin(r.angle)*(14+(ox||0)) + Math.cos(r.angle)*(oy||0);
  const dx = Math.cos(a), dy = Math.sin(a);
  let t = Infinity;
  for (const o of (obs||[])) {
    if (!o || o.w===undefined) continue;
    const ix=dx?1/dx:Infinity, iy=dy?1/dy:Infinity;
    const x1=(o.x-sx)*ix, x2=(o.x+o.w-sx)*ix;
    const y1=(o.y-sy)*iy, y2=(o.y+o.h-sy)*iy;
    const mn=Math.max(Math.min(x1,x2),Math.min(y1,y2));
    const mx=Math.min(Math.max(x1,x2),Math.max(y1,y2));
    if (mx>=0 && mn<=mx && mn<t) t=mn;
  }
  return t;
}

/**
 * isPointOnLine(px, py, lineLayer, W, H)
 * Checks if point (px,py) is within lineWidth/2 of the line path.
 */
function isPointOnLine(px, py, layer, W, H) {
  const pts = (layer.points || []).map(p => ({ x: p.xf*W, y: p.yf*H }));
  if (pts.length < 2) return false;
  const halfWidth = (layer.lineWidth || 18) / 2 + 2; // +2 for sensor tolerance

  for (let i = 0; i < pts.length - 1; i++) {
    const ax=pts[i].x, ay=pts[i].y, bx=pts[i+1].x, by=pts[i+1].y;
    const abx=bx-ax, aby=by-ay, len2=abx*abx+aby*aby;
    if (len2 === 0) continue;
    const t = Math.max(0, Math.min(1, ((px-ax)*abx+(py-ay)*aby)/len2));
    const cx=ax+t*abx, cy=ay+t*aby;
    const dist = Math.sqrt((px-cx)**2+(py-cy)**2);
    if (dist <= halfWidth) return true;
  }
  return false;
}

function irSample(r, obs, ox, oy, ao) {
  if (!r || !obs) return 80;
  const a  = r.angle + (ao||0);
  const sx = r.x + Math.cos(r.angle)*(14+(ox||0)) - Math.sin(r.angle)*(oy||0);
  const sy = r.y + Math.sin(r.angle)*(14+(ox||0)) + Math.cos(r.angle)*(oy||0);
  const dx = Math.cos(a), dy = Math.sin(a);
  let t = Infinity;
  for (const o of obs) {
    if (!o || o.w === undefined) continue;
    const ix=dx?1/dx:Infinity, iy=dy?1/dy:Infinity;
    const x1=(o.x-sx)*ix, x2=(o.x+o.w-sx)*ix;
    const y1=(o.y-sy)*iy, y2=(o.y+o.h-sy)*iy;
    const mn=Math.max(Math.min(x1,x2),Math.min(y1,y2));
    const mx=Math.min(Math.max(x1,x2),Math.max(y1,y2));
    if (mx>=0 && mn<=mx && mn<t) t=mn;
  }
  if (t===Infinity) return 80;
  const d = Math.max(10, Math.min(80, (t/280)*80));
  const v = Math.max(.4, Math.min(3.1, 18/(d-1)));
  return Math.max(0, Math.min(1023, Math.floor((v/5)*1023)));
}

// ══════════════════════════════════════════════════════════════
// APP STATE — single canonical state object
// ══════════════════════════════════════════════════════════════
// ── FRANKY simulator instance ────────────────────────────────────
// Lazily initialized when a FRANKY challenge is loaded.
let franky = null;
function getFranky() {
  if (!franky) {
    franky = new RL.FrankySimulator(eco.eventBus);
  }
  return franky;
}

const S = {
  view:        'home',
  ss:          'IDLE',
  cid:         null,
  code:        '',
  simTime:     0,
  speed:       1,
  tab:         'ch',
  thQ:         [],
  thShown:     new Set(),
  _hintIdx:    {},
  log:         [],
  activeScene: null,  // current SceneDescriptor — set by applyScene()
  _sessionLog: [],   // [{t,cid,event,data}] pedagogic session events
  _frankyLedPwm: null, // local PWM state fallback for FRANKY LED
  _teacherNotes: '', // free-form docente notes, persisted across sessions
};

// ══════════════════════════════════════════════════════════════
// SIM LOOP — clean lifecycle
// ══════════════════════════════════════════════════════════════
let gen=null, pend=null, run=false, raf=null, lts=0, acc=0, uiF=0, spkF=0;
let prevA0=-1, prevA1=-1, prevDA='', prevDB='', prevPA=-1, prevPB=-1;

// FPS watchdog
const FPS = {
  ema:30, alpha:.12, frames:0, lastSec:0, raw:0, state:'ok',
  tick(ts) {
    this.frames++;
    if (ts-this.lastSec >= 1000) {
      this.raw = Math.round(this.frames*1000/(ts-this.lastSec));
      this.ema = Math.round(this.ema*(1-this.alpha)+this.raw*this.alpha);
      this.frames=0; this.lastSec=ts;
      if (this.ema < 10 && S.speed > 0.5) {
        S.speed = Math.max(0.5, S.speed/2);
        $('spdi').value=S.speed; $('spdl').textContent=S.speed+'×';
        ser('[SYS] FPS bajo — velocidad reducida automáticamente.','i');
      }
    }
  },
};

// ── FRANKY Bloques VM Executor ────────────────────────────────────
// Executes one instruction from the FrankySimulator's program bytecode
// every N milliseconds, simulating the real firmware's execution loop.
const _bloquesState = {
  ip: 0,              // instruction pointer
  waitUntil: 0,       // simTime when current delay expires
  varGlobal: 0,       // varGlobal register (used by ADC_READ, IF_GT, IF_LT)
  _wasRunning: false, // tracks Blockly active → used by loop() to detect FIN completion
};

function bloquesVMStep(simTime) {
  if (!franky) return;
  const s = franky.getState();
  const prog = s.program;
  if (!prog || prog.length === 0) return;

  // Wait if we're in a delay
  if (simTime < _bloquesState.waitUntil) return;

  // Clamp IP
  if (_bloquesState.ip >= prog.length) {
    _bloquesState.ip = 0; // loop back like REPEAT(0)
    franky.handleRequest('POST', '/bloques/stop');
    return;
  }

  const inst = prog[_bloquesState.ip];
  const op = inst.op, val = inst.val;

  // Show active instruction in Blockly FS header for causal visibility
  const _opNames={0:'FIN',1:'▶ ADE',2:'◀ ATR',3:'↺ IZQ',4:'↻ DER',5:'■ STOP',6:'⏱ ESP',7:'💡 LED_ON',8:'💡 LED_OFF',9:'IF_DIST',30:'📡 ADC',60:'VAR_SET',70:'IF>',71:'IF<',74:'REPETIR'};
  const opEl = $('bly-active-op');
  if (opEl) opEl.textContent = (_opNames[op]||'OP'+op) + (val>0?' '+val+'ms':'');
  // Pedagogic log (debug mode only)
  if (_consoleFilter === 'all') {
    ser('▶ ['+(_bloquesState.ip+1)+'] '+(_opNames[op]||'OP'+op)+(val>0?' ('+val+'ms)':''), 'f');
  }

  switch (op) {
    case 0: // FIN
      _bloquesState.ip = 0;
      franky.handleRequest('POST', '/bloques/stop');
      const _opClear = $('bly-active-op'); if (_opClear) _opClear.textContent = '';
      return;
    case 1: // ADE — avanzar val ms
      franky.handleRequest('POST', '/mv', {d:'f', val: s.motorSpeed});
      _bloquesState.waitUntil = simTime + (val > 0 ? val : 500);
      break;
    case 2: // ATR — retroceder val ms
      franky.handleRequest('POST', '/mv', {d:'b', val: s.motorSpeed});
      _bloquesState.waitUntil = simTime + (val > 0 ? val : 500);
      break;
    case 3: // IZQ — girar izq val ms
      franky.handleRequest('POST', '/mv', {d:'l', val: s.motorSpeed});
      _bloquesState.waitUntil = simTime + (val > 0 ? val : 300);
      break;
    case 4: // DER — girar der val ms
      franky.handleRequest('POST', '/mv', {d:'r', val: s.motorSpeed});
      _bloquesState.waitUntil = simTime + (val > 0 ? val : 300);
      break;
    case 5: // STOP
      franky.handleRequest('POST', '/st');
      break;
    case 6: // ESP — esperar val ms
      franky.handleRequest('POST', '/st');
      _bloquesState.waitUntil = simTime + (val > 0 ? val : 100);
      break;
    case 7: // LED_ON
      franky.handleRequest('POST', '/led/on');
      break;
    case 8: // LED_OFF
      franky.handleRequest('POST', '/led/off');
      break;
    case 30: { // ADC_READ — read sensor channel, store in varGlobal
      // val = GPIO channel (0=ADC0, 1=ADC1) — matches f_adc field value
      const _ch = val || 0;
      let _adcVal = 0;
      if (franky) {
        _adcVal = _ch === 1 ? franky.getState().a1 : franky.getState().a0;
      } else {
        const _pin = _ch === 1 ? 'A1' : 'A0';
        _adcVal = Math.round((eco.hal.getAllPins()[_pin]?.value||0) * 4095/1023);
      }
      _bloquesState.varGlobal = _adcVal;
      // Show ADC reading in Blockly FS header for pedagogic visibility
      // The student sees exactly what value the sensor returned
      const _opElAdc = $('bly-active-op');
      if (_opElAdc) _opElAdc.textContent = '📡 ADC' + _ch + ': ' + _adcVal;
      break;
    }
    case 70: { // IF_GT val — if varGlobal > val: execute DO block, else skip
      if (_bloquesState.varGlobal <= val) {
        // skip the entire DO block (inst.skip = #DO_instructions + 1)
        _bloquesState.ip += (inst.skip || 2);
        return;
      }
      break;
    }
    case 71: { // IF_LT val — if varGlobal < val: execute DO block, else skip
      if (_bloquesState.varGlobal >= val) {
        _bloquesState.ip += (inst.skip || 2);
        return;
      }
      break;
    }
    case 74: // REPEAT idx — jump to instruction idx
      _bloquesState.ip = Math.max(0, Math.min(val, prog.length - 1));
      return; // don't increment IP
    case 11: // FRENO — brake (stop with active braking)
      franky.handleRequest('POST', '/st');  // same as STOP for sim
      break;
    case 20: { // DOUT — digital output to GPIO pin
      // val encoding: GPIO_number * 10 + (1=HIGH / 0=LOW)
      const _gpio = Math.floor(val / 10);
      const _high = (val % 10) === 1;
      // Map FRANKY GPIO to a HAL-compatible pin for extLeds rendering
      // extLeds reads eco.hal.getAllPins() for non-GPIO8 pins
      const _pinMap = {0:'A0',1:'A1',2:'A2',3:'A3',4:'A4',5:'A5'};
      const _halPin = _gpio === 8 ? null : _pinMap[_gpio];
      if (_gpio === 8) {
        // GPIO8 is the onboard LED — use /led/on or /led/off
        franky.handleRequest('POST', _high ? '/led/on' : '/led/off');
      } else if (_halPin) {
        // Other GPIOs: inject into HAL for extLeds canvas rendering
        try { eco.hal.setPin(_halPin, _high ? 1 : 0); } catch(e) {}
      }
      break;
    }
    case 22: { // PWM_OUT — PWM on GPIO (LED brightness, motor speed)
      // val encoding: gpio_num * 256 + duty (0-255)
      // GPIO8 = onboard LED → /led/brillo sets ledState=2, ledBrillo=duty
      const _pwmGpio = Math.floor(val / 256);
      const _duty    = val % 256;
      if (_pwmGpio === 8) {
        // LED PWM: duty=0 → off, duty>0 → brillo mode (ledState=2, visible in canvas)
        if (_duty === 0) {
          franky.handleRequest('POST', '/led/off');
        } else {
          franky.handleRequest('POST', '/led/brillo', {val: _duty});
        }
        // Local fallback: store duty in S._frankyLedPwm
        // Used by draw() if bundle doesn't set ledBrillo in getState()
        S._frankyLedPwm = {duty: _duty, active: _duty > 0};
      } else {
        // Other GPIO: inject into HAL for extLeds canvas rendering
        const _pinMapP = {0:'A0',1:'A1',2:'A2',3:'A3',4:'A4',5:'A5'};
        const _halPinP = _pinMapP[_pwmGpio];
        if (_halPinP) {
          // Scale duty to 0/1 for extLeds (on if duty > 0)
          try { eco.hal.setPin(_halPinP, _duty > 0 ? 1 : 0); } catch(e) {}
        }
      }
      _bloquesState.varGlobal = _duty;
      break;
    }
    case 60: // VAR_SET — set varGlobal to literal value
      _bloquesState.varGlobal = val;
      break;
    case 61: // VAR_ADD — add val to varGlobal
      _bloquesState.varGlobal = (_bloquesState.varGlobal || 0) + val;
      break;
    case 62: // VAR_SUB — subtract val from varGlobal
      _bloquesState.varGlobal = (_bloquesState.varGlobal || 0) - val;
      break;
    default:
      break; // unknown op: skip
  }

  _bloquesState.ip++;
}

// ── FRANKY Autonomous Sumo AI ────────────────────────────────────
// Implements mode=1 (MICRO) and mode=2 (MINI) autonomous robot behavior.
// The FrankySimulator in the bundle has no periodic tick() method —
// it only exposes handleRequest(). We drive the AI from here using
// the already-injected sensor values (a0=borde QTR, a1=HC-SR04 distance).
//
// Strategy:
//   a0 (12-bit, from QTR):  > 2700 = borde blanco detectado
//   a1 (12-bit, from HCSR04): > 0 = oponente en rango
//   If border: retroceder + girar
//   If oponente: atacar
//   Else: buscar (girar buscando)
let _sumoState = { phase: 'search', phaseMs: 0, lastDir: 'l' };

function frankyAutonomousStep() {
  if (!franky) return;
  const fs = franky.getState();
  if (!fs.running) return;
  if (fs.mode !== 1 && fs.mode !== 2) return;

  const a0 = fs.a0;   // QTR borde (12-bit): > 2700 borde blanco
  const a1 = fs.a1;   // HC-SR04 / Sharp (12-bit): > 300 oponente detectado
  const spd = fs.motorSpeed || 200;

  // Try bundle's own tick method first (future-proof if bundle adds it)
  if (typeof franky.tick === 'function') {
    franky.tick(16.67);
    return;
  }
  if (typeof franky.step === 'function') {
    franky.step(16.67);
    return;
  }

  // ── Read config from UI sliders (or use defaults) ──────────────
  const _cfg = S._sumoConfig || {};
  const BORDER_THRESHOLD = _cfg.thrBorde !== undefined ? _cfg.thrBorde : 2700;
  const ATTACK_THRESHOLD = _cfg.thrAtk   !== undefined ? _cfg.thrAtk   : 400;
  // Attack trim: independent sliders control straightness during charge
  const atkA  = _cfg.atkA  !== undefined ? _cfg.atkA  : (fs.trimA || 255);
  const atkB  = _cfg.atkB  !== undefined ? _cfg.atkB  : (fs.trimB || 255);
  // Search trim: independent sliders control arc/spin during scan
  const srchA = _cfg.srchA !== undefined ? _cfg.srchA : 160;
  const srchB = _cfg.srchB !== undefined ? _cfg.srchB : 160;

  // ── Helper: apply differential motor command directly ─────────
  // The /mv endpoint only takes ONE val for both motors.
  // To achieve different speeds per motor, we use /mv to set direction
  // and then immediately override via /sumo/trim on each call.
  // Simpler approach: use /mv for direction + pass separate trim values.
  // Since FrankySimulator's getMotorCmds() uses internal trimA/trimB,
  // we temporarily set trim to match our desired differential.
  const _driveDiff = (velA, velB) => {
    const _maxV = Math.max(Math.abs(velA), Math.abs(velB), 1);
    // Set trim ratio so simulator applies correct differential
    franky.handleRequest('POST', '/sumo/trim', {
      ma: Math.round(255 * Math.abs(velA) / _maxV),
      mb: Math.round(255 * Math.abs(velB) / _maxV)
    });
    // Determine direction from average
    const _dir = (velA >= 0 && velB >= 0) ? 'f' : (velA < 0 && velB < 0) ? 'b' : (velA > velB ? 'r' : 'l');
    // IMPORTANT: apply same l/r inversion as fkMove (simulator's 'l' = physical right)
    const _physDir = _dir === 'l' ? 'r' : _dir === 'r' ? 'l' : _dir;
    franky.handleRequest('POST', '/mv', {d: _physDir, val: _maxV});
  };

  // ── Update phase display in phone panel ──────────────────────
  const _phaseEl = $('sumo-phase-lbl');

  // ── State machine ─────────────────────────────────────────────
  if (a0 > BORDER_THRESHOLD) {
    // BORDE: retroceder recto, luego girar para alejarse del borde
    if (_phaseEl) { _phaseEl.textContent = '◀◀ ESCAPE'; _phaseEl.style.color='var(--re)'; }
    _driveDiff(-spd, -spd);  // reverse straight
    _sumoState.phase = 'escape_back';
    _sumoState.phaseMs = S.simTime + 180;
    _sumoState.lastDir = _sumoState.lastDir === 'l' ? 'r' : 'l';

  } else if (_sumoState.phase === 'escape_back' && S.simTime < _sumoState.phaseMs) {
    if (_phaseEl) { _phaseEl.textContent = '◀◀ RETRO'; _phaseEl.style.color='var(--re)'; }
    _driveDiff(-spd, -spd);  // continue reversing

  } else if (_sumoState.phase === 'escape_back' || (_sumoState.phase === 'escape' && S.simTime < _sumoState.phaseMs)) {
    // Girar para quedar de espaldas al borde
    if (_phaseEl) { _phaseEl.textContent = '↺ GIRO'; _phaseEl.style.color='var(--am)'; }
    if (_sumoState.phase === 'escape_back') {
      _sumoState.phase = 'escape';
      _sumoState.phaseMs = S.simTime + 350;
    }
    // Turn: one motor forward, other reverse — use search trim for speed
    const _escDir = _sumoState.lastDir;  // already physical direction
    const _physEsc = _escDir === 'l' ? 'r' : 'l';  // apply inversion
    franky.handleRequest('POST', '/sumo/trim', {ma:255, mb:255});  // equal for clean spin
    franky.handleRequest('POST', '/mv', {d: _physEsc, val: Math.round(spd * 0.8)});

  } else if (a1 > ATTACK_THRESHOLD) {
    // ATAQUE: cargar contra el oponente con trim diferencial de ataque
    if (_phaseEl) { _phaseEl.textContent = '▶▶ ATAQUE'; _phaseEl.style.color='var(--gr)'; }
    _sumoState.phase = 'attack';
    // Attack uses attack trim — different from search trim
    // This lets the student tune straight-line charge independently
    _driveDiff(atkA, atkB);

  } else {
    // BÚSQUEDA: barrido en arco buscando oponente
    // Not pure spin — use search trim to create a sweep arc
    // srchA ≠ srchB → arc sweep; srchA = srchB → spin on axis
    if (_phaseEl) { _phaseEl.textContent = '⟳ BÚSQUEDA'; _phaseEl.style.color='var(--cy)'; }
    _sumoState.phase = 'search';
    // MICRO searches turning left, MINI searches turning right (their natural preference)
    // Arc: one motor slightly faster → sweeping arc instead of pure spin
    const _searchFwd  = Math.max(srchA, srchB);
    const _searchSlow = Math.min(srchA, srchB);
    if (fs.mode === 1) {
      _driveDiff(_searchFwd, _searchSlow);  // MICRO: arc left (A faster)
    } else {
      _driveDiff(_searchSlow, _searchFwd);  // MINI: arc right (B faster)
    }
  }
}

// Reset sumo state on challenge change
function resetSumoAI() {
  _sumoState = { phase: 'search', phaseMs: 0, lastDir: 'l' };
}

// Reset bloques state on challenge change
function resetBloquesVM() {
  _bloquesState.ip = 0;
  _bloquesState.waitUntil = 0;
  _bloquesState.varGlobal = 0;
  _bloquesState._wasRunning = false;
  resetSumoAI();
}

function fwStep() {
  if (!gen) return;
  if (pend) { if (eco.vm._firmwareTime < pend.t) return; pend=null; }
  // Hard 2ms time budget — checked every iteration, not every 50.
  // gen.next() can execute many VM instructions per call. A tight C loop
  // (no delay/serial/yield) in a bundle sketch blocks the entire JS thread.
  // Checking the clock every iteration ensures we always yield in time.
  // Max 300 gen.next() calls per fwStep — resumes next simTick automatically.
  const _tBudget = performance.now() + 2;
  for (let i=0; i<300; i++) {
    if (performance.now() > _tBudget) return; // time up — yield to event loop
    let it;
    try { it=gen.next(); } catch(e) { onErr(e); return; }
    if (it.done) { gen=null; return; }
    const y=it.value; if (!y) continue;
    if (y.kind==='DELAY')     { pend={t:eco.vm._firmwareTime+y.remainingMs}; return; }
    if (y.kind==='YIELD_CPU'||y.kind==='SETUP_DONE'||y.kind==='LOOP_START') return;
  }
}

function simTick(dt) {
  S.simTime += dt;
  eco.vm.advanceFirmwareTime(dt / S.speed);
  // isFranky must be evaluated BEFORE fwStep.
  // fwStep must NOT run during FRANKY challenges — the ROBOARD firmware VM
  // would try to execute concurrently with bloquesVMStep, generating HAL errors
  // on FRANKY-exclusive pins (GPIO2-5) and wasting CPU on a dead code path.
  // isFranky: only true when FRANKY platform AND not 'codigo' interaction mode.
  // For fk-minisumo-pd and fk-seguidor-2sensor (interactionMode='codigo'):
  // these use the ROBOARD VM with C++ sketches, NOT FrankySimulator.
  // If franky was initialized from a prior FRANKY challenge and is non-null,
  // isFranky would be true → fwStep() never runs → ROBOARD sketch is dead.
  const _ch_sim = getChallenge(S.cid);
  const _isCodigo = _ch_sim?.interactionMode === 'codigo';
  const isFranky = !!(franky && _ch_sim?.platformId === 'FRANKY' && !_isCodigo);
  if (!isFranky) fwStep();
  // Safe robot access — ALWAYS use R()
  const r   = R();
  const obs = eco.physics.obstacles || [];
  // Sensor injection: Sharp IR (distance-based) by default
  // For QTR-based challenges, override with reflectance simulation
  const scene = S.activeScene;
  const sceneType = scene?.type || 'arena';

  if (sceneType === 'line-follower') {
    // QTR array simulation: 2-sensor basic (U3.4) and 8-sensor array (U3.5)
    // Sensor positions relative to robot center (px): symmetric array
    const QTR_OFFSETS = [
      {ox:-14,oy:0},{ox:-10,oy:0},{ox:-6,oy:0},{ox:-2,oy:0},
      {ox: 2,oy:0},{ox: 6,oy:0},{ox:10,oy:0},{ox:14,oy:0},
    ];
    // Inject all 8 analog pins A0–A7
    for (let i=0; i<8; i++) {
      const off=QTR_OFFSETS[i];
      eco.hal.setSensorValue('A'+i, qtrSample(r, scene, off.ox, off.oy));
    }
  } else if (sceneType === 'minisumo') {
    // QTR: reflectance from ring geometry
    const qtrVal = qtrRing(r, scene);
    eco.hal.setSensorValue('A0', qtrVal);
    eco.hal.setSensorValue('A6', qtrVal);
    // Sharp IR on A1: opponent/obstacle distance sensor for minisumo
    // Without this A1 stays at HAL default (0), making analogRead(A1)=0 < 400 always true
    // — opponent_detected fires every tick even with no obstacle nearby
    eco.hal.setSensorValue('A1', irSample(r, obs, 3, 5, .44));
    // HC-SR04 (ECHO=A3): inject pulseInValue for pulseIn() calls
    const hcUs = hcsr04Sample(r, eco.physics.obstacles || []);
    eco.hal.setPulseInValue('A3', hcUs);
  } else {
    // Sharp IR distance simulation
    eco.hal.setSensorValue('A0', irSample(r, obs, 4, 0, 0));
    eco.hal.setSensorValue('A1', irSample(r, obs, 3, 5, .44));
  }
  // ── Peripheral HAL injection (ALL scenario types) ────────────
  // FIXED BUG: was previously scoped inside line-follower block only.
  // Button (D12) and DIP-switch (D11/D2) now work in ALL challenge types.
  if (S._periph && !isFranky) {
    const _pp = S._periph;
    if (_pp.showBtn) eco.hal.setSensorValue('D12', _pp.btnPressed ? 0 : 1);
    if (_pp.showDip) {
      eco.hal.setSensorValue('D11', _pp.dip11on ? 0 : 1);
      eco.hal.setSensorValue('D2',  _pp.dip2on  ? 0 : 1);
    }
  }

  // Determine motor commands — FRANKY uses its own simulator, not the ROBOARD HAL
  let effectiveMC;
  // (isFranky declared at top of simTick — no re-declaration needed)

  if (isFranky) {
    // ── STEP 1: Inject sensors FIRST so AI and Blockly VM read current values ──
    // Previous order injected AFTER getMotorCmds → AI used stale (prev-tick) sensors.
    if (sceneType === 'minisumo') {
      const qtrVal = qtrRing(r, scene);
      const adc12qtr = Math.round((qtrVal / 1023) * 4095);
      const hcUs = hcsr04Sample ? hcsr04Sample(r, obs) : 5800;
      const adc12hc = Math.round(Math.min(1, (isFinite(hcUs)?hcUs:5800) / 5800) * 4095);
      franky.injectSensors({a0: adc12qtr, a1: adc12hc, temp: 22.5, hum: 55.0});
    } else if (sceneType === 'line-follower' || sceneType === 'lf') {
      const qL = (typeof qtrSample === 'function') ? qtrSample(r, scene, 0, 12) : 500;
      const qR = (typeof qtrSample === 'function') ? qtrSample(r, scene, 0, -12) : 500;
      franky.injectSensors({a0: Math.round((qL/1023)*4095), a1: Math.round((qR/1023)*4095), temp: 22.5, hum: 55.0});
    } else {
      const irPx = irRaycast(R(), obs, 0, 0, 0);
      const adc12 = (!isFinite(irPx) || irPx > 400) ? 0 : Math.round((1 - irPx/400) * 4095);
      franky.injectSensors({a0: adc12, a1: Math.round(adc12 * 0.6), temp: 22.5, hum: 55.0});
    }
    // ── STEP 2: Run VM / Autonomous AI (now reads current-tick sensors) ──
    if (franky.getState().mode === 3 && franky.getState().running) {
      bloquesVMStep(S.simTime);
    }
    if ((franky.getState().mode === 1 || franky.getState().mode === 2) && franky.getState().running) {
      frankyAutonomousStep();
    }
    // ── STEP 3: Get resulting motor commands ──
    effectiveMC = franky.getMotorCmds();
  } else {
    // ROBOARD: motor commands from HAL pin state
    const mp = eco.hal.getMotorPinValues();
    effectiveMC = eco.driver ? eco.driver.evaluate(mp)
      : {motorA:{direction:'DISABLED',pwm:0},motorB:{direction:'DISABLED',pwm:0}};
  }

  // Physics step uses the correct motor commands for the active platform
  eco.physics.step(effectiveMC, dt);

  // ── Obstacle pushing physics ──────────────────────────────────
  // eco.physics.step() moves the robot but does NOT push obstacles.
  // For minisumo, the "obstacle" IS the opponent robot — it must be pushed.
  // We implement a simple AABB collision response: when the robot body
  // overlaps an obstacle, push the obstacle away from the robot center.
  if (r && r.x !== undefined) {
    const _rHW = 18 * Math.max(1, Math.min(1.8, (cvs.width||800) / 560)); // robot half-width
    const _rHH = 14 * Math.max(1, Math.min(1.8, (cvs.width||800) / 560)); // robot half-height
    for (const o of (eco.physics.obstacles || [])) {
      if (!o || o.w === undefined) continue;
      // Get robot corners in world space (simplified as axis-aligned bounding box)
      const _rx1 = r.x - _rHW, _rx2 = r.x + _rHW;
      const _ry1 = r.y - _rHH, _ry2 = r.y + _rHH;
      // Obstacle bounds
      const _ox1 = o.x, _ox2 = o.x + o.w;
      const _oy1 = o.y, _oy2 = o.y + o.h;
      // AABB overlap check
      if (_rx2 > _ox1 && _rx1 < _ox2 && _ry2 > _oy1 && _ry1 < _oy2) {
        // Overlap detected — push obstacle away from robot center (minisumo pushing physics)
        const _dx = (o.x + o.w/2) - r.x;
        const _dy = (o.y + o.h/2) - r.y;
        const _dist = Math.sqrt(_dx*_dx + _dy*_dy) || 1;
        // Push magnitude: robot speed + minimum guaranteed push + forward bonus
        // Minimum push of 2px ensures even a slow robot moves the obstacle visibly.
        // Forward bonus: extra push when robot is facing obstacle (cos of angle diff).
        const _robotSpd = Math.abs(r.vL||0) + Math.abs(r.vR||0);
        const _facingBonus = Math.max(0, (r.vL||0) + (r.vR||0)) * 0.3; // bonus for moving forward
        const _pushMag = Math.max(2, _robotSpd * 0.6 + _facingBonus);
        o.x += (_dx/_dist) * _pushMag;
        o.y += (_dy/_dist) * _pushMag;
        // Separate robot from obstacle (prevent overlap accumulation)
        const _overlapX = Math.min(_rx2 - _ox1, _ox2 - _rx1);
        const _overlapY = Math.min(_ry2 - _oy1, _oy2 - _ry1);
        if (_overlapX < _overlapY) {
          // Separate on X axis
          if (r.x < o.x + o.w/2) { r.x -= _overlapX * 0.3; } else { r.x += _overlapX * 0.3; }
        } else {
          // Separate on Y axis
          if (r.y < o.y + o.h/2) { r.y -= _overlapY * 0.3; } else { r.y += _overlapY * 0.3; }
        }
        // Clamp obstacle within canvas with some margin
        const _W = cvs.width || 800, _H = cvs.height || 500;
        o.x = Math.max(-o.w*0.5, Math.min(_W - o.w*0.5, o.x));
        o.y = Math.max(-o.h*0.5, Math.min(_H - o.h*0.5, o.y));
      }
    }
  }

  // Minisumo boundary constraint: robot cannot exit the ring
  // Without this, the robot exits → qtrRing returns HIGH forever → VM stuck in DELAY
  if (sceneType === 'minisumo' && scene) {
    var _ringL = null;
    for (var _li = 0; _li < (scene.layers||[]).length; _li++) {
      if (scene.layers[_li].type === 'ring' && scene.layers[_li].id === 'tatami') {
        _ringL = scene.layers[_li]; break;
      }
    }
    if (_ringL) {
      var _cW = cvs.width || 800, _cH = cvs.height || 500;
      var _rcx = _ringL.xf * _cW, _rcy = _ringL.yf * _cH;
      var _maxR = _ringL.rf * Math.min(_cW, _cH) - 18;
      var _rb = eco.physics.robot;
      if (_rb) {
        var _rdx = _rb.x - _rcx, _rdy = _rb.y - _rcy;
        var _rdist = Math.sqrt(_rdx*_rdx + _rdy*_rdy);
        if (_rdist > _maxR) {
          var _rscale = _maxR / _rdist;
          _rb.x = _rcx + _rdx * _rscale;
          _rb.y = _rcy + _rdy * _rscale;
          _rb.vL = (_rb.vL||0) * -0.5;
          _rb.vR = (_rb.vR||0) * -0.5;
        }
      }
    }
  }

  eco.telemetry.recorder.recordTick({
    simTime: S.simTime,
    gpio: eco.hal.getAllPins(),
    motorCmds: effectiveMC,
    variables: eco.vm.getVariables(),
  });
  // Revelation observations
  const a0 = eco.hal.getAllPins()['A0']?.value ?? 1023;
  const _scType = S.activeScene?.type || 'arena';
  const _isDanger = _scType === 'minisumo' ? (a0 > 600) : (a0 < 350);
  if (_isDanger) eco.revelation.observe(RL.OBS.ROBOT_STOPPED,{});
  // Border event tracking for minisumo challenges
  // Tracks transitions: off-border → on-border (detection) and on-border → off-border (escape)
  if (_scType === 'minisumo') {
    const _onBorder = a0 > 700;
    if (_onBorder && !S._wasOnBorder) {
      S._wasOnBorder = true;
      S._borderDetectedCount = (S._borderDetectedCount || 0) + 1;
    } else if (!_onBorder && S._wasOnBorder) {
      S._wasOnBorder = false;
      S._borderEscapedCount = (S._borderEscapedCount || 0) + 1;
    }
  }
  eco.eventBus.emit({type:'SIM_TICK',payload:{
    simTime:S.simTime, gpio:eco.hal.getAllPins(),
    motorCmds:effectiveMC, robotState:R(), obstacles:obs,
    variables:{...eco.vm.getVariables(),
      // Physics-derived: available for ALL platforms
      motor_moved:    !!(Math.abs(effectiveMC.motorA.pwm||0)+Math.abs(effectiveMC.motorB.pwm||0) > 0),
      forward_moved:  effectiveMC.motorA.direction==='FORWARD' && effectiveMC.motorB.direction==='FORWARD' && (effectiveMC.motorA.pwm||0)>0,
      turn_performed: effectiveMC.motorA.direction !== effectiveMC.motorB.direction && (effectiveMC.motorA.pwm||0)>0,
      reverse_moved:  effectiveMC.motorA.direction==='REVERSE' && effectiveMC.motorB.direction==='REVERSE' && (effectiveMC.motorA.pwm||0)>0,
      robot_x:        R().x, robot_y: R().y, robot_angle: R().angle,
      vL:             R().vL||0, vR: R().vR||0,
      sim_time:       S.simTime,
      // Sensor readings — available for both platforms
      a0_raw:         a0,   // ROBOARD: eco.hal A0 (10-bit), FRANKY: unused here
      a1_raw:         (eco.hal.getAllPins()['A1']?.value ?? 0),
      a6_raw:         (eco.hal.getAllPins()['A6']?.value ?? 0),
      // Minisumo-specific: QTR borde detection + time tracking + opponent detection
      qtr_border:     a0 > 600,   // QTR > 600 = borde/línea for ROBOARD scenes
      a0_qtr:         a0,
      survived_ms:    S.simTime,  // total sim time = time robot has survived
      in_ring:        true,       // boundary constraint keeps robot in ring
      // Opponent/obstacle proximity: Sharp IR A1 < 400 OR robot speed > 0 near obstacle
      // irSample returns ~80 when no obstacle (Infinity baseline) — > 120 excludes it
      opponent_detected: (eco.hal.getAllPins()['A1']?.value ?? 1023) > 120 && (eco.hal.getAllPins()['A1']?.value ?? 1023) < 400,
      stby_high:      !!(eco.hal.getAllPins()['D6']?.value),  // driver enabled
      led_on:         !!(eco.hal.getAllPins()['D10']?.value),  // ROBOARD onboard LED D10
      robot_moving:   (Math.abs(r?.vL||0) + Math.abs(r?.vR||0)) > 0.5,
      // Border event tracking: how many times robot detected and escaped border
      // Avoids trivial survival (robot parado with in_ring=true always)
      border_detected_count: S._borderDetectedCount || 0,
      border_escaped_count:  S._borderEscapedCount  || 0,
      ...(isFranky && franky ? {
        motorSpeed:     franky.getState().motorSpeed,
        mode:           franky.getState().mode,
        program:        franky.getState().program,
        a0_max:         Math.max(franky.getState().a0, S._fkA0Max||0),
        a0_min:         Math.min(franky.getState().a0, S._fkA0Min||4095),
        temp_read:      franky.getState().dht===1,
        trimConfigured: !!(S._sumoConfig) || franky.getState().trimA!==255 || franky.getState().trimB!==255,
        sumo_config_set: !!(S._sumoConfig),
        adc0:           franky.getState().a0,
        pwmA:           franky.getState().pwmA,
        pwmB:           franky.getState().pwmB,
        sumo_running:   franky.getState().mode===1 || franky.getState().mode===2,
        bloques_ran:    franky.getState().mode===3 && !franky.getState().running,
        led_on:         !!(franky.getState().ledState || franky.getState().ledOn || franky.getState().led),
      } : {}),
    },
  },source:'UI'});

  // Track FRANKY ADC min/max
  if (isFranky && franky) {
    if (S._fkA0Max===undefined) S._fkA0Max=0;
    if (S._fkA0Min===undefined) S._fkA0Min=4095;
    S._fkA0Max = Math.max(S._fkA0Max, franky.getState().a0);
    S._fkA0Min = Math.min(S._fkA0Min, franky.getState().a0);
  }
  if (a0 < 350) eco.revelation.observe(RL.OBS.ROBOT_STOPPED,{});
  const spd = Math.abs(r.vL||0)+Math.abs(r.vR||0);
  if (spd > 0.2) eco.revelation.observe(RL.OBS.ROBOT_MOVED,{});
  // Update HC-SR04 cone distance for canvas visualization
  // For FRANKY challenges with HC-SR04: inject hcsr04 distance into a0 feed
  if (S._periph?.showHCSR04) {
    try {
      const _obs = eco.physics?.obstacles?.[0];
      const _r   = eco.physics?.robot;
      if (_r && _obs) {
        const _us = hcsr04Sample(_r, _obs ? [_obs] : []);
        const _dist_cm = _us > 0 ? Math.round(_us / 58) : null;
        S._periph.hcsrDist = _dist_cm;
        // For FRANKY: inject as 12-bit a1 equivalent via HAL proxy
        if (isFranky && _dist_cm !== null) {
          const _dist_12bit = Math.round(4095 * (1 - Math.min(_dist_cm, 400) / 400));
          try { eco.hal.setPin('A1', Math.round(_dist_12bit / 4)); } catch(e) {}
        }
      }
    } catch(e) {}
  } else if (S._periph?.showHCSR04 === false || !S._periph?.showHCSR04) {
    // Only update for non-FRANKY when not explicitly HC-SR04 mode
  }

  // OLED auto-telemetry for FRANKY challenges with showOled
  if (isFranky && S._periph?.showOled && run) {
    if (!S._periph.oledLines) S._periph.oledLines = [];
    const _fst = franky ? franky.getState() : null;
    const _a0v = _fst ? Math.round(_fst.a0 / 40.95) : 0; // 0-100%
    const _vel = effectiveMC ? Math.max(effectiveMC.motorA.pwm||0, effectiveMC.motorB.pwm||0) : 0;
    const _dist = S._periph.hcsrDist;
    // Update every ~500ms (simTime is ms)
    if (!S._periph._lastOledUpdate || S.simTime - S._periph._lastOledUpdate > 500) {
      S._periph._lastOledUpdate = S.simTime;
      S._periph.oledLines = [
        'FRANKY Telemetry',
        'A0: ' + _a0v + '%',
        'VEL: ' + _vel,
        _dist !== null ? 'DIST: ' + _dist + 'cm' : 'DIST: ---',
        'T: ' + (S.simTime/1000).toFixed(1) + 's',
      ];
    }
  }

  if (S._periph?.showHCSR04 && !isFranky) {
    // hcsr04Sample returns microseconds; convert to cm: us/58
    try {
      const _obs = eco.physics?.obstacles?.[0];
      const _r   = eco.physics?.robot;
      if (_r && _obs) {
        const _us = hcsr04Sample(_r, _obs ? [_obs] : []);
        S._periph.hcsrDist = _us > 0 ? Math.round(_us / 58) : null;
      }
    } catch(e) {}
  }

  // Evaluate synthetic challenge objectives from current SIM_TICK variables
  // PLATFORM-AWARE: reads correct state for ROBOARD (HAL pins) vs FRANKY (simulator state)
  if (S._synthState && SYNTHETIC_CHALLENGES[S.cid]) {
    const _pins = eco.hal.getAllPins();
    const _btnPressed = !!(S._periph?.btnPressed) || (_pins['D12']?.value === 0 && _pins['D12']?.value !== undefined);
    const _dip11on    = _pins['D11']?.value === 0;
    const _dip2on     = _pins['D2']?.value  === 0;
    // FRANKY state: LED is gpio8 (inverted logic handled by FrankySimulator.ledOn)
    // ROBOARD state: LED is D10 in eco.hal
    const _fs         = isFranky && franky ? franky.getState() : null;
    const _ledOn      = isFranky ? !!((_fs?.ledState) || (_fs?.ledOn) || (_fs?.led)) : !!(eco.hal.getAllPins()['D10']?.value);
    const _frankyA0   = _fs?.a0 || 0;
    _synthValidate({
      // LED — platform-aware
      led_on:         _ledOn,
      // Sensors — ROBOARD 10-bit (0-1023), FRANKY 12-bit (0-4095)
      a0_raw:         isFranky ? Math.round(_frankyA0 / 4) : a0,
      adc0:           isFranky ? _frankyA0 : (a0 * 4),
      a1_raw:         _pins['A1']?.value ?? 0,
      // Driver
      stby_high:      !!(eco.hal.getAllPins()['D6']?.value),
      // Motors (effectiveMC is correct for both platforms)
      motorA_fwd:     effectiveMC.motorA.direction === 'FORWARD',
      motorA_rev:     effectiveMC.motorA.direction === 'REVERSE',
      motorA_pwm:     effectiveMC.motorA.pwm || 0,
      motorB_fwd:     effectiveMC.motorB.direction === 'FORWARD',
      motorB_rev:     effectiveMC.motorB.direction === 'REVERSE',
      motorB_pwm:     effectiveMC.motorB.pwm || 0,
      forward_moved:  effectiveMC.motorA.direction==='FORWARD' && effectiveMC.motorB.direction==='FORWARD' && (effectiveMC.motorA.pwm||0)>0,
      motor_moved:    !!(Math.abs(effectiveMC.motorA.pwm||0)+Math.abs(effectiveMC.motorB.pwm||0) > 0),
      robot_moving:   spd > 0.5,
      // FRANKY motion flags
      turn_performed: isFranky
        ? ((effectiveMC.motorA.direction !== effectiveMC.motorB.direction && (effectiveMC.motorA.pwm||0)>0) || !!(S._frankyCmd_l||S._frankyCmd_r))
        : false,
      bloques_ran:    !!(isFranky && S._synthState),
      // Digital inputs (ROBOARD only; FRANKY uses canvas click for btn)
      btn_pressed:    _btnPressed,
      dip11_on:       _dip11on,
      dip2_on:        _dip2on,
      // Time
      sim_time:       S.simTime,
      // Distance sensors
      hcsr04_cm:      S._periph?.hcsrDist ?? null,
      hcsr04_near:    S._periph?.hcsrDist !== null && S._periph?.hcsrDist !== undefined && S._periph.hcsrDist < 20,
      tof_mm:         S._periph?.showTOF ? (S._periph?.hcsrDist != null ? S._periph.hcsrDist * 10 : null) : null,
    });
  }
  return effectiveMC;
}

function loop(ts) {
  if (!run) return;
  FPS.tick(ts);
  const wd = Math.min(ts-lts, 100); lts=ts; acc+=wd*S.speed;
  let n=0;
  while (acc>=16.67 && n<5) {
    try { simTick(16.67); } catch(e) { onErr(e); return; }
    acc-=16.67; n++;
  }

  // ── Blockly program completion detection ─────────────────────
  // When a Blockly program hits FIN (or /bloques/stop), the FrankySimulator
  // transitions mode→0 and running→0. Without this check:
  //   • run stays true indefinitely
  //   • badge reads "EJECUTANDO" forever
  //   • the student has no signal that the program finished
  // _wasRunning latches to true the moment Blockly actually starts executing,
  // so we only fire the completion signal after a real run (not on initial load).
  if (franky && S.ss === 'RUNNING') {
    const fs = franky.getState();
    if (fs.mode === 3 && fs.running) {
      _bloquesState._wasRunning = true;        // Blockly is actively running
    } else if (_bloquesState._wasRunning) {    // was running → now stopped → FIN reached
      _bloquesState._wasRunning = false;
      run = false;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      S.ss = 'DONE';
      setBadge();
      ser('[SYS] ✓ Programa Blockly finalizado.', 'i');
      toast('✓ Programa finalizado');
      uiUpdate();
      renderObjs();  // refresh objectives panel immediately — no more ticks after this
      return;  // exit loop — raf already cancelled
    }
  }

  uiF++;
  if (uiF%2===0) uiUpdate();
  raf = requestAnimationFrame(loop);
}

function onErr(e) {
  S._sessionLog.push({t:Date.now(),cid:S.cid,event:'error',data:{msg:(e?.message||String(e)).slice(0,120)}});
  run=false; S.ss='ERROR';
  if (raf) { cancelAnimationFrame(raf); raf=null; }
  // Guard: e may not be an Error instance
  const msg = (e && e.message) ? e.message : (typeof e === 'string' ? e : JSON.stringify(e)||'Unknown error');
  showErr(msg.slice(0,200));
  ser('[ERR] '+msg, 'e');
  setBadge();
  if (e.code==='INFINITE_LOOP') TH.trigger('concept_infinite_loop');
  // Auto-recovery: clear VM, leave physics/HAL so student sees where robot stopped
  gen=null; pend=null;
  eco.vm.stop();
  eco.vm._globals={};
  eco.vm._firmwareTime=0;
  eco.vm._instructionCount=0;
  setTimeout(()=>{
    if (S.ss==='ERROR') { S.ss='IDLE'; setBadge(); ser('[SYS] VM reiniciado. Corregí el código y ejecutá de nuevo.','i'); }
  }, 3000);
}

// ══════════════════════════════════════════════════════════════
// EVENTS
// ══════════════════════════════════════════════════════════════
eco.eventBus.on('SERIAL_OUTPUT', e => {
  const _smsg = e.payload.message || '';
  // OLED intercept: lines starting with "OLED:" go to canvas display
  // Sketch writes: Serial.println("OLED:Hola Mundo"); → appears on OLED canvas
  if (_smsg.startsWith('OLED:') && S._periph?.showOled) {
    const _oledLine = _smsg.slice(5).trim();
    if (!S._periph.oledLines) S._periph.oledLines = [];
    // Special commands
    if (_oledLine === 'CLR' || _oledLine === 'CLEAR') {
      S._periph.oledLines = [];
    } else {
      // Add line, max 7 lines visible on OLED
      S._periph.oledLines.push(_oledLine);
      if (S._periph.oledLines.length > 7) S._periph.oledLines.shift();
    }
  }
  ser(e.payload.message,'f');
  // Hint: student may not know Serial Monitor exists if they're in the Desafío tab
  if (S.tab !== 'co' && !S._serialHintShown) {
    S._serialHintShown = true;
    setTimeout(function(){ toast('💬 El sketch imprime datos → tab Código → Serial Monitor'); }, 800);
  }
});
eco.eventBus.on('HAL_PERR',             e => { if (getChallenge(S.cid)?.platformId === 'FRANKY') return; ser('[HAL] '+e.payload.msg,'e'); });
eco.eventBus.on('GPIO_ANALOG_IMPLICIT', e => { ser('[INFO] '+e.payload.msg,'i'); TH.trigger('concept_analog_vs_digital'); });
eco.eventBus.on('OBJECTIVE_COMPLETED',  e => {
  renderObjs();
  toast('✓ '+e.payload.label);
  if (eco.persistence.getCurrentStudent()) {
    eco.persistence.recordObjectiveCompletion(S.cid, e.payload.objectiveId, S.simTime).catch(()=>{});
    saveUnitProgress();
  }
});
eco.eventBus.on('CHALLENGE_COMPLETED', () => {
  const _cst2 = S._synthState || eco.challenges.getState();
  S._sessionLog.push({t:Date.now(),cid:S.cid,event:'complete',
    data:{done:_cst2?.objectives.filter(o=>o.completed).length||0,tot:_cst2?.objectives.length||0,sim_t:S.simTime}});
  if (S._sessionLog.length) lsSet('session:log',JSON.stringify(S._sessionLog.slice(-200)));
  ser('[SYS] ¡Desafío completado!','i');
  if (eco.persistence.getCurrentStudent()) {
    eco.persistence.recordChallengeCompletion(S.cid, S.simTime, 0).catch(()=>{});
    eco.persistence.saveProject(S.cid, S.cid, S.code, {runCount:1,simTimeTotalMs:S.simTime,platformId:(getChallenge(S.cid)?.platformId||'ROBOARD')}).catch(()=>{});
    saveUnitProgress();
  }
  // Show completion panel
  const ch = getChallenge(S.cid);
  if (!ch) { toast('🏆 ¡Desafío completado!'); return; }
  $('m-comp-title').textContent = '¡Desafío completado!';
  $('m-comp-desc').textContent  = ch.name;
  const mins = Math.floor(S.simTime/60000);
  const secs = Math.floor((S.simTime%60000)/1000);
  const _compSt = (S._synthState) ? S._synthState : eco.challenges.getState();
  const objDone = _compSt?.objectives.filter(o=>o.completed).length || 0;
  const objTot  = _compSt?.objectives.length || 0;
  $('m-comp-stats').innerHTML =
    '<div><div style="font-size:1.1rem;font-weight:700;color:var(--cy)">'+(mins>0?mins+'m ':'')+secs+'s</div><div style="color:var(--t2);font-size:.5rem">tiempo</div></div>'+
    '<div><div style="font-size:1.1rem;font-weight:700;color:var(--gr)">'+objDone+'/'+objTot+'</div><div style="color:var(--t2);font-size:.5rem">objetivos</div></div>';
  // Next challenge
  const uIdx = UNIT_CHS[S.cid];
  const unit = (uIdx!==undefined) ? UNITS[uIdx] : null;
  const nextId = unit ? unit.ks[unit.ks.indexOf(S.cid)+1] : null;
  const nextCh = nextId ? getChallenge(nextId) : null;
  var nextBtn = nextCh
    ? '<button class="btn btn-run" style="width:100%;padding:9px" data-next="'+nextId+'" onclick="A._completeClose(this.dataset.next)">Siguiente: '+nextCh.name+' →</button>'
    : '<button class="btn btn-run" style="width:100%;padding:9px" onclick="A._completeClose(null)">Ver mapa curricular →</button>';
  $('m-comp-next').innerHTML = nextBtn;
  $('m-complete').classList.remove('hid');
});
eco.eventBus.on('REVELATION_ACTION', e => {
  if (e.payload.type==='SHOW') applyReveal(e.payload.componentId);
  if (e.payload.type==='MILESTONE') toast(e.payload.text);
});
eco.eventBus.on('THEORY_TRIGGERED', e => TH.add(e.payload));
eco.eventBus.on('VALIDATION_REPORT', e => renderVal(e.payload));
eco.eventBus.on('DIAGNOSTIC_REPORT', e => {
  $('vbar').innerHTML = '<span class="vb-err">'+e.payload.title+': '+(e.payload.suggestion||'').slice(0,55)+'</span>';
});

// ══════════════════════════════════════════════════════════════
// THEORY MANAGER
// ══════════════════════════════════════════════════════════════
// ── THEORY CONTENT FALLBACK ───────────────────────────────────────
// Used when the bundle does not have the concept referenced by THEORY_TRIGGERS.
// Without this, TH.trigger() fires but no THEORY_TRIGGERED event returns,
// and the Theory tab stays empty for most challenges.
const THEORY_CONTENT_FALLBACK = {
  'concept_gpio_digital': {
    id: 'concept_gpio_digital', title: 'GPIO Digital — Pines HIGH y LOW',
    content: { body: `UN PIN DIGITAL tiene dos estados únicos:\n  HIGH = 5V (o 3.3V en ESP32) = "encendido"\n  LOW  = 0V                    = "apagado"\n\nCÓMO USARLO:\n  pinMode(10, OUTPUT);      // configurar como salida\n  digitalWrite(10, HIGH);   // poner en HIGH (5V)\n  digitalWrite(10, LOW);    // poner en LOW  (0V)\n\nPARA LEER (sensor digital):\n  pinMode(2, INPUT_PULLUP);  // configurar como entrada\n  int estado = digitalRead(2); // leer: 0 o 1\n\n¿POR QUÉ pinMode()?\nEl pin puede ser salida o entrada.\nSin configurarlo, el estado es indefinido.\nSiempre configurar ANTES de usar.` }
  },
  'concept_i2c_spi': {
    id: 'concept_i2c_spi', title: 'I2C y SPI — Buses de Comunicación',
    content: { body: `BUSES DE COMUNICACIÓN:\n\nI2C (Inter-Integrated Circuit):\n  Cables: 2 (SDA = datos, SCL = reloj)\n  Velocidad: hasta 400kHz (Fast Mode)\n  Dispositivos: muchos en el mismo bus\n  Cada uno tiene dirección (0x00-0x7F)\n  Ideal para: OLED, IMU, TOF, expansores E/S\n\nSPI (Serial Peripheral Interface):\n  Cables: 4 (SCLK, MOSI, MISO, CS)\n  Velocidad: hasta 10MHz (25x más rápido que I2C)\n  Un dispositivo a la vez (por CS)\n  Ideal para: ADCs externos, pantallas gráficas, Flash\n\n¿CUÁNDO USAR CADA UNO?\n  I2C: múltiples sensores lentos, economía de cables\n  SPI: alta velocidad, un dispositivo principal` }
  },
  'concept_hcsr04': {
    id: 'concept_hcsr04', title: 'HC-SR04 — Sensor Ultrasónico',
    content: { body: `PRINCIPIO DE FUNCIONAMIENTO:\nEl HC-SR04 envía un pulso ultrasónico y mide cuánto tarda en volver.\ncm = microsegundos_de_eco / 58\n\nPROTOCOLO (siempre el mismo orden):\n  digitalWrite(TRIG, LOW); delayMicroseconds(2);\n  digitalWrite(TRIG, HIGH); delayMicroseconds(10);\n  digitalWrite(TRIG, LOW);\n  long us = pulseIn(ECHO, HIGH);\n  int cm = us / 58;\n\nLIMITACIONES REALES:\n  - Punto muerto: < 2cm no detecta\n  - Ángulos > 15° → el eco no vuelve al sensor\n  - No puede medir más rápido que cada 60ms\n  - Superficies blandas (tela, espuma) absorben el sonido\n\nCOMPARADO CON SHARP IR:\n  Sharp = rápido, pasivo, sin protocolo, impreciso en cm\n  HC-SR04 = preciso en cm, activo, con punto muerto` }
  },
  'concept_sharp_ir': {
    id: 'concept_sharp_ir', title: 'Sensor Sharp GP2Y0A21 — Infrarrojo',
    content: { body: `CÓMO FUNCIONA:\nEmite un rayo IR y mide el ángulo de reflexión.\nMás cerca el objeto → mayor ángulo → voltaje mayor.\nPero la relación NO es lineal.\n\nVALORES (analogRead A0):\n~100-200  = objeto muy cercano (<10cm)\n~300-450  = objeto a 15-25cm\n~700-900  = campo libre\n\nUMBRAL TÍPICO: 350 para detectar a ~20cm\n\n¿POR QUÉ A0 BAJA CUANDO HAY OBSTÁCULO?\nEl sensor mide reflectancia inversa —\nmás luz reflejada (objeto cerca) = voltaje MÁS ALTO,\npero la circuencia inversora del chip lo invierte.\nResultado: objeto cerca → A0 BAJO.` }
  },
  'concept_robot_diferencial': {
    id: 'concept_robot_diferencial', title: 'Robot Diferencial — Movimiento',
    content: { body: `UN ROBOT DIFERENCIAL tiene 2 motores independientes.\nLa dirección depende de la DIFERENCIA de velocidades.\n\nAmbos iguales → avanza recto\nMotor A más rápido → gira hacia B\nVelocidades opuestas → gira en el lugar\nA mayor diferencia → giro más cerrado\n\nEsto es igual que una silla de ruedas o un tanque.\nNo hay dirección mecánica: la trayectoria emerge\nde la diferencia entre ruedas.` }
  },
  'concept_secuencia': {
    id: 'concept_secuencia', title: 'Programación Secuencial',
    content: { body: `Un programa secuencial ejecuta instrucciones\nuna tras otra, en orden, sin ramificaciones.\n\nCada línea se ejecuta EXACTAMENTE UNA VEZ\ny en el orden en que aparece.\n\nvoid loop() no es "una vez" — se ejecuta\nen loop infinito. Cada llamada a loop() ejecuta\ntodas las instrucciones de arriba a abajo.` }
  },
  'concept_millis': {
    id: 'concept_millis', title: 'Temporizado sin delay() — millis()',
    content: { body: `PROBLEMA CON delay():\nBloquea TODO el programa. El robot queda ciego.\n\nSOLUCIÓN — millis():\nunsigned long prevMs = 0;\nconst long INTERVALO = 500;\n\nvoid loop() {\n  unsigned long ahora = millis();\n  if (ahora - prevMs >= INTERVALO) {\n    prevMs = ahora;\n    // acción periódica\n  }\n  // lectura de sensores SIN BLOQUEAR\n  int sensor = analogRead(A0);\n}` }
  },
  'concept_control_proporcional': {
    id: 'concept_control_proporcional', title: 'Control Proporcional (P)',
    content: { body: `ON/OFF: gira 100% o no gira — oscila mucho.\n\nCONTROL P:\n  error = sensor_der - sensor_izq;\n  velocidad = BASE + Kp * error;\n\nCuanto más se desvía → más corrección.\nKp típico: 0.3 a 1.5\n\nSi el robot oscila → Kp muy alto, bajarlo.\nSi el robot no corrige rápido → Kp muy bajo.` }
  },
  'concept_control_pd': {
    id: 'concept_control_pd', title: 'Control PD (Proporcional + Derivativo)',
    content: { body: `CONTROL PD agrega anticipación al control P:\n  error    = sensor_der - sensor_izq;\n  derivada = error - errorAnterior;\n  corr     = Kp*error + Kd*derivada;\n  errorAnterior = error;\n\nKd "frena" las correcciones bruscas.\nResultado: seguimiento más suave en curvas.\n\nKd típico: 0.1 a 0.8\nEmpezar con Kd=0, subir hasta reducir oscilaciones.` }
  },
  'concept_qtr_sensor': {
    id: 'concept_qtr_sensor', title: 'Sensor QTR — Reflectancia',
    content: { body: `CÓMO FUNCIONA:\nEmite IR y mide cuánta luz regresa.\nSuperficie clara → mucha reflexión → valor ALTO.\nSuperficie oscura → poca reflexión → valor BAJO.\n\nVALORES (analogRead A0):\n~900 = superficie CLARA (borde blanco, fondo)\n~80  = superficie OSCURA (tatami negro, línea)\n\nUMBRAL: 700 separa blanco de negro\n\nNOTA: el QTR es OPUESTO al Sharp IR —\nSharp: objeto cerca → valor bajo\nQTR:   superficie clara → valor alto` }
  },
  'concept_webserver': {
    id: 'concept_webserver', title: 'FRANKY WebServer — HTTP API',
    content: { body: `FRANKY crea un punto de acceso WiFi (AP).\nCualquier dispositivo puede conectarse y enviar\ncomandos HTTP a 192.168.4.1.\n\nCOMANDOS PRINCIPALES:\n  POST /mv?d=f   → avanzar\n  POST /mv?d=b   → retroceder\n  POST /mv?d=l   → girar izquierda\n  POST /mv?d=r   → girar derecha\n  POST /st       → frenar\n  POST /led/on   → encender LED\n  GET  /status   → estado JSON\n\nEl simulador replica exactamente estos endpoints.` }
  },
  'concept_bloques': {
    id: 'concept_bloques', title: 'Programación con Bloques — FRANKY',
    content: { body: `El sistema Bloques convierte bloques visuales\nen instrucciones que el firmware ejecuta.\n\nINSTRUCCIONES:\n  ADE/ATR/IZQ/DER (ms) — movimiento N ms\n  ESP (ms)             — esperar\n  LED_ON / LED_OFF     — LED GPIO8\n  ADC_READ             — leer sensor\n  SI > / SI <          — condicional\n  REPETIR              — volver al bloque N\n\nFLUJO: Arrastrar bloques → ▶ Ejecutar → observar robot` }
  },
  'concept_gpio_esp32': {
    id: 'concept_gpio_esp32', title: 'GPIO ESP32-C3 — FRANKY',
    content: { body: `FRANKY usa un ESP32-C3 con 10 pines GPIO:\n  GPIO0-1: SPI / comunicación\n  GPIO2-5: Control de motores (L9110s)\n  GPIO6-7: I2C (SDA/SCL)\n  GPIO8:   LED onboard\n  GPIO9:   Botón onboard\n  ADC0-1:  Sensores analógicos (12-bit, 0-4095)\n\nDIFERENCIA CON ARDUINO:\n  Arduino: 10-bit ADC (0-1023)\n  ESP32:   12-bit ADC (0-4095)\n  Los umbrales son 4x mayores en FRANKY.` }
  },
  'concept_pid': {
    id: 'concept_pid', title: 'Control PID',
    content: { body: `PID = Proporcional + Integral + Derivativo\n\nP: corrección según error actual\nI: corrección acumulada (errores pasados)\nD: corrección anticipada (tendencia del error)\n\nPara seguidor de línea básico: PD es suficiente.\nEl término I agrega complejidad sin ventaja clara\nen pistas con curvas simples.\n\nEmpezar siempre con solo P, luego agregar D.` }
  },
  'concept_maquina_estados': {
    id: 'concept_maquina_estados', title: 'Máquina de Estados Finitos',
    content: { body: `Una máquina de estados tiene:\n- ESTADOS: lo que el robot está haciendo ahora\n- TRANSICIONES: condiciones para cambiar de estado\n- ACCIONES: lo que hace en cada estado\n\nEJEMPLO (minisumo):\n  enum Estado { BUSCAR, ATACAR, ESCAPAR };\n  Estado estado = BUSCAR;\n\n  void loop() {\n    switch(estado) {\n      case BUSCAR:\n        girar();\n        if(oponente_detectado) estado=ATACAR;\n        break;\n      case ATACAR:\n        avanzar_rapido();\n        if(borde_detectado) estado=ESCAPAR;\n        break;\n      case ESCAPAR:\n        retroceder_girar();\n        estado = BUSCAR;\n        break;\n    }\n  }\n\nVENTAJA: comportamiento complejo con código simple.` }
  },
  'concept_adc_calibracion': {
    id: 'concept_adc_calibracion', title: 'Calibración ADC — Sensores Analógicos',
    content: { body: `El ADC (Analog-to-Digital Converter) convierte\nvoltaje analógico (0-5V) a número digital:\n  Arduino: 0-1023 (10-bit)\n  ESP32:   0-4095  (12-bit)\n\nCÓMO CALIBRAR:\n  1. Medir valor con sensor en condición MÍNIMA\n  2. Medir valor con sensor en condición MÁXIMA\n  3. Umbral = punto medio entre ambos\n\nEJEMPLO:\n  int minVal = 80;   // tatami negro\n  int maxVal = 920;  // borde blanco\n  int umbral = (minVal + maxVal) / 2; // = 500\n\nUSO CON map():\n  int porcentaje = map(valor, minVal, maxVal, 0, 100);\n\n¿POR QUÉ VARÍA?\nCabido, polvo, luz ambiente, temperatura.` }
  },
  'concept_qtr8_array': {
    id: 'concept_qtr8_array', title: 'Array QTR-8 — 8 Sensores de Línea',
    content: { body: `El QTR-8 tiene 8 sensores de reflectancia\nen línea, separados ~9mm. Cada uno en un pin analógico.\n\nUSO EN SEGUIDOR:\nLeer todos los sensores → calcular posición\nde la línea con promedio ponderado:\n  pos = (s0*0 + s1*1 + ... + s7*7) / suma\n\nPOSICIÓN: 0=extremo izquierdo, 7=extremo derecho\nLÍNEA AL CENTRO → pos ≈ 3.5\n\nVENTAJA sobre 2 sensores:\n• Más preciso en curvas cerradas\n• Puede medir CUÁNTO se desvió\n• Permite PID más robusto\n\nREQUIERE: leer 8 analogRead() por tick.` }
  },
};

const TH = {
  trigger(id) {
    const before = S.thQ.length;
    eco.theory.trigger(id, {});
    // If the bundle doesn't have this concept, use our fallback after 120ms
    if (THEORY_CONTENT_FALLBACK[id]) {
      setTimeout(function() {
        if (S.thQ.length === before && THEORY_CONTENT_FALLBACK[id]) {
          TH.add(THEORY_CONTENT_FALLBACK[id]);
        }
      }, 120);
    }
  },
  add(b) {
    if (S.thShown.has(b.id)) return;
    S.thShown.add(b.id);
    // Append challenge-specific anchor tip so theory stays relevant to current task
    if (typeof THEORY_ANCHORS !== 'undefined' && THEORY_ANCHORS[S.cid]) {
      const _anchor = THEORY_ANCHORS[S.cid];
      if (b.content && b.content.body && !b.content.body.includes(_anchor)) {
        b = Object.assign({}, b, {
          content: Object.assign({}, b.content, { body: b.content.body + '\n\n───────────────────\n' + _anchor })
        });
      }
    }
    S.thQ.push(b);
    $('thdot').classList.add('on');
    // Notify student only on first new concept in a challenge session
    if (S.thQ.length === 1) {
      setTimeout(function(){ if(S.thQ&&S.thQ.length>0) toast('💡 Nuevo concepto desbloqueado — tab Teoría'); }, 1500);
    }
    if (S.tab==='th') this.render();
  },
  render() {
    const has = S.thQ.length > 0;
    $('th-em').style.display = has ? 'none' : '';
    $('th-tt').style.display = has ? '' : 'none';
    $('th-sp').style.display = has ? '' : 'none';
    $('th-bo').style.display = has ? '' : 'none';
    if (!has) return;
    const b=S.thQ[0], c=b.content;
    $('th-tt').textContent = b.title || '';
    let txt = '';
    if      (c?.body)        txt = c.body;
    else if (c?.analogy)     txt = c.analogy+(c.warning?'\n\n⚠ '+c.warning:'');
    else if (c?.formula)     txt = c.formula+(c.note?'\n\n'+c.note:'')+(c.examples?'\n\n'+c.examples.join('\n'):'');
    else if (c?.items)       txt = c.items.map(i=>i.label+':\n'+i.value).join('\n\n');
    else if (c?.description) txt = c.description+(c.keyPoints?'\n\n'+c.keyPoints.join('\n'):'');
    else if (c?.bad)         txt = '✗ Problema:\n'+c.bad+'\n\n✓ Solución:\n'+c.good+(c.explanation?'\n\n'+c.explanation:'');
    else                     txt = JSON.stringify(c, null, 2);
    $('th-bo').textContent = txt;
    const more = S.thQ.length > 1;
    $('th-s2').style.display = more ? '' : 'none';
    $('th-nv').style.display = more ? 'flex' : 'none';
    if (more) $('th-cn').textContent = S.thQ.length+' conceptos pendientes';
  },
  next() { S.thQ.shift(); if (!S.thQ.length) $('thdot').classList.remove('on'); this.render(); },
};

// ══════════════════════════════════════════════════════════════
// REVELATION
// ══════════════════════════════════════════════════════════════
function applyReveal(cid) {
  if (cid==='SENSOR_HUD' || cid==='CANVAS') $('shud').classList.add('vis');
}

// ══════════════════════════════════════════════════════════════
// CHALLENGE LOADING
// CRITICAL: canvas must be sized BEFORE obstacles are placed.
// loadCh(id) is safe to call before lab view is visible
// but applyScene() must only run after resize().
// ══════════════════════════════════════════════════════════════
function applyScene(scenarioId) {
  if (cvs.width < 10 || cvs.height < 10) resize();
  const W = cvs.width || 800, H = cvs.height || 500;

  // Get scene descriptor from bundle (declarative)
  const scene = (RL.getScene && RL.getScene(scenarioId)) || SCENE_FALLBACK;
  // Cache current scene for renderer
  S.activeScene = scene;

  // Position robot from scene spawn
  const sp = scene.spawnPoints?.robot || { xf:.2, yf:.5, angle:0 };
  const robot = eco.physics.robot;
  if (robot) {
    robot.x=sp.xf*W; robot.y=sp.yf*H;
    robot.angle=sp.angle||0; robot.trail=[]; robot.vL=0; robot.vR=0;
  }

  // Place obstacles from scene spawn descriptors (pixel coords)
  const obsSpawns = (scene.spawnPoints?.obstacles || []).map(o => ({
    ...o, x:o.xf*W, y:o.yf*H, w:o.wf*W, h:o.hf*H,
  }));
  eco.physics.setObstacles(obsSpawns);
}

// Fallback scene for unknown scenarioIds
const SCENE_FALLBACK = {
  id:'fallback', type:'arena',
  layers:[{type:'surface',color:'#06080d'}],
  spawnPoints:{ robot:{xf:.2,yf:.5,angle:0}, obstacles:[{id:'o1',xf:.55,yf:.35,wf:.07,hf:.22,drag:true}] },
  renderHints:{showGrid:true},
};

function loadCh(id) {
  if (!id) {
    ser('[SYS] No se especificó challenge.','i');
    return;
  }
  const ch = getChallenge(id);
  if (!ch) {
    ser('[ERR] Challenge no encontrado: '+id,'e');
    return;
  }
  S.cid = id;

  // Sketch: prefer localStorage draft, then challenge sketch, then override
  // For OVERRIDE_PRIORITY challenges, our safe sketch takes precedence over
  // localStorage drafts — the bundle sketch may have been saved as a draft previously
  // and causes the VM to hang (pulseIn tight loops, while() without delay, etc.)
  const _overridePriority = [
    'ms-mantenerse-en-ring','ms-buscar-atacar',
    'u3-minisumo-borde','u3-minisumo-atacar','u3-minisumo-estrategia',
    'fk-minisumo-pd','fk-seguidor-2sensor',
  ];
  const draft = _overridePriority.includes(id) ? null : lsGet('sk:'+id);
  const sk    = draft || getChallengeSketch(id);
  S.code = sk;
  $('ced').value = sk;
  updLineNums();

  // Challenge UI
  $('ch-nm').textContent = ch.name || id;
  $('ch-ds').textContent = ch.description || '';

  // Challenge engine — bypass bundle for synthetic challenges
  S._synthState = null; // reset synthetic state
  if (SYNTHETIC_CHALLENGES[id]) {
    const _sc = SYNTHETIC_CHALLENGES[id];
    S._synthState = {
      id: id,
      objectives: _sc.objectives.map(function(o) {
        return { id: o.id, label: o.label, required: o.required, completed: false };
      }),
      _flags: {},
      _reqDoneSince: 0,
      _completed: false,
    };
    // Initialize peripheral overlay from challenge definition
    S._periph = _sc.periph ? JSON.parse(JSON.stringify(_sc.periph)) : null;
    try { eco.challenges.start(id, eco.eventBus); } catch(e) {}
  } else {
    eco.challenges.start(id, eco.eventBus);
  }
  renderObjs();

  // Scene — apply after canvas sizing
  const scenarioId = ch.scenarioId || 'single-obstacle';
  applyScene(scenarioId);

  // Revelation — configure with correct unit lesson
  eco.revelation.reset();
  const _unitIdx = (typeof UNIT_CHS !== 'undefined') ? UNIT_CHS[id] : undefined;
  const _lessonId = (_unitIdx === 6) ? 'unit-7' : ('unit-' + ((_unitIdx != null ? _unitIdx + 1 : 1)));
  // Triple fallback: computed lesson → unit-7 → unit-1
  // unit-7 may not exist in the bundle for all versions; unit-1 is always present.
  // Without this, FRANKY challenges silently get the ROBOARD lesson criteria,
  // causing revelation moments to never advance and milestones to never fire.
  const lesson = eco.content.getLesson(_lessonId)
              || eco.content.getLesson('unit-7')
              || eco.content.getLesson('unit-1');
  if (lesson) eco.revelation.configure(lesson);

  // Always show HUD — student should see sensor values immediately, not only after play()
  // This lets them verify sensor operation before writing any code.
  $('shud').classList.add('vis');

  // Validation
  if (sk) renderVal(eco.validator.validate(sk));

  // Theory — reset per challenge so relevant concepts always show, not just first time
  // S.thShown persisting across challenges means concepts from challenge N+1 are
  // suppressed if already shown in challenge N — the theory panel goes empty.
  S.thShown = new Set();
  S.thQ = [];
  const thdotEl = $('thdot'); if(thdotEl) thdotEl.classList.remove('on');
  const thcnEl = $('th-cn'); if(thcnEl) thcnEl.textContent = '';
  const thcEl = $('th-c'); if(thcEl) thcEl.innerHTML = '';
  // Trigger the concept relevant to this specific challenge
  const _thId = THEORY_TRIGGERS[id] || 'concept_tb6612fng';
  TH.trigger(_thId);
  // Challenge context — add the "why" below the description
  (function() {
    const ctxEl = $('ch-ds');
    if (!ctxEl || !CHALLENGE_CONTEXT[id]) return;
    const existing = ctxEl.parentNode.querySelector('.ch-ctx-line');
    if (existing) existing.remove();
    const ctx = document.createElement('div');
    ctx.className = 'ch-ctx-line';
    ctx.style.cssText = 'font-size:.62rem;color:rgba(0,205,179,.65);margin-top:6px;line-height:1.65;font-style:italic;padding:5px 8px;background:rgba(0,205,179,.04);border-radius:3px;border-left:2px solid rgba(0,205,179,.2)';
    ctx.textContent = CHALLENGE_CONTEXT[id];
    ctxEl.parentNode.insertBefore(ctx, ctxEl.nextSibling);
  })();
  // Contextual manual section highlight
  const manualMap = {
    // challenge tag → manual section id
    'minisumo':    'qtr',            'hc-sr04':    'hcsr04',
    'ir':          'sharp-ir',       'pd':         'control-pd',
    'proportional':'control-p',      'millis':     'millis',
    'qtr':         'qtr',            'qtr8':       'qtr8',
    'franky':      'webserver',      'blockly':    'blockly-codigo',
    'bloques':     'blockly-codigo', 'iot':        'webserver',
    'timing':      'millis',         'motors':     'puente-h',
    'motor':       'puente-h',       'proportional':'control-p',
    'pid':         'control-pid',    'derivative': 'control-pd',
    'adc':         'analogread',     'line-follower':'qtr',
    'pwm':         'analogwrite',    'reactive':   'millis',
    'state-machine':'millis',        'dht':        'dht11',
    'telemetria':  'telemetria',
  };
  const tags = ch.tags || [];
  for (const [tag, section] of Object.entries(manualMap)) {
    if (tags.includes(tag)) {
      // Expand the relevant manual section if manual tab is active
      if (S.tab === 'mn') {
        requestAnimationFrame(()=>{
          const el = document.querySelector('#manual-content details[data-section="'+section+'"]');
          if (el) el.open = true;
        });
      }
      break;
    }
  }

  // Update challenge selector to match
  const sel = $('chsel');
  if (sel) {
    for (let i=0; i<sel.options.length; i++) {
      if (sel.options[i].value === id) { sel.selectedIndex=i; break; }
    }
  }

  ser('[SYS] Desafío: '+ch.name,'i');

  // Adjust code tab for FRANKY web-first challenges
  const codeTab  = document.querySelector('.ptab[data-p="co"]');
  const codePP   = $('pp-co');
  const frankyMode = ch.platformId === 'FRANKY' ? (ch.interactionMode || 'webserver') : null;
  const hidCodeTab = ch.platformId === 'FRANKY' && frankyMode !== 'codigo';
  if (codeTab)  codeTab.style.display  = hidCodeTab ? 'none' : '';
  if (codePP && hidCodeTab && S.tab === 'co') A.tab('ch');

  // Auto-open FRANKY panel based on interactionMode
  if (ch.platformId === 'FRANKY') {
    if (frankyMode === 'webserver' || frankyMode === 'hybrid' || frankyMode === 'bloques') {
      if (A._frankyOpenTimer) clearTimeout(A._frankyOpenTimer);
      A._frankyOpenTimer = setTimeout(function(){
        A._frankyOpenTimer = null;
        A.openFranky();
        if (frankyMode === 'bloques') setTimeout(function(){ A.wpPage('bloques'); }, 200);
      }, 200);
      // Show HUD immediately for FRANKY — telemetry is always relevant
      $('shud').classList.add('vis');
      ser('[SYS] Panel FRANKY abierto. Controlá el robot desde el dispositivo móvil simulado.','i');
    } else {
      // 'codigo': no panel — use code editor
      A.closeFranky();
      ser('[SYS] Challenge FRANKY — modo código. Usá el editor para programar.','i');
    }
  } else {
    A.closeFranky();
  }

  // Update scene label overlay
  const scLbl = $('scene-lbl');
  if (scLbl && S.activeScene) {
    const typeLabel = {
      'arena':'ARENA','minisumo':'TATAMI MINISUMO',
      'line-follower':'PISTA SEGUIDOR','corridor':'CORREDOR',
    }[S.activeScene.type] || 'ARENA';
    scLbl.textContent = typeLabel + ' · ' + (ch.platformId || 'ROBOARD');
  }
  // Show QTR-8 bar for line-follower challenges
  const qtr8El = $('qtr8-bar');
  if (qtr8El) qtr8El.style.display = (S.activeScene?.type==='line-follower') ? '' : 'none';
}

// ══════════════════════════════════════════════════════════════
// CHALLENGE SELECTOR — populate from full challenge DB
// ══════════════════════════════════════════════════════════════
function buildChallengeSelector() {
  const sel = $('chsel');
  if (!sel) return;
  sel.innerHTML = '';
  // Group by unit
  const GROUPS = [
    { label:'Unidad 0 — Primeros Pasos',           ids:['u0-led-blink','u0-leds-externos','u0-boton','u0-un-motor','u0-leer-sensor','u0-parar-con-sensor','u0-dip-switch','u0-pwm','u0-mapeo','u0-movimiento','u0-evasion','u0-ultrasonido','u0-comparar-sensores','u0-i2c','u0-oled','u0-tof','u0-spi'] },
    { label:'E0 — FRANKY Primeros Pasos (Blockly)', ids:['e0-led-blink','e0-gpio-salida','e0-sensor-adc','e0-motores','e0-decision','e0-repetir','e0-pwm','e0-movimiento','e0-evasion','e0-ultrasonido','e0-comparar','e0-oled','e0-i2c','e0-tof','e0-spi','e0-mapeo'] },
    { label:'Unidad 1 — Sistemas Robóticos',      ids:['u1-explorar-motores','u1-reactivo-parar','u1-reactivo-girar','robot-reactivo-1','robot-reactivo-2'] },
    { label:'Unidad 2 — Programación Interactiva', ids:['u2-secuencia-tiempos','u2-millis-no-delay','u2-seguir-pared'] },
    { label:'Unidad 3 — Sensado y Datos',          ids:['u3-calibrar-ir','u3-minisumo-borde','u3-minisumo-atacar','u3-seguidor-linea'] },
    { label:'LNR — Minisumo',                      ids:['ms-mantenerse-en-ring','ms-buscar-atacar'] },
    { label:'LNR — Seguidor de Línea',             ids:['lf-pista-recta','lf-curvas'] },
    { label:'FRANKY — Etapa 1: Robot Conectado',   ids:['fk-control-remoto','fk-figuras-basicas'] },
    { label:'FRANKY — Etapa 2: Telemetría',         ids:['fk-telemetria-live','fk-led-reactivo'] },
    { label:'FRANKY — Etapa 3: Programación Visual',ids:['fk-esquivar-obstaculo','fk-patrulla'] },
    { label:'FRANKY — Etapa 4: Autónomos',          ids:['fk-minisumo-config'] },
    { label:'FRANKY — Etapa 5: Control Avanzado',   ids:['fk-seguidor-2sensor','fk-minisumo-pd'] },
    { label:'ROBOARD — Unidad 3 (avanzado)',         ids:['u3-minisumo-estrategia','u3-seguidor-pd','u3-seguidor-qtr8'] },
  ];
  for (const g of GROUPS) {
    const validIds = g.ids.filter(id => !!getChallenge(id));
    if (!validIds.length) continue;
    const grp = document.createElement('optgroup');
    grp.label = g.label;
    for (const id of validIds) {
      const ch = getChallenge(id);
      const opt = document.createElement('option');
      opt.value = id;
      opt.textContent = ch.name;
      grp.appendChild(opt);
    }
    sel.appendChild(grp);
  }
  sel.onchange = e => A.chChange(e.target.value);
}

// ══════════════════════════════════════════════════════════════
// RENDERING — objectives, validation, GPIO, motors, sparks
// ══════════════════════════════════════════════════════════════
function renderObjs() {
  // For synthetic challenges: use local state; for bundle challenges: use eco.challenges.getState()
  const st = (S._synthState) ? S._synthState : eco.challenges.getState();
  if (!st) return;
  const done = st.objectives.filter(o=>o.completed).length;
  const tot  = st.objectives.length;
  $('ch-pf').style.width = (tot ? done/tot*100 : 0)+'%';
  $('ch-pn').textContent = done+'/'+tot;
  $('ol').innerHTML = st.objectives.map(o => {
    const ck  = o.completed ? 'ock done' : 'ock';
    const cls = o.completed ? 'obj done' : 'obj';
    const opt = o.required===false ? ' <em style="color:var(--t2)">(opcional)</em>' : '';
    return '<div class="'+cls+'"><div class="'+ck+'">'+(o.completed?'✓':'')+'</div><span class="ob-l">'+o.label+opt+'</span></div>';
  }).join('');
  const tab = document.querySelector('.ptab[data-p="ch"]');
  if (tab) tab.style.color = done>0 ? (done===tot?'var(--gr)':'var(--cy)') : '';
}

function renderVal(r) {
  if (!r) return;
  const vbar = $('vbar');
  if (!r.errors.length && !r.warnings.length) {
    vbar.innerHTML = '<span class="vb-ok">✓ Sketch válido</span>';
    $('vstrip').innerHTML = '';
    return;
  }
  const primary = r.errors[0] || r.warnings[0];
  const cls     = r.errors.length ? 'vb-err' : 'vb-wrn';
  const total   = r.errors.length + r.warnings.length;
  const extra   = total>1 ? ' <span style="color:var(--t2)">(+'+(total-1)+')</span>' : '';
  vbar.innerHTML = '<span class="'+cls+'">'+(r.errors.length?'✗':'⚠')+' '+(primary.message||primary.msg||'').slice(0,65)+'</span>'+extra;
  $('vstrip').innerHTML =
    r.errors.slice(0,1).map(i=>'<div class="vi vi-e">'+(i.message||i.msg||'').slice(0,55)+'</div>').join('') +
    r.warnings.slice(0,1).map(i=>'<div class="vi vi-w">'+(i.msg||'').slice(0,55)+'</div>').join('');
}

// GPIO — built once, updated in uiUpdate
const GPINS = ['D3','D4','D5','D6','D7','D8','D9','D10','A0','A1','A2'];
const GLBLS = {D3:'PWMA',D4:'AIN2',D5:'AIN1',D6:'STBY',D7:'BIN1',D8:'BIN2',D9:'PWMB',D10:'LED',A0:'Sharp IR',A1:'Lateral',A2:'Sensor'};
const GELS  = {};

function buildGPIO() {
  const g = $('gpio');
  if (!g) return;
  g.innerHTML = GPINS.map(id =>
    '<div class="gp"><div class="gp-id">'+id+'</div><div class="gp-lb">'+(GLBLS[id]||id)+'</div><div class="gp-v gv-off" id="gv-'+id+'">—</div></div>'
  ).join('');
  GPINS.forEach(id => { GELS[id] = $('gv-'+id); });
}

const DC = {FORWARD:'dc-f',REVERSE:'dc-r',BRAKE:'dc-b',DISABLED:'dc-o',COAST:'dc-o'};

function uiUpdate() {
  // ── OLED HUD update ─────────────────────────────────────────
  const _oledHud = $('oled-hud');
  if (_oledHud) {
    const _showOled = !!(S._periph?.showOled && run);
    _oledHud.classList.toggle('vis', _showOled);
    // Debug mode: window.DEBUG_OLED = true shows extra telemetry
    _oledHud.classList.toggle('debug', !!(window.DEBUG_OLED));
    if (_showOled) {
      const _hudLines = $('oled-hud-lines');
      if (_hudLines) {
        const _lines = S._periph.oledLines || [];
        // Add debug overlay if DEBUG_OLED is active
        const _displayLines = window.DEBUG_OLED
          ? [..._lines, '──────────────', 'SIM:'+((S.simTime/1000)|0)+'s A0:'+((eco.hal.getAllPins()['A0']?.value||0)|0)]
          : _lines;
        if (_displayLines.length === 0) {
          _hudLines.innerHTML = '<div class="dim">── sin datos ──</div>';
        } else {
          _hudLines.innerHTML = _displayLines
            .slice(-7)  // show last 7 lines (OLED has 8 rows in text mode)
            .map(function(l) { return '<div>' + (l||'').replace(/</g,'&lt;').replace(/>/g,'&gt;').slice(0,32) + '</div>'; })
            .join('');
        }
      }
    }
  }
  const pins = eco.hal.getAllPins();
  const _chUI = getChallenge(S.cid);
  const isFrankyActive = !!(franky && _chUI?.platformId === 'FRANKY' && _chUI?.interactionMode !== 'codigo');
  const mc = isFrankyActive
    ? franky.getMotorCmds()
    : (eco.driver ? eco.driver.evaluate(eco.hal.getMotorPinValues())
        : {motorA:{direction:'DISABLED',pwm:0},motorB:{direction:'DISABLED',pwm:0}});
  // For FRANKY: use FrankySimulator sensor values (12-bit ADC → scale to 10-bit for HUD)
  // For ROBOARD: use eco.hal pin values as before
  const a0 = isFrankyActive
    ? Math.round((franky.getState().a0 / 4095) * 1023)
    : (pins['A0']?.value ?? 0);
  const a1 = isFrankyActive
    ? Math.round((franky.getState().a1 / 4095) * 1023)
    : (pins['A1']?.value ?? 0);
  const det  = (S.activeScene?.type === 'minisumo') ? (a0 > 600) : (a0 < 350);

  // HUD — conditional update
  if (a0 !== prevA0) {
    prevA0 = a0;
    const scT = S.activeScene?.type || 'arena';
    if (scT === 'minisumo' || scT === 'line-follower') {
      // QTR: show state instead of raw value
      const onLine  = a0 > 600;
      $('hv0').textContent = (onLine ? (scT==='minisumo'?'BORDE':'LÍNEA') : (scT==='minisumo'?'NEGRO':'BLANCO')) + ' ' + a0;
      $('hv0').style.color = onLine ? 'var(--re)' : 'var(--gr)';
      $('hb0').style.width = (a0/1023*100)+'%';
      $('hb0').style.background = onLine ? 'var(--re)' : 'var(--gr)';
    } else {
      // Sharp IR: add CERCA/MEDIO/LIBRE label so student knows what the value means
      const _irLabel = det ? ' ←CERCA' : (a0 < 600 ? ' ←MEDIO' : ' ←LIBRE');
      $('hv0').textContent = a0 + _irLabel;
      $('hb0').style.width = ((1-a0/1023)*100)+'%';
      $('hv0').style.color = det ? 'var(--re)' : 'var(--am)';
      $('hb0').style.background = det ? 'var(--re)' : 'var(--am)';
    }
  }
  if (a1 !== prevA1) {
    prevA1 = a1;
    $('hv1').textContent = a1;
    $('hb1').style.width = ((1-a1/1023)*100)+'%';
  }
  $('hvt').textContent = Math.floor(S.simTime)+'ms';

  // QTR-8 array: update mini visualization in HUD
  if (S.activeScene?.type === 'line-follower') {
    const qtr8 = $('qtr8-bar');
    if (qtr8) {
      const pins = eco.hal.getAllPins();
      const bars = Array.from({length:8},(_,i)=>{
        const v=pins['A'+i]?.value||0;
        const on=v>600;
        return '<div style="width:6px;height:'+(on?20:4)+'px;background:'+(on?'var(--re)':'var(--t2)')+';border-radius:1px;transition:height .1s"></div>';
      }).join('');
      qtr8.innerHTML='<div style="display:flex;align-items:flex-end;gap:2px;height:24px">'+bars+'</div>';
    }
  }

  // Update HUD labels based on scene type
  const scType = S.activeScene?.type || 'arena';
  const h0lbl = $('h0-lbl'), h1lbl = $('h1-lbl');
  if (h0lbl) {
    if (scType === 'minisumo')           h0lbl.textContent = 'A0 QTR';
    else if (scType === 'line-follower') h0lbl.textContent = 'A0 Centro';
    else                                 h0lbl.textContent = 'A0 Sharp';
  }
  if (h1lbl) {
    if (scType === 'line-follower') h1lbl.textContent = 'A1 Derecho';
    else                             h1lbl.textContent = 'A1 Lat';
  }

  // Motors — conditional
  if (mc.motorA.direction !== prevDA || mc.motorA.pwm !== prevPA) {
    prevDA=mc.motorA.direction; prevPA=mc.motorA.pwm;
    $('mAd').textContent = mc.motorA.direction;
    $('mAd').className  = 'mc-d '+(DC[mc.motorA.direction]||'dc-o');
    $('mAb').style.width = (mc.motorA.pwm/255*100)+'%';
    $('mAp').textContent = mc.motorA.pwm;
  }
  if (mc.motorB.direction !== prevDB || mc.motorB.pwm !== prevPB) {
    prevDB=mc.motorB.direction; prevPB=mc.motorB.pwm;
    $('mBd').textContent = mc.motorB.direction;
    $('mBd').className  = 'mc-d '+(DC[mc.motorB.direction]||'dc-o');
    $('mBb').style.width = (mc.motorB.pwm/255*100)+'%';
    $('mBp').textContent = mc.motorB.pwm;
  }

  // GPIO — only when hardware tab visible
  if (S.tab === 'hw') {
    for (const id of GPINS) {
      const p=pins[id], el=GELS[id]; if(!p||!el) continue;
      if      (p.mode===null)                     { el.textContent='?';         el.className='gp-v gv-off'; }
      else if (p.mode==='INPUT'||p.mode==='INPUT_PULLUP') { el.textContent='IN:'+p.value; el.className='gp-v gv-in'; }
      else if (p.mode==='ANALOG_IMPLICIT')        { el.textContent=p.value;    el.className='gp-v gv-ai'; }
      else if (p.isPWM)                           { el.textContent='~'+p.pwmDuty; el.className='gp-v gv-pw'; }
      else { el.textContent=p.value?'HIGH':'LOW'; el.className='gp-v '+(p.value?'gv-hi':'gv-off'); }
    }
  }

  // Motor mini-overlay — show during ROBOARD execution (code tab) for causal connection
  const motorMini = $('motor-mini');
  if (motorMini) {
    if (run && S.tab === 'co') {
      motorMini.style.display = 'block';
      const ma = $('mm-a'), mb = $('mm-b');
      const DIR_COLOR = {FORWARD:'var(--gr)',REVERSE:'var(--am)',BRAKE:'var(--re)',DISABLED:'var(--t2)',COAST:'var(--t2)'};
      if (ma) { ma.textContent = mc.motorA.direction + ' ~' + mc.motorA.pwm; ma.style.color = DIR_COLOR[mc.motorA.direction]||'var(--t2)'; }
      if (mb) { mb.textContent = mc.motorB.direction + ' ~' + mc.motorB.pwm; mb.style.color = DIR_COLOR[mc.motorB.direction]||'var(--t2)'; }
    } else {
      motorMini.style.display = 'none';
    }
  }

  // Sparks — 6fps
  spkF++;
  if (spkF%10===0 && S.tab==='hw') updSparks();
}

// Sparks
let spkEls = null;
function initSparks() {
  spkEls = [
    {sid:'gpio.A0',       cv:$('sp0'),vv:$('spv0'),clr:'#f09600'},
    {sid:'motor.motorA.pwm',cv:$('spA'),vv:$('spvA'),clr:'#00cdb3'},
    {sid:'motor.motorB.pwm',cv:$('spB'),vv:$('spvB'),clr:'#18cc60'},
  ];
}
function updSparks() {
  if (!spkEls) return;
  for (const s of spkEls) {
    if (!s.cv) continue;
    const data = eco.telemetry.recorder.getSparklineData ? eco.telemetry.recorder.getSparklineData(s.sid, 60) : [];
    s.cv.width = s.cv.parentElement.offsetWidth || 100;
    const c2 = s.cv.getContext('2d'); c2.clearRect(0,0,s.cv.width,24);
    if (data.length>=2) {
      const vs=data.map(p=>p.v), mn=Math.min(...vs), mx=Math.max(...vs), rng=mx-mn||1;
      c2.beginPath(); c2.strokeStyle=s.clr; c2.lineWidth=1.5;
      data.forEach((p,i)=>{ const x=(i/(data.length-1))*s.cv.width, y=22-((p.v-mn)/rng)*20; i===0?c2.moveTo(x,y):c2.lineTo(x,y); });
      c2.stroke();
      const lp=data[data.length-1];
      c2.beginPath(); c2.arc(s.cv.width, 22-((lp.v-mn)/rng)*20, 2.5,0,Math.PI*2); c2.fillStyle=s.clr; c2.fill();
    }
    const last=eco.telemetry.recorder.getLatest ? eco.telemetry.recorder.getLatest(s.sid) : null;
    if (s.vv && last) s.vv.textContent = typeof last.v==='number' ? last.v.toFixed(0) : '—';
  }
}

// ══════════════════════════════════════════════════════════════
// SCENE RENDERER
// Consumes SceneDescriptor layers declaratively.
// No scene-specific logic here — add new scene types in scene-library.js
// ══════════════════════════════════════════════════════════════

function renderSceneLayers(scene, W, H) {
  if (!scene || !scene.layers) return;
  for (const layer of scene.layers) {
    switch (layer.type) {

      case 'surface':
        ctx.fillStyle = layer.color || '#06080d';
        ctx.fillRect(0, 0, W, H);
        break;

      case 'boundary': {
        const x=layer.xf*W, y=layer.yf*H, w=layer.wf*W, h=layer.hf*H;
        ctx.fillStyle   = layer.color  || 'rgba(59,120,236,.3)';
        ctx.strokeStyle = layer.border || 'rgba(59,120,236,.6)';
        ctx.lineWidth   = 2;
        ctx.beginPath(); ctx.roundRect(x,y,w,h,0); ctx.fill(); ctx.stroke();
        break;
      }

      case 'zone': {
        if (layer.shape === 'circle') {
          const cx=layer.xf*W, cy=layer.yf*H, r=layer.rf*Math.min(W,H);
          ctx.fillStyle   = layer.color  || 'rgba(0,205,179,.1)';
          ctx.strokeStyle = layer.border || 'rgba(0,205,179,.4)';
          ctx.lineWidth = 1;
          ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2); ctx.fill(); ctx.stroke();
        } else {
          const x=layer.xf*W, y=layer.yf*H, w=layer.wf*W, h=layer.hf*H;
          ctx.fillStyle   = layer.color  || 'rgba(0,205,179,.06)';
          ctx.strokeStyle = layer.border || 'rgba(0,205,179,.2)';
          ctx.lineWidth = 1;
          ctx.beginPath(); ctx.roundRect(x,y,w,h,3); ctx.fill(); ctx.stroke();
        }
        if (layer.label) {
          ctx.fillStyle = 'rgba(255,255,255,.25)';
          ctx.font      = '9px JetBrains Mono,monospace';
          ctx.textAlign = 'center';
          const cx = (layer.xf + (layer.wf||0)/2) * W;
          const cy = (layer.yf + (layer.hf||0)/2) * H + 4;
          ctx.fillText(layer.label, cx, cy);
        }
        break;
      }

      case 'ring': {
        // Circular ring (minisumo tatami / donut)
        const cx=layer.xf*W, cy=layer.yf*H;
        const r=layer.rf*Math.min(W,H);
        ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
        if (layer.fillColor && layer.fillColor!=='transparent') {
          ctx.fillStyle=layer.fillColor; ctx.fill();
        }
        ctx.strokeStyle = layer.strokeColor || 'rgba(255,255,255,.8)';
        ctx.lineWidth   = layer.strokeWidth  || 4;
        ctx.stroke();
        // Ring label
        if (layer.label) {
          ctx.fillStyle = 'rgba(255,255,255,.15)';
          ctx.font      = '10px JetBrains Mono,monospace';
          ctx.textAlign = 'center';
          ctx.fillText(layer.label, cx, cy - r + 18);
        }
        break;
      }

      case 'line': {
        // Smooth line path through waypoints (QTR-detectable line)
        const pts = (layer.points||[]).map(p => ({ x:p.xf*W, y:p.yf*H }));
        if (pts.length < 2) break;
        const lw = layer.lineWidth || 18;
        // Draw line (the physical tape)
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        if (pts.length === 2) {
          ctx.lineTo(pts[1].x, pts[1].y);
        } else {
          // Catmull-Rom smooth curve through waypoints
          for (let i=0; i<pts.length-1; i++) {
            const p0 = pts[Math.max(0,i-1)];
            const p1 = pts[i];
            const p2 = pts[i+1];
            const p3 = pts[Math.min(pts.length-1,i+2)];
            const cp1x = p1.x + (p2.x-p0.x)/6;
            const cp1y = p1.y + (p2.y-p0.y)/6;
            const cp2x = p2.x - (p3.x-p1.x)/6;
            const cp2y = p2.y - (p3.y-p1.y)/6;
            ctx.bezierCurveTo(cp1x,cp1y,cp2x,cp2y,p2.x,p2.y);
          }
        }
        ctx.strokeStyle = layer.color || '#111111';
        ctx.lineWidth   = lw;
        ctx.lineCap     = 'round';
        ctx.lineJoin    = 'round';
        ctx.stroke();
        // Center guide (thin lighter line for visual reference)
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        if (pts.length === 2) {
          ctx.lineTo(pts[1].x, pts[1].y);
        } else {
          for (let i=0; i<pts.length-1; i++) {
            const p0=pts[Math.max(0,i-1)],p1=pts[i],p2=pts[i+1],p3=pts[Math.min(pts.length-1,i+2)];
            ctx.bezierCurveTo(p1.x+(p2.x-p0.x)/6,p1.y+(p2.y-p0.y)/6,p2.x-(p3.x-p1.x)/6,p2.y-(p3.y-p1.y)/6,p2.x,p2.y);
          }
        }
        ctx.strokeStyle = 'rgba(255,255,255,.06)';
        ctx.lineWidth   = 1;
        ctx.stroke();
        // Label
        if (layer.label && pts.length) {
          const mid = pts[Math.floor(pts.length/2)];
          ctx.fillStyle='rgba(0,0,0,.5)'; ctx.font='9px JetBrains Mono,monospace'; ctx.textAlign='center';
          ctx.fillText(layer.label, mid.x, mid.y - lw/2 - 4);
        }
        break;
      }
    }
  }
}

function renderGrid(W, H) {
  ctx.strokeStyle='rgba(255,255,255,.025)'; ctx.lineWidth=1;
  for (let x=0; x<W; x+=32) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
  for (let y=0; y<H; y+=32) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
}

let drawRunning = false;

function draw() {
  if (S.view !== 'lab') { drawRunning = false; return; }
  if (drawRunning) return;
  drawRunning = true; // Do NOT reschedule when not in lab

  const W = cvs.width, H = cvs.height;
  const r   = R();
  const obs = eco.physics.obstacles || [];
  const ch = getChallenge(S.cid);
  // isFrankyDraw: exclude 'codigo' mode challenges (E5.2, E5.1) which use ROBOARD VM
  const isFrankyDraw = !!(ch && ch.platformId === 'FRANKY' && franky && ch.interactionMode !== 'codigo');
  // For FRANKY: sensor value from FrankySimulator. For ROBOARD/codigo: from HAL.
  const a0  = isFrankyDraw
    ? Math.round((franky.getState().a0 / 4095) * 1023)
    : (eco.hal.getAllPins()['A0']?.value ?? 1023);
  // det: "dangerous condition" — interpretation depends on scene type
  //   Sharp IR / arena: LOW a0 = obstacle close → danger
  //   Minisumo QTR:     HIGH a0 = white border = about to fall off → danger
  const _sceneTypeDraw = S.activeScene?.type || 'arena';
  const det = _sceneTypeDraw === 'minisumo' ? (a0 > 600) : (a0 < 350);
  const mc = ch && ch.platformId==='FRANKY'
    ? getFranky().getMotorCmds()
    : (eco.driver ? eco.driver.evaluate(eco.hal.getMotorPinValues()) : {motorA:{direction:'DISABLED',pwm:0},motorB:{direction:'DISABLED',pwm:0}});
  const mov = mc.motorA.direction==='FORWARD' || mc.motorA.direction==='REVERSE';

  ctx.clearRect(0, 0, W, H);

  // ── Layer 1: Scene layers (surface, lines, rings, zones, boundaries) ──
  const scene = S.activeScene || SCENE_FALLBACK;
  renderSceneLayers(scene, W, H);

  // ── Layer 2: Reference grid (if scene requests it) ────────────
  if (scene.renderHints?.showGrid) renderGrid(W, H);

  // ── Layer 3: Draggable obstacles ──────────────────────────────
  for (const o of obs) {
    if (!o || o.w===undefined) continue;
    ctx.fillStyle   = 'rgba(240,40,64,.08)';
    ctx.strokeStyle = det ? 'rgba(240,40,64,.82)' : 'rgba(240,40,64,.28)';
    ctx.lineWidth   = det ? 2 : 1.5;
    ctx.beginPath(); ctx.roundRect(o.x,o.y,o.w,o.h,4); ctx.fill(); ctx.stroke();
  }

  // ── Layer 4: Robot trail ───────────────────────────────────────
  const trail = r.trail || [];
  for (let i=1; i<trail.length; i++) {
    ctx.strokeStyle = 'rgba(0,205,179,'+(i/trail.length*.2)+')';
    ctx.lineWidth=1.5; ctx.beginPath();
    ctx.moveTo(trail[i-1].x,trail[i-1].y); ctx.lineTo(trail[i].x,trail[i].y); ctx.stroke();
  }

  // ── Layer 5: Sensor beam ───────────────────────────────────────
  if (r.x !== undefined) {
    const bx=r.x+Math.cos(r.angle)*15, by=r.y+Math.sin(r.angle)*15;
    const bl=Math.min(80, a0/6);
    ctx.strokeStyle=det?'rgba(240,40,64,.5)':'rgba(240,150,0,.18)';
    ctx.lineWidth=1; ctx.setLineDash([3,4]);
    ctx.beginPath(); ctx.moveTo(bx,by); ctx.lineTo(bx+Math.cos(r.angle)*bl,by+Math.sin(r.angle)*bl); ctx.stroke();
    ctx.setLineDash([]);

    // ── Layer 6: Robot body ──────────────────────────────────────
    ctx.save(); ctx.translate(r.x,r.y); ctx.rotate(r.angle);
    if (mov) { ctx.shadowColor='#00cdb3'; ctx.shadowBlur=9; }
    // Scale robot for larger canvases so it remains visible
    const _rs = Math.max(1, Math.min(1.8, W / 560));
    ctx.fillStyle='#090d16'; ctx.strokeStyle=det?'#f02840':'#00cdb3'; ctx.lineWidth=1.8;
    ctx.beginPath(); ctx.roundRect(-18*_rs,-14*_rs,36*_rs,28*_rs,3); ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;
    ctx.fillStyle=det?'#f02840':'#00cdb3'; ctx.beginPath(); ctx.roundRect(14*_rs,-3*_rs,5*_rs,6*_rs,2); ctx.fill();
    const dc=det?'#f02840':'#f09600';
    [-6,0,6].forEach(dy=>{ ctx.fillStyle=dc; ctx.beginPath(); ctx.arc(15*_rs,dy*_rs,2.5*_rs,0,Math.PI*2); ctx.fill(); });
    // LED: for FRANKY, read from FrankySimulator (ledOn field, set by /led/on endpoint)
    // For ROBOARD, read from HAL pin D10 as before
    const _fState = isFrankyDraw ? franky.getState() : null;
    // LED state: bundle ledState OR local PWM fallback (S._frankyLedPwm)
    const led = isFrankyDraw
      ? !!(_fState.ledState || _fState.ledOn || _fState.led || S._frankyLedPwm?.active)
      : (eco.hal.getAllPins()['D10']?.value??0);
    // PWM brightness: bundle ledBrillo first, then local fallback
    const _ledBrillo = isFrankyDraw
      ? (_fState.ledState === 2
          ? Math.max(0.15, (_fState.ledBrillo || 0) / 255)
          : (S._frankyLedPwm?.active
              ? Math.max(0.15, (S._frankyLedPwm.duty || 0) / 255)
              : 1))
      : 1;
    // LED: radio variable según brillo + barra PWM duty visible
    const _ledRadius = led ? (3.5 + _ledBrillo * 2.5) * _rs : 3.5 * _rs;
    if(led){
      ctx.shadowColor='#18cc60';
      ctx.shadowBlur = Math.max(4, 20 * _ledBrillo);
      ctx.globalAlpha = Math.max(0.25, _ledBrillo);
    }
    ctx.fillStyle = led ? '#18cc60' : 'rgba(255,255,255,.07)';
    ctx.beginPath(); ctx.arc(-12*_rs,-10*_rs,_ledRadius,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur=0; ctx.globalAlpha=1;
    // Barra de duty PWM: solo cuando el LED está encendido en modo PWM (no a pleno)
    if(led && _ledBrillo < 0.98 && isFrankyDraw) {
      const _dutyPct = _ledBrillo;
      const _barW = 20 * _rs, _barH = 2.5 * _rs;
      const _barX = -12*_rs - _barW/2, _barY = -10*_rs + _ledRadius + 2*_rs;
      ctx.fillStyle = 'rgba(255,255,255,.15)';
      ctx.fillRect(_barX, _barY, _barW, _barH);
      ctx.fillStyle = '#18cc60';
      ctx.fillRect(_barX, _barY, _barW * _dutyPct, _barH);
      ctx.fillStyle = 'rgba(24,204,96,.9)';
      ctx.font = (4.5 * _rs) + 'px JetBrains Mono,monospace';
      ctx.textAlign = 'center';
      ctx.fillText(Math.round(_dutyPct * 255), -12*_rs, _barY + _barH + 5*_rs);
    }
    ctx.restore();
  }

  // ── Layer 6.5: Peripheral components overlay ────────────────
  // Draws interactive components (button, DIP, ext LED, OLED) based on S._periph
  if (S._periph) {
    ctx.save();
    const _p = S._periph;

    // ── Button (D12, pull-up, active LOW) ──────────────────────
    if (_p.showBtn) {
      const bx=W-58, by=40, br=13;
      // Shadow glow when pressed
      if (_p.btnPressed) { ctx.shadowColor='#f09600'; ctx.shadowBlur=10; }
      ctx.fillStyle = _p.btnPressed ? '#f09600' : '#2e424f';
      ctx.strokeStyle = '#00cdb3'; ctx.lineWidth=1.2;
      ctx.beginPath(); ctx.arc(bx,by,br,0,Math.PI*2); ctx.fill(); ctx.stroke();
      ctx.shadowBlur=0;
      ctx.fillStyle='rgba(255,255,255,.85)'; ctx.font='bold 7px JetBrains Mono,monospace'; ctx.textAlign='center';
      ctx.fillText('BTN',bx,by+2.5);
      ctx.fillStyle='var(--t2)'; ctx.font='6px JetBrains Mono,monospace';
      ctx.fillText('D12',bx,by+br+9);
      // Click zone stored for mousedown handler
      _p._btnZone = {x:bx,y:by,r:br};
    }

    // ── DIP-switch (D11, D2) ───────────────────────────────────
    if (_p.showDip) {
      const dx=W-58, dy=80, dw=32, dh=18;
      ctx.fillStyle='#1a2436'; ctx.strokeStyle='#2e424f'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.roundRect(dx-dw/2,dy-dh/2,dw,dh,3); ctx.fill(); ctx.stroke();
      ctx.fillStyle='rgba(255,255,255,.5)'; ctx.font='5.5px JetBrains Mono,monospace'; ctx.textAlign='center';
      ctx.fillText('DIP',dx,dy-dh/2-3);
      // Two switches
      [0,1].forEach(function(i) {
        const pinId = i===0 ? 'D11':'D2';
        const isOn  = i===0 ? !!(_p.dip11on) : !!(_p.dip2on);
        const sx = dx - 8 + i*16, sy = dy - 5, sw = 12, sh = 10;
        ctx.fillStyle = isOn ? '#00cdb3' : '#0d1520';
        ctx.strokeStyle = '#2e424f'; ctx.lineWidth=1;
        ctx.beginPath(); ctx.roundRect(sx-sw/2,sy,sw,sh,2); ctx.fill(); ctx.stroke();
        // Slider knob position
        ctx.fillStyle = isOn ? '#fff' : '#2e424f';
        ctx.beginPath(); ctx.roundRect(sx-4,isOn?sy+1:sy+sh-6,8,5,1); ctx.fill();
        ctx.fillStyle='rgba(255,255,255,.4)'; ctx.font='4.5px JetBrains Mono,monospace';
        ctx.fillText(pinId,sx,sy+sh+8);
        _p['_dip'+i+'Zone'] = {x:sx,y:sy+sh/2,r:8};
      });
    }

    // ── External LEDs (A0..A5 as digital output) ───────────────
    if (_p.extLeds && _p.extLeds.length) {
      _p.extLeds.forEach(function(led,i) {
        const lx=20, ly=30+i*22;
        // FRANKY-aware: GPIO8 reads franky.getState().ledOn (inverted logic handled internally)
        // Other pins read eco.hal as usual
        const _isFrankyLed = led.pin === 'GPIO8' || led.pin === 'FRANKY_LED';
        const _fst = franky ? franky.getState() : null;
        const isOn = _isFrankyLed
          ? !!(franky && (_fst.ledState || _fst.ledOn || _fst.led || S._frankyLedPwm?.active))
          : !!(eco.hal.getAllPins()[led.pin]?.value);
        // PWM brightness: bundle ledBrillo first, local fallback second
        const _bri = _isFrankyLed
          ? (_fst && _fst.ledState === 2
              ? Math.max(0.2, (_fst.ledBrillo || 0) / 255)
              : (S._frankyLedPwm?.active
                  ? Math.max(0.2, (S._frankyLedPwm.duty || 0) / 255)
                  : 1))
          : 1;
        if (isOn) { ctx.shadowColor=led.color||'#18cc60'; ctx.shadowBlur = 10 * _bri; }
        // Scale opacity with PWM brightness when in brillo mode
        const _extColor = led.color || '#18cc60';
        if (isOn && _bri < 1) {
          // Parse hex color to rgba for opacity support
          const _r = parseInt(_extColor.slice(1,3)||'18',16);
          const _g = parseInt(_extColor.slice(3,5)||'cc',16);
          const _b = parseInt(_extColor.slice(5,7)||'60',16);
          ctx.fillStyle = `rgba(${_r},${_g},${_b},${_bri})`;
        } else {
          ctx.fillStyle = isOn ? _extColor : 'rgba(255,255,255,.08)';
        }
        ctx.strokeStyle = isOn ? (led.color||'#18cc60') : '#2e424f'; ctx.lineWidth=1.2;
        const _extRadius = isOn ? Math.max(4, 7 * (0.4 + 0.6 * _bri)) : 7;
        ctx.beginPath(); ctx.arc(lx,ly,_extRadius,0,Math.PI*2); ctx.fill(); ctx.stroke();
        ctx.shadowBlur=0;
        ctx.fillStyle='rgba(255,255,255,.55)'; ctx.font='5.5px JetBrains Mono,monospace'; ctx.textAlign='center';
        ctx.fillText(led.pin,lx,ly+14);
        // Duty label para modo PWM
        if (isOn && _bri < 0.98 && S._frankyLedPwm?.active) {
          ctx.fillStyle = 'rgba(255,220,80,.9)';
          ctx.font = '5px JetBrains Mono,monospace';
          ctx.fillText(Math.round(_bri * 255), lx, ly + _extRadius + 8);
        }
      });
    }

    // ── HC-SR04 ultrasonic sensor (cone of detection) ─────────
    if (_p.showHCSR04) {
      // Cone drawn in front of robot direction
      const r = eco.physics?.robot;
      if (r) {
        const rx = r.x, ry = r.y, ra = r.angle || 0;
        const coneLen = _p.hcsrDist ? Math.min(_p.hcsrDist * 1.2, 160) : 80;
        const coneAngle = 0.26; // ~15° half-angle (30° total beam)
        ctx.save();
        ctx.translate(rx, ry);
        ctx.rotate(ra);
        // Draw cone as filled triangle
        const alpha = _p.hcsrDist && _p.hcsrDist < 50 ? 0.35 : 0.18;
        ctx.fillStyle = `rgba(0,205,180,${alpha})`;
        ctx.strokeStyle = 'rgba(0,205,180,0.7)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(12, 0);  // robot front edge
        ctx.lineTo(12 + coneLen * Math.cos(coneAngle), coneLen * Math.sin(coneAngle));
        ctx.lineTo(12 + coneLen * Math.cos(-coneAngle), coneLen * Math.sin(-coneAngle));
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
        // Distance label
        if (_p.hcsrDist !== undefined) {
          ctx.fillStyle = 'rgba(0,205,180,.9)';
          ctx.font = '6px JetBrains Mono,monospace';
          ctx.textAlign = 'center';
          ctx.fillText((_p.hcsrDist|0) + ' cm', 12 + coneLen * 0.6, -8);
        }
        ctx.restore();
      }
      // HC-SR04 label
      ctx.fillStyle = 'rgba(0,205,180,.5)';
      ctx.font = '5px JetBrains Mono,monospace'; ctx.textAlign = 'left';
      ctx.fillText('HC-SR04 (' + (_p.hcsrDist ? (_p.hcsrDist|0)+' cm' : 'sin eco') + ')', 6, H-20);
    }

    // OLED: now rendered as fixed HUD div (#oled-hud), not on canvas

    ctx.restore();
  }

  // ── Layer 7: HUD status label ─────────────────────────────────
  const _chHUD = ch;
  const _isRingScene = S.activeScene?.type === 'minisumo';
  // Status label: more specific than just AVANZANDO/OBSTÁCULO
  let sl;
  if (!run) {
    sl = S.ss === 'DONE' ? '✓ PROGRAMA FINALIZADO' : (S.ss === 'PAUSED' ? 'PAUSA' : S.ss);
  } else if (isFrankyDraw) {
    const _fmode = franky ? franky.getState().mode : 0;
    const _frun  = franky ? franky.getState().running : false;
    if (_fmode === 3 && _frun) sl = '▶ BLOQUES';
    else if (_fmode === 1) sl = '🤖 MICRO AUTO';
    else if (_fmode === 2) sl = '🤖 MINI AUTO';
    else sl = det ? 'OBSTÁCULO' : 'AVANZANDO';
  } else {
    sl = det ? 'OBSTÁCULO' : (_isRingScene ? 'EN TATAMI' : 'AVANZANDO');
  }
  const sc = det ? '#f02840' : run ? '#00cdb3' : (S.ss === 'DONE' ? '#18cc60' : '#2e424f');
  const slW = S.ss === 'DONE' ? 220 : Math.max(185, sl.length * 7 + 10);
  ctx.fillStyle='rgba(5,7,12,.86)'; ctx.fillRect(7,H-23,slW,15);
  ctx.fillStyle=sc; ctx.font='8.5px JetBrains Mono,monospace'; ctx.textAlign='left';
  ctx.fillText(sl,12,H-12);
  // Sensor value label — top right: sensor type + value
  const _sensorLabel = isFrankyDraw
    ? ('ADC0:'+Math.round((franky?franky.getState().a0:0)/40.95)+'%')
    : (_isRingScene ? ('QTR:'+a0) : ('A0:'+a0));
  const _sensorColor = _isRingScene
    ? (a0>600 ? 'rgba(240,40,64,.9)' : 'rgba(24,204,96,.85)')
    : 'rgba(240,150,0,.9)';
  ctx.fillStyle=_sensorColor; ctx.font='10px JetBrains Mono,monospace';
  ctx.fillText(_sensorLabel, W-72, H-10);
  // Motor state mini-display (bottom right, during execution)
  if (run) {
    const _ma = mc.motorA, _mb = mc.motorB;
    const _maStr = _ma.direction==='FORWARD'?'A:▶':_ma.direction==='REVERSE'?'A:◀':_ma.direction==='DISABLED'?'A:—':'A:■';
    const _mbStr = _mb.direction==='FORWARD'?'B:▶':_mb.direction==='REVERSE'?'B:◀':_mb.direction==='DISABLED'?'B:—':'B:■';
    ctx.fillStyle='rgba(5,7,12,.75)'; ctx.fillRect(W-92,H-38,86,13);
    ctx.fillStyle=_ma.direction==='FORWARD'?'#00cdb3':_ma.direction==='REVERSE'?'#f09600':'#2e424f';
    ctx.font='8px JetBrains Mono,monospace';
    ctx.fillText(_maStr+'~'+(_ma.pwm||0), W-90, H-28);
    ctx.fillStyle=_mb.direction==='FORWARD'?'#00cdb3':_mb.direction==='REVERSE'?'#f09600':'#2e424f';
    ctx.fillText(_mbStr+'~'+(_mb.pwm||0), W-52, H-28);
  }
  if (FPS.state!=='ok'&&FPS.raw>0) {
    ctx.fillStyle=FPS.state==='crit'?'rgba(240,40,64,.8)':'rgba(240,150,0,.7)';
    ctx.fillText(FPS.raw+'fps',W-110,H-12);
  }

  drawRunning = false;
  requestAnimationFrame(draw);
}

// ── Drag ────────────────────────────────────────────────────────
let drag=null, dox=0, doy=0, dragRaf=false;
cvs.addEventListener('mousedown', e => {
  const r2=cvs.getBoundingClientRect(), mx=e.clientX-r2.left, my=e.clientY-r2.top;
  for (const o of (eco.physics.obstacles||[])) {
    if (o.drag!==false && mx>o.x && mx<o.x+o.w && my>o.y && my<o.y+o.h) {
      drag=o; dox=mx-o.x; doy=my-o.y; cvs.style.cursor='grabbing'; return;
    }
  }
});
cvs.addEventListener('mousemove', e => {
  if (!drag) return;
  const r2=cvs.getBoundingClientRect();
  drag.x=e.clientX-r2.left-dox; drag.y=e.clientY-r2.top-doy;
  if (!dragRaf) { dragRaf=true; requestAnimationFrame(()=>{ dragRaf=false; eco.revelation.observe(RL.OBS.OBSTACLE_MOVED,{}); }); }
});
cvs.addEventListener('mouseup', ()=>{ drag=null; cvs.style.cursor='crosshair'; });

// ══════════════════════════════════════════════════════════════
// HOME VIEW
// ══════════════════════════════════════════════════════════════
const UNITS = [
  {n:'00',t:'Primeros Pasos — LED, Entradas y Motores',
   d:'LED onboard, botón, DIP-switch, sensor analógico, primer motor. Con ROBOARD y FRANKY.',
   c:'#3878ec',
   ks:['u0-led-blink','u0-leds-externos','u0-boton','u0-un-motor','u0-leer-sensor','u0-parar-con-sensor','u0-dip-switch','u0-pwm','u0-mapeo','u0-movimiento','u0-evasion','u0-ultrasonido','u0-comparar-sensores','u0-i2c','u0-oled','u0-tof','u0-spi'],
   p:'ROBOARD',ok:true},
  {n:'E0',t:'Primeros Pasos — FRANKY Blockly',
   d:'Equivalente pedagógico de U0 para FRANKY. Mismos conceptos, mismos periféricos, programación visual con Blockly.',
   c:'#f09600',
   ks:['e0-led-blink','e0-gpio-salida','e0-sensor-adc','e0-motores','e0-decision','e0-repetir','e0-pwm','e0-movimiento','e0-evasion','e0-ultrasonido','e0-comparar','e0-oled','e0-i2c','e0-tof','e0-spi','e0-mapeo'],
   p:'FRANKY',ok:true},
  {n:'01',t:'Sistemas Robóticos y Automatización',    d:'Causalidad sensor→decisión→acción. Robot diferencial con Sharp IR.',c:'#00cdb3',
   ks:['u1-explorar-motores','u1-reactivo-parar','u1-reactivo-girar'],p:'ROBOARD',ok:true},
  {n:'02',t:'Programación de Sistemas Interactivos',  d:'millis(), máquinas de estado, control proporcional básico.',c:'#8f68ec',
   ks:['u2-secuencia-tiempos','u2-millis-no-delay','u2-seguir-pared'],p:'ROBOARD',ok:true},
  {n:'03',t:'Sensado y Adquisición de Datos',          d:'HC-SR04, QTR, Sharp IR. Calibración. Minisumo y seguidor LNR.',c:'#f09600',
   ks:['u3-calibrar-ir','u3-minisumo-borde','u3-minisumo-atacar','u3-minisumo-estrategia','u3-seguidor-linea','u3-seguidor-pd','u3-seguidor-qtr8'],p:'ROBOARD',ok:true},
  {n:'04',t:'Control de Movimiento',                   d:'Control diferencial. PID. Seguidor de línea avanzado.',c:'#18cc60',
   ks:['lf-pista-recta','lf-curvas'],p:'ROBOARD',ok:true},
  {n:'05',t:'Robots Autónomos',                        d:'Navegación. Minisumo avanzado. Competencia LNR.',c:'#f02840',ks:[],p:'ROBOARD',ok:false},
  {n:'06',t:'Control Realimentado',                    d:'Lazo cerrado. PID avanzado.',c:'#3878ec',ks:[],p:'ROBOARD',ok:false},
  {n:'07',t:'FRANKY — Robot Conectado (IoT)',         d:'Control remoto, telemetría, programación visual. ESP32-C3.',c:'#f09600',
   ks:['fk-control-remoto','fk-figuras-basicas','fk-telemetria-live','fk-led-reactivo','fk-esquivar-obstaculo','fk-patrulla','fk-minisumo-config','fk-seguidor-2sensor','fk-minisumo-pd'],p:'FRANKY',ok:true},
  {n:'08',t:'Automatización Industrial',               d:'PLC-CORE-MDE. RS485. Modbus. Lógica secuencial.',c:'#8f68ec',ks:[],p:'PLC-CORE',ok:false},
  {n:'09',t:'Sistemas Inteligentes Distribuidos',      d:'Agentes. Coordinación. Sistemas multi-robot.',c:'#00cdb3',ks:[],p:'ROBOARD',ok:false},
];

// Progress tracking
const UNIT_CHS = {};
UNITS.forEach((u,i) => u.ks.forEach(id => UNIT_CHS[id]=i));

// ── localStorage migration: inserting U0 at index 0 shifted all unit indices ──
// Run once to migrate prog:u:0→prog:u:1, prog:u:1→prog:u:2, etc.
// Safe to run multiple times — _migrated_u0 guard prevents double-migration.
(function() {
  if (lsGet('_migrated_u0')) return;
  for (var _mi = 8; _mi >= 0; _mi--) {
    var _old = lsGet('prog:u:' + _mi);
    if (_old) {
      lsSet('prog:u:' + (_mi + 1), _old);
      try { localStorage.removeItem('prog:u:' + _mi); } catch(e) {}
    }
  }
  lsSet('_migrated_u0', '1');
})();

function lsGet(k){try{return localStorage.getItem(k);}catch(e){return null;}}
function lsSet(k,v){try{localStorage.setItem(k,v);}catch(e){}}

function saveUnitProgress() {
  const st = (S._synthState) ? S._synthState : eco.challenges.getState();
  if (!st) return;
  const done= st.objectives.filter(o=>o.completed&&o.required!==false).length;
  const req = st.objectives.filter(o=>o.required!==false).length;
  if (done===req && req>0) {
    const ui = UNIT_CHS[S.cid];
    if (ui !== undefined) {
      const key = 'prog:u:'+ui;
      const prev = JSON.parse(lsGet(key)||'{}');
      prev[S.cid] = true;
      lsSet(key, JSON.stringify(prev));
    }
  }
  if (S.view==='home') renderUnits();
}

function getUnitProg(idx) { return JSON.parse(lsGet('prog:u:'+idx)||'{}'); }

function renderUnits() {
  const g = $('ugrid'); if (!g) return;

  // Calculate overall progress to determine which units are unlocked
  // Unlock rule: unit N+1 unlocks when unit N has at least 1 challenge done
  const unitProgress = UNITS.map((_,i) => {
    const p = getUnitProg(i);
    return Object.keys(p).length;
  });

  g.innerHTML = UNITS.map((u,i) => {
    const done    = unitProgress[i];
    const tot     = u.ks.length;
    const isDone  = done===tot && tot>0;
    const pct     = tot > 0 ? Math.round(done/tot*100) : 0;

    // Unlock logic: ok=true means content exists; prereq check for locked-but-available
    // Units 0-3 available if content exists; future units always locked
    const isAvail  = u.ok;
    // i > 1: U0 and U1 always accessible — U0 is optional intro, U1 is the main entry point
    const hasPre   = i > 1 && unitProgress[i-1] === 0 && u.ok;
    const isActive = S.cid && u.ks.includes(S.cid);

    let cardClass = 'ucard';
    if (!isAvail)     cardClass += ' locked';
    else if (hasPre)  cardClass += ' prereq';
    else if (isActive)cardClass += ' active-unit';

    const clickable = isAvail && !hasPre && u.ks.length > 0;
    const onclick   = clickable ? 'onclick="A.openUnit('+i+')"' : '';

    // Tags
    let tagHtml = '';
    if (isAvail) {
      tagHtml += '<span class="u-tag go">▶ '+tot+' desafíos</span>';
      if (isDone) tagHtml += '<span class="u-tag done">✓ Completada</span>';
    } else {
      tagHtml += '<span class="u-tag">🔒 Próximamente</span>';
    }

    // Progress bar (only for available units with content)
    const progHtml = (isAvail && tot > 0)
      ? '<div class="u-prog-row"><div class="u-prog-bar"><div class="u-prog-fill" style="width:'+pct+'%;background:'+u.c+'"></div></div><span style="font-family:var(--fm);font-size:.55rem;color:var(--t2);white-space:nowrap">'+done+'/'+tot+'</span></div>'
      : '';

    return '<div class="'+cardClass+'" style="--uc:'+u.c+'" '+onclick+'>'
      +'<div class="u-num">U'+u.n+' · '+u.p+'</div>'
      +'<div class="u-title">'+u.t+'</div>'
      +'<div class="u-desc">'+u.d+'</div>'
      +progHtml
      +'<div class="u-tags">'+tagHtml+'</div>'
      +'</div>';
  }).join('');
}

function updBanner(s) {
  if (!s) return;
  const ch = (s.alias||s.name||'?')[0].toUpperCase();
  $('stu-av').textContent = ch;
  $('stu-av').style.background = s.color||'var(--cy)';
  $('stu-av').style.color = '#000';
  $('stu-nm').textContent = s.name;
  const total = Object.values(UNIT_CHS).reduce((acc,ui)=>{
    const p=getUnitProg(ui); return acc+Object.keys(p).length;
  },0);
  const totalChs = UNITS.reduce((a,u)=>a+u.ks.length,0);
  $('stu-sb').textContent = total>0 ? total+' de '+totalChs+' desafíos completados' : 'Empezá con la Unidad 0 — Primeros Pasos';
  $('pbar').style.width = (totalChs>0 ? total/totalChs*100 : 0)+'%';
}

// ══════════════════════════════════════════════════════════════
// LOGIN
// ══════════════════════════════════════════════════════════════
async function showLogin() {
  $('mlogin').classList.remove('hid');
  const sts = await eco.persistence.listStudents().catch(()=>[]);
  const wrap=$('ex-w'), list=$('sl');
  if (sts.length) {
    wrap.classList.remove('hid');
    list.innerHTML = sts.sort((a,b)=>b.lastActiveAt-a.lastActiveAt).map(s =>
      '<div class="sopt" onclick="A.selS(\''+s.id+'\')">'
      +'<div class="so-av" style="background:'+(s.color||'var(--cy)')+';color:#000">'+(s.alias||s.name||'?')[0].toUpperCase()+'</div>'
      +'<div><div class="so-nm">'+s.name+'</div><div class="so-sb">'+new Date(s.lastActiveAt).toLocaleDateString()+'</div></div>'
      +'</div>'
    ).join('');
  }
}
async function doCreate() {
  const name=$('in-nm').value.trim(), alias=$('in-al').value.trim();
  if (!name) { $('in-nm').style.borderColor='var(--re)'; return; }
  const cols=['#00cdb3','#f09600','#18cc60','#8f68ec','#3878ec','#f02840'];
  const s = await eco.persistence.createStudent(name, alias||name, cols[Math.floor(Math.random()*cols.length)]).catch(()=>null);
  if (s) doLogin(s);
}
function doLogin(stu) {
  if (!stu) return;
  $('mlogin').classList.add('hid');
  // Show onboarding wizard to new users (first login ever)
  if (!lsGet('onboard-done')) {
    setTimeout(function(){ $('m-onboard').classList.remove('hid'); }, 300);
  }
  $('sav').textContent = (stu.alias||stu.name||'?')[0].toUpperCase();
  $('sav').style.background = stu.color||'var(--cy)';
  $('sav').style.color = '#000';
  $('snm').textContent = stu.alias||stu.name;
  $('spill').classList.add('on');
  updBanner(stu);
  ser('[SYS] Bienvenido/a, '+stu.name+'!','i');
}

$('btn-crt').onclick = doCreate;
$('in-nm').onkeydown = e => { if (e.key==='Enter') doCreate(); };

// ══════════════════════════════════════════════════════════════
// EDITOR HELPERS
// ══════════════════════════════════════════════════════════════
function updLineNums() {
  const n = ($('ced').value||'').split('\n').length;
  $('lnums').textContent = Array.from({length:n},(_,i)=>i+1).join('\n');
  $('lnums').scrollTop = $('ced').scrollTop;
}
let autoSaveT=null;
$('ced').addEventListener('input', () => {
  updLineNums();
  if (autoSaveT) clearTimeout(autoSaveT);
  autoSaveT = setTimeout(() => { if (S.cid) lsSet('sk:'+S.cid, $('ced').value); }, 1200);
});
$('ced').addEventListener('scroll', () => { $('lnums').scrollTop=$('ced').scrollTop; });
$('ced').addEventListener('keydown', e => {
  if (e.key==='Tab') {
    e.preventDefault();
    const s=$('ced').selectionStart, en=$('ced').selectionEnd;
    $('ced').value=$('ced').value.substring(0,s)+'  '+$('ced').value.substring(en);
    $('ced').selectionStart=$('ced').selectionEnd=s+2;
    updLineNums();
  }
});

// ══════════════════════════════════════════════════════════════
// TOAST / SERIAL / BADGE
// ══════════════════════════════════════════════════════════════
let toastT=null;
function toast(t) { clearTimeout(toastT); $('tms').textContent=t; $('tms').classList.add('on'); toastT=setTimeout(()=>$('tms').classList.remove('on'),3500); }
let errT=null;
function showErr(t) { clearTimeout(errT); $('terr').textContent=t; $('terr').classList.add('on'); errT=setTimeout(()=>$('terr').classList.remove('on'),6000); }

let serBatch=[], serFlushT=null;
let _consoleFilter = 'student'; // 'student' | 'all'
function ser(msg, type) {
  // Guard: coerce to string — prevents [object Object] in console
  let m = msg;
  if (m === null || m === undefined)       m = '(null)';
  else if (typeof m !== 'string')          m = JSON.stringify(m, null, 0).slice(0, 200);
  serBatch.push({msg:m, type});
  if (!serFlushT) serFlushT=setTimeout(flushSerial,50);
}
function flushSerial() {
  serFlushT=null; if (!serBatch.length) return;
  const frag=document.createDocumentFragment();
  for (const{msg,type}of serBatch) {
    // Student mode: only show firmware output (f) and real errors (e)
    // System/info messages only shown in 'all' mode
    if (_consoleFilter === 'student' && type === 'i') continue;
    if (_consoleFilter === 'student' && type === 's' && !msg.includes('[ERR]')) continue;
    const d=document.createElement('div');
    d.className='sl-'+(type==='f'?'f':type==='e'?'e':type==='i'?'i':'s');
    d.textContent=(type==='f'?'> ':'')+msg;
    frag.appendChild(d);
    S.log.push(msg);
  }
  serBatch=[];
  $('sout').appendChild(frag);
  while($('sout').children.length>400) $('sout').removeChild($('sout').firstChild);
  $('sout').scrollTop=$('sout').scrollHeight;
  $('sdot').style.background='var(--cy)';
}

function setBadge() {
  const m={IDLE:'IDLE',RUNNING:'EJECUTANDO',PAUSED:'PAUSA',ERROR:'ERROR',STEPPING:'PASO',DONE:'✓ FINALIZADO'};
  $('badge').textContent=m[S.ss]||S.ss;
  $('badge').className='badge b-'+S.ss.toLowerCase();
}

// ══════════════════════════════════════════════════════════════
// PUBLIC API (A)
// ══════════════════════════════════════════════════════════════
const A = window.A = {

  nav(v) {
    S.view=v;
    document.querySelectorAll('.view').forEach(x=>x.classList.remove('on'));
    $('v-'+v).classList.add('on');
    document.querySelectorAll('.npill').forEach(p=>p.classList.toggle('on',p.dataset.v===v));
    $('npills').classList.add('on');
    const sb=$('simbar');
    if (v==='lab') {
      sb.classList.add('on');
      // Ensure canvas is sized BEFORE any loadCh or render
      requestAnimationFrame(()=>{
        resize();
        // If there's an active challenge but editor is empty, load it now.
        // (This happens when the user clicks "Laboratorio →" directly without going through openUnit)
        if (S.cid && !$('ced').value.trim()) {
          loadCh(S.cid);
        } else if (S.cid) {
          applyScene(getChallenge(S.cid)?.scenarioId||'single-obstacle');
        }
        initSparks();
        buildGPIO();
        // Only start render loop if we're still in lab (not navigated away during rAF)
        if (S.view === 'lab') draw();
      });
    } else {
      sb.classList.remove('on');
      renderUnits();
      updBanner(eco.persistence.getCurrentStudent());
    }
  },

  play() {
    if (run) return;
    // Allow re-run from DONE state — treat it like IDLE so the student can
    // press ▶ again after a Blockly program finishes without needing to reset first.
    if (S.ss === 'DONE') { S.ss = 'IDLE'; }
    if (!gen) {
      const r = eco.vm.load(S.code);
      if (!r.ok) { showErr(errorsToString(r.errors)); return; }
      gen=eco.vm.createExecutor(); pend=null; rng.reset();
      ser('[SYS] Ejecutando…','i');
    }
    run=true; S.ss='RUNNING'; lts=performance.now();
    S._sessionLog.push({t:Date.now(),cid:S.cid,event:'play',data:{sim_t:S.simTime}});
    raf=requestAnimationFrame(loop); setBadge();
    eco.revelation.observe(RL.OBS.PLAY_PRESSED,{});
    $('shud').classList.add('vis');
  },

  pause() {
    if (!run) return;
    run=false; S.ss='PAUSED';
    if (raf) { cancelAnimationFrame(raf); raf=null; }
    setBadge();
  },

  step() {
    if (run) this.pause();
    if (!gen) {
      const r=eco.vm.load(S.code); if (!r.ok) { showErr(errorsToString(r.errors)); return; }
      gen=eco.vm.createExecutor(); pend=null;
    }
    S.ss='STEPPING';
    try { simTick(16.67); } catch(e) { onErr(e); return; }
    S.ss='PAUSED'; setBadge(); uiUpdate();
  },

  reset() {
    S._frankyLedPwm = null;  // clear PWM state
    if (raf) { cancelAnimationFrame(raf); raf=null; }
    run=false; gen=null; pend=null;
    // VM
    eco.vm.stop();
    eco.vm._globals={};
    eco.vm._firmwareTime=0;
    eco.vm._instructionCount=0;
    // HAL + physics + telemetry
    eco.hal.reset();
    rng.reset();
    eco.physics.reset();
    eco.telemetry.recorder.reset();
    // FRANKY cleanup (single cancel — duplicate removed)
    if (A._frankyRaf) { cancelAnimationFrame(A._frankyRaf); A._frankyRaf = null; }
    S._fkA0Max = undefined; S._fkA0Min = undefined;
    S._sumoConfig = null;  // prevent stale sumo config leaking into next run
    S._periph = null;      // reset peripheral canvas overlay
    // State
    S.simTime=0; acc=0; S.ss='IDLE';
    uiF=0; spkF=0;
    prevA0=-1; prevA1=-1; prevDA=''; prevDB=''; prevPA=-1; prevPB=-1;
    resetBloquesVM();
    if (window.FrankyBlockly) window.FrankyBlockly.clear();
    A._blocklyFSLoaded = false;  // force toolbox re-init for new challenge
    // Reload challenge (re-positions robot and obstacles with correct canvas size)
    if (S.cid) loadCh(S.cid);
    setBadge(); uiUpdate();
    ser('[SYS] Reset.','i');
  },

  setSpd(v) { S.speed=parseFloat(v); $('spdl').textContent=S.speed+'×'; },

  chChange(id) {
    S._frankyLedPwm = null;  // clear PWM state on challenge change
    if (!id) return;
    if (run) this.pause();
    gen=null; pend=null;
    eco.vm.stop(); eco.vm._globals={}; eco.vm._firmwareTime=0; eco.vm._instructionCount=0;
    eco.hal.reset(); rng.reset(); eco.physics.reset(); eco.telemetry.recorder.reset();
    S.simTime=0; acc=0; S.ss='IDLE';
    uiF=0; spkF=0;
    prevA0=-1; prevA1=-1; prevDA=''; prevDB=''; prevPA=-1; prevPB=-1;
    if (A._frankyRaf) { cancelAnimationFrame(A._frankyRaf); A._frankyRaf = null; }
    S._fkA0Max = undefined; S._fkA0Min = undefined;
    resetBloquesVM();
    // Reset FRANKY command tracking flags for E1.1 objectives
    S._frankyCmd_f=false; S._frankyCmd_b=false; S._frankyCmd_l=false; S._frankyCmd_r=false;
    S._frankySpeedChanged=false;
    S._sumoConfig=null;
    // Reset minisumo border tracking
    S._wasOnBorder=false; S._borderDetectedCount=0; S._borderEscapedCount=0;
    S._serialHintShown=false;
    S._synthState = null;  // reset synthetic challenge state on challenge change
    S._periph = null;      // reset peripheral overlay state
    // Clear Blockly workspace to avoid carrying program from previous challenge
    if (window.FrankyBlockly) window.FrankyBlockly.clear();
    A._blocklyFSLoaded = false;  // force toolbox re-init for new challenge
    // Toolbox refresh: if etapa changed (etapa5 ↔ pre-etapa5), the toolbox
    // (initV1 vs init) is different. Reset _blocklyFSLoaded so _mountBlocklyFS
    // re-initializes with the correct toolbox instead of just doing a resize.
    const prevCh  = getChallenge(S.cid);
    const nextCh  = getChallenge(id);
    const prevEt5 = prevCh && prevCh.tags && prevCh.tags.includes('etapa5');
    const nextEt5 = nextCh && nextCh.tags && nextCh.tags.includes('etapa5');
    if (prevEt5 !== nextEt5) {
      this._blocklyFSLoaded = false;  // force remount with correct toolbox
    }
    loadCh(id);
    setBadge();
  },

  loadSketch() {
    if (run) this.pause();
    gen=null; pend=null;
    S.code = $('ced').value;
    if (S.cid) lsSet('sk:'+S.cid, S.code);
    const r = eco.vm.load(S.code);
    const lb = $('clbl');
    if (r.ok) {
      gen=eco.vm.createExecutor(); pend=null;
      lb.textContent='✓ Compilado'; lb.className='cl-ok';
      renderVal(eco.validator.validate(S.code));
      ser('[SYS] Sketch cargado.','i');
      eco.revelation.observe(RL.OBS.CODE_LOADED,{hasSerial:S.code.includes('Serial.begin')});
      eco.revelation.observe(RL.OBS.CODE_MODIFIED,{});
    } else {
      lb.textContent='✗ '+errorsToString(r.errors); lb.className='cl-err';
      ser('[ERR] '+errorsToString(r.errors),'e');
    }
  },

  hint() {
    const ch = getChallengeWithHints(S.cid);
    // For synthetic challenges (u0-*, e0-*), use _synthState which has real objectives
    const st = S._synthState || eco.challenges.getState();
    const b  = $('hbox');
    if (!ch || !st) { b.innerHTML='<div class="hint-level">Pista</div>No hay desafío activo.'; b.classList.add('on'); return; }
    const incomplete = st.objectives.filter(function(o){ return o.required!==false&&!o.completed; })[0];
    if (!incomplete) { b.innerHTML='<div class="hint-level">✓ Completado</div>¡Todos los objetivos cumplidos!'; b.className='hint-box on'; return; }

    const key = (S.cid||'')+'_'+incomplete.id;
    if (!S._hintIdx) S._hintIdx={};
    const clickCount = S._hintIdx[key] || 0;
    const rawHints = (ch.hints && ch.hints[incomplete.id]) || [];

    var levelLabel='', hintText='', hintCode='', levelClass='hint-box on', hasMore=false;

    if (clickCount === 0) {
      levelLabel = '💡 Pista 1 — Objetivo';
      levelClass = 'hint-box on l1';
      hintText   = incomplete.label;
      if (rawHints.length > 0) hasMore = true;
    } else if (clickCount === 1 && rawHints[0]) {
      levelLabel = '💡 Pista 2 — Concepto';
      levelClass = 'hint-box on l1';
      hintText   = rawHints[0];
      if (rawHints[1]) hasMore = true;
    } else if (clickCount === 2 && rawHints[1]) {
      levelLabel = '⚙ Pista 3 — Técnica';
      levelClass = 'hint-box on l2';
      hintText   = rawHints[1];
      if (rawHints[2]) hasMore = true;
    } else if (clickCount >= 3 && rawHints[2]) {
      levelLabel = '📋 Pista 4 — Código de referencia';
      levelClass = 'hint-box on l3';
      if (rawHints[2].startsWith('code:')) {
        hintCode = rawHints[2].slice(5).trim();
        hintText = 'Referencia de código:';
      } else {
        hintText = rawHints[2];
      }
    } else {
      levelLabel = '💡 Pista';
      levelClass = 'hint-box on l1';
      hintText   = rawHints[rawHints.length-1] || ('Revisá: '+incomplete.label);
    }

    var safeHintText = hintText.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    var safeCode     = hintCode.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    b.className = levelClass;
    b.innerHTML  = '<div class="hint-level">'+levelLabel+'</div>'
      + '<div style="white-space:pre-wrap">'+safeHintText+'</div>'
      + (safeCode ? '<div class="hint-code">'+safeCode+'</div>' : '')
      + (hasMore ? '<div style="margin-top:7px;font-size:.58rem;color:var(--t2);cursor:pointer" onclick="A.hint()">→ Pedir más ayuda</div>' : '');

    S._hintIdx[key] = clickCount + 1;
    S._sessionLog.push({t:Date.now(),cid:S.cid,event:'hint',data:{level:clickCount+1,obj:incomplete?.id}});
    eco.revelation.observe(RL.OBS.CHALLENGE_ATTEMPTED,{});
    if (S.tab !== 'ch') A.tab('ch');
  },

  openTutorial() {
    const body = $('tutorial-body');
    if (!body) { $('m-tutorial').classList.remove('hid'); return; }
    function fmt(s) {
      return s
        .replace(/`([^`]+)`/g, '<code style="background:var(--bg2);padding:1px 4px;border-radius:3px;font-family:var(--fm);font-size:.95em">$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em style="color:var(--t2)">$1</em>');
    }
    function renderMD(md) {
      const lines = md.split('\n');
      let html = '', inTable = false, inList = false;
      lines.forEach(function(line) {
        if (line.startsWith('|')) {
          if (!inTable) { html += '<table style="width:100%;border-collapse:collapse;font-size:.6rem;margin:8px 0">'; inTable=true; }
          const cells = line.split('|').filter(function(s,i,a){ return i>0&&i<a.length-1; });
          const isSep = line.replace(/[|:\-]/g,'').trim()==='';
          if (!isSep) {
            html += '<tr>' + cells.map(function(cell){ return '<td style="padding:3px 8px;border:1px solid var(--ln)">'+fmt(cell.trim())+'</td>'; }).join('') + '</tr>';
          }
          return;
        } else if (inTable) { html += '</table>'; inTable=false; }
        if (line.startsWith('### ')) { html += '<h3 style="color:var(--cy);margin:14px 0 4px;font-size:.78rem">'+line.slice(4)+'</h3>'; return; }
        if (line.startsWith('## '))  { html += '<h2 style="color:var(--cy);margin:18px 0 6px;font-size:.88rem;border-bottom:1px solid var(--ln);padding-bottom:3px">'+line.slice(3)+'</h2>'; return; }
        if (line.startsWith('# '))   { html += '<h1 style="color:var(--cy);margin:0 0 10px;font-size:1rem">'+line.slice(2)+'</h1>'; return; }
        if (line.trim() === '---') { html += '<hr style="border:none;border-top:1px solid var(--ln);margin:10px 0">'; return; }
        if (line.startsWith('- ') || line.startsWith('* ')) {
          if (!inList) { html += '<ul style="margin:4px 0;padding-left:18px">'; inList=true; }
          html += '<li style="margin:2px 0">'+fmt(line.slice(2))+'</li>'; return;
        } else if (inList) { html += '</ul>'; inList=false; }
        if (line.trim() === '') { if (inList){html+='</ul>';inList=false;} html+='<br>'; return; }
        html += '<p style="margin:3px 0">'+fmt(line)+'</p>';
      });
      if (inTable) html += '</table>';
      if (inList)  html += '</ul>';
      return html;
    }
    if (!body.innerHTML || body.innerHTML.length < 10) {
      body.innerHTML = renderMD(TUTORIAL_MD);
    }
    $('m-tutorial').classList.remove('hid');
  },

  openTeacher() {
    S._teacherNotes = lsGet('teacher:notes') || '';
    const tn = $('td-notes');
    if (tn) tn.value = S._teacherNotes;
    const stu = eco.auth?.getStudent?.() || {};
    const tdStu = $('td-student');
    if (tdStu) tdStu.innerHTML = '<strong style="color:var(--t1)">' + (stu.name || lsGet('stu:name') || 'Estudiante') + '</strong>';
    // Progress table
    const tdProg = $('td-progress');
    if (tdProg) {
      let rows = '<table style="width:100%;font-family:var(--fm);font-size:.52rem;border-collapse:collapse">';
      rows += '<tr style="color:var(--t2);border-bottom:1px solid var(--ln)"><th style="text-align:left;padding:2px 5px">Unidad</th><th style="text-align:left;padding:2px 5px">Desafío</th><th style="padding:2px 5px">Estado</th><th style="padding:2px 5px">Pistas</th></tr>';
      UNITS.forEach(function(u,idx) {
        if (!u.ok) return;
        const prog = getUnitProg(idx);
        u.ks.forEach(function(id) {
          const ch = getChallenge(id); if (!ch) return;
          const done = !!(prog[id]);
          const hints = Object.keys(S._hintIdx||{}).filter(function(k){ return k.startsWith(id+'_'); }).length;
          rows += '<tr style="border-bottom:1px solid rgba(255,255,255,.04)">'
            + '<td style="padding:2px 5px;color:var(--t2)">U'+u.n+'</td>'
            + '<td style="padding:2px 5px;color:var(--t1)">'+(ch.name||id)+'</td>'
            + '<td style="text-align:center;padding:2px 5px">'+(done?'<span style="color:var(--cy)">✓</span>':'<span style="color:var(--t2)">○</span>')+'</td>'
            + '<td style="text-align:center;padding:2px 5px;color:'+(hints>2?'var(--re)':hints>0?'var(--am)':'var(--t2)') + '">'+(hints||'—')+'</td>'
            + '</tr>';
        });
      });
      tdProg.innerHTML = rows + '</table>';
    }
    // Indicators
    const log = S._sessionLog || [];
    const plays=log.filter(function(e){return e.event==='play';}).length;
    const completes=log.filter(function(e){return e.event==='complete';}).length;
    const hints_req=log.filter(function(e){return e.event==='hint';}).length;
    const errors=log.filter(function(e){return e.event==='error';}).length;
    const totalChs=UNITS.reduce(function(a,u){return a+(u.ok?u.ks.length:0);},0);
    const doneChs=Object.values(UNIT_CHS).reduce(function(acc,ui){return acc+Object.keys(getUnitProg(ui)).length;},0);
    const persistence=plays>0?Math.min(5,Math.round(plays/Math.max(completes,1))):0;
    const autonomy=Math.max(0,5-Math.round(hints_req/Math.max(completes,1)));
    const tdInd=$('td-indicators');
    if (tdInd) {
      function ind(label,val,color){
        return '<div style="background:var(--bg2);border-radius:var(--r);padding:5px 8px;flex:1;min-width:100px">'
          +'<div style="font-family:var(--fm);font-size:.45rem;color:var(--t2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px">'+label+'</div>'
          +'<div style="font-size:.75rem;color:'+color+';font-weight:bold">'+val+'</div></div>';
      }
      tdInd.innerHTML=
        ind('Progreso',doneChs+'/'+totalChs,'var(--cy)')+
        ind('Ejecuciones',plays,'var(--t1)')+
        ind('Persistencia','★'.repeat(persistence)+'☆'.repeat(5-persistence),'var(--am)')+
        ind('Autonomía','★'.repeat(autonomy)+'☆'.repeat(5-autonomy),'var(--gr)')+
        ind('Pistas',hints_req,hints_req>completes*2?'var(--am)':'var(--t2)')+
        ind('Errores',errors,errors>5?'var(--re)':'var(--t2)');
    }
    // Narrative
    const tdNar=$('td-narrative');
    if (tdNar) {
      const byC={};
      log.forEach(function(e){ if(!byC[e.cid])byC[e.cid]=[]; byC[e.cid].push(e); });
      let narr='';
      Object.entries(byC).forEach(function(entry){
        const cid=entry[0],evts=entry[1];
        const ch=getChallenge(cid); if(!ch) return;
        const cPlays=evts.filter(function(e){return e.event==='play';}).length;
        const cHints=evts.filter(function(e){return e.event==='hint';}).length;
        const cDone=evts.some(function(e){return e.event==='complete';});
        const cErrs=evts.filter(function(e){return e.event==='error';}).length;
        let d='<strong style="color:var(--cy)">'+(ch.name||cid)+'</strong>: '+cPlays+' ejecución'+(cPlays===1?'':'es');
        if(cDone) d+=' · <span style="color:var(--cy)">✓ Completado</span>';
        if(cHints>0) d+=' · '+cHints+' pista'+(cHints===1?'':'s');
        if(cErrs>0) d+=' · <span style="color:var(--re)">'+cErrs+' error'+(cErrs===1?'':'es')+'</span>';
        if(cHints>2&&!cDone) d+=' <em style="color:var(--am)">← necesita apoyo</em>';
        if(cPlays>5&&!cDone) d+=' <em style="color:var(--am)">← explorando activamente</em>';
        if(cDone&&cHints===0) d+=' <em style="color:var(--gr)">← resolvió autónomamente</em>';
        narr+='<div style="margin-bottom:4px">'+d+'</div>';
      });
      tdNar.innerHTML=narr||'<em style="color:var(--t2)">Sin actividad registrada aún.</em>';
    }
    $('m-teacher').classList.remove('hid');
  },

  exportTeacherJSON() {
    const stu=eco.auth?.getStudent?.() || {};
    const progress={};
    UNITS.forEach(function(u,i){ if(u.ok) progress['U'+u.n]=getUnitProg(i); });
    const data={version:'ROBOLAB-V1',exported:new Date().toISOString(),
      student:stu.name||lsGet('stu:name')||'Estudiante',
      progress,hints:S._hintIdx||{},sessionLog:S._sessionLog||[],teacherNotes:S._teacherNotes||''};
    const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download='robolab-progreso-'+(stu.name||'estudiante').replace(/\s+/g,'_')+'-'+new Date().toISOString().slice(0,10)+'.json';
    a.click(); toast('📥 Progreso exportado');
  },

  tab(id) {
    S.tab=id;
    document.querySelectorAll('.ptab').forEach(t=>t.classList.toggle('on',t.dataset.p===id));
    document.querySelectorAll('.pp').forEach(p=>p.classList.toggle('on',p.id==='pp-'+id));
    if (id==='th') { TH.render(); $('thdot').classList.remove('on'); }
    if (id==='hw') updSparks();
    if (id==='mn') { $('manual-content').innerHTML=''; A._renderManual(); }
  },

  _MANUAL_SECTIONS: null, // loaded from RL.MANUAL_SECTIONS in bundle

  _renderManual() {
    const el=$('manual-content'); if(!el) return;
    el.innerHTML='';
    // Merge bundle sections with MANUAL_CONTENT fallback
    const sections = (typeof getManualSections === 'function') ? getManualSections() : (this._MANUAL_SECTIONS||[]);
    const cid=S.cid;
    const SECTION_FOR_TAG={
      'minisumo':'qtr','lnr':'qtr8','line-follower':'qtr','qtr8':'qtr8',
      'pd':'control-pd','proportional':'control-p','pid':'control-pd',
      'millis':'millis','hcsr04':'hcsr04','ir':'sharp-ir',
      'franky':'webserver','bloques':'bytecode','blockly':'bytecode',
      'calibrar':'analogread','pwm':'pwm','tb6612fng':'puente-h',
      'motor':'puente-h','motors':'puente-h',
    };
    // Determine relevant section by challenge tag
    var relevantId=null;
    var ch=getChallenge(cid);
    if(ch&&ch.tags){for(var ti=0;ti<ch.tags.length;ti++){var m=SECTION_FOR_TAG[ch.tags[ti]];if(m){relevantId=m;break;}}}
    // Also check challenge ID directly for FRANKY challenges
    if(!relevantId && cid) {
      if(cid.startsWith('fk-') && (cid.includes('bloq')||cid.includes('fig')||cid.includes('esq')||cid.includes('patrol')||cid.includes('seg')||cid.includes('mini'))) relevantId='bytecode';
      if(cid.startsWith('fk-') && cid.includes('control')) relevantId='webserver';
      if(cid.includes('millis')) relevantId='millis';
      if(cid.includes('motor')||cid==='u1-explorar-motores') relevantId='puente-h';
      if(cid.includes('reactivo')||cid.includes('parar')||cid.includes('girar')) relevantId='sharp-ir';
      if(cid.includes('borde')||cid.includes('ring')||cid.includes('lf-')) relevantId='qtr';
    }
    if (!sections.length) {
      el.innerHTML='<div style="font-family:var(--fm);font-size:.58rem;color:var(--t2);padding:16px;text-align:center">El manual se carga con los archivos del firmware.<br>Abrí el challenge para ver el contenido relevante.</div>';
      return;
    }
    el.innerHTML=sections.map(function(s){
      var safeBody=(s.body||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      var safeTitle=(s.title||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      var rel=(s.id===relevantId);
      // Per-challenge context line
      var contextLine='';
      if(s._context && s._context[cid]) {
        var safeCtx=s._context[cid].replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        contextLine='<div style="margin-top:8px;padding:5px 8px;background:rgba(0,205,179,.06);border-left:2px solid rgba(0,205,179,.3);border-radius:3px;font-family:var(--fm);font-size:.53rem;color:rgba(0,205,179,.85);line-height:1.6">'+safeCtx+'</div>';
      }
      return '<details data-section="'+s.id+'" '+(rel?'open':'')+' style="border:1px solid '+(rel?'var(--cy)':'var(--ln)')+';border-radius:6px;overflow:hidden;margin-bottom:4px">'
        +'<summary style="padding:8px 10px;cursor:pointer;font-family:var(--fm);font-size:.62rem;font-weight:700;color:'+(rel?'var(--cy)':'var(--t1)')+';background:var(--bg2);user-select:none;display:flex;align-items:center;justify-content:space-between">'
        +'<span>'+safeTitle+'</span>'+(rel?'<span style="font-family:var(--fm);font-size:.44rem;padding:2px 6px;border-radius:10px;background:rgba(0,205,179,.1);color:var(--cy)">▶ relevante</span>':'')
        +'</summary>'
        +'<div style="padding:10px 12px;white-space:pre-wrap;font-family:var(--fm);font-size:.58rem;color:var(--t1);line-height:1.8">'+safeBody+contextLine+'</div>'
        +'</details>';
    }).join('');
  },

  nextTh() { TH.next(); },

  clrS() {
    $('sout').innerHTML='<span class="sl-s">// Console limpio</span>';
    $('sdot').style.background='var(--t2)';
    S.log=[];
  },

  _toggleConsoleMode() {
    _consoleFilter = (_consoleFilter === 'student') ? 'all' : 'student';
    const btn = $('console-mode-btn');
    if (btn) {
      btn.textContent = (_consoleFilter === 'all') ? 'alumno' : 'debug';
      btn.style.opacity = (_consoleFilter === 'all') ? '1' : '.55';
      btn.style.color = (_consoleFilter === 'all') ? 'var(--cy)' : '';
    }
    ser(_consoleFilter === 'all' ? '[SYS] Modo debug — mostrando todos los mensajes' : '[SYS] Modo alumno — solo Serial.print y errores', 's');
  },

  showLogin,

  selS: async (id) => {
    const s = await eco.persistence.setCurrentStudent(id).catch(()=>null);
    if (s) doLogin(s);
  },

  openUnit(i) {
    const u=UNITS[i]; if (!u||!u.ok||!u.ks.length) return;
    A.nav('lab');
    // After rAF from nav(), load the challenge
    requestAnimationFrame(()=>{
      requestAnimationFrame(()=>{ A.chChange(u.ks[0]); });
    });
  },

  async exportP() {
    try {
      const j=await eco.persistence.exportBundle().catch(()=>null);
      if (!j) { ser('[SYS] No hay perfil activo.','i'); return; }
      const blob=new Blob([j],{type:'application/json'});
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');
      const stu=eco.persistence.getCurrentStudent();
      a.download='robolab-'+(stu?.alias||stu?.name||'perfil').toLowerCase().replace(/\s+/g,'-')+'.json';
      a.href=url; a.click(); URL.revokeObjectURL(url);
      toast('✓ Perfil exportado');
    } catch(e) { ser('[ERR] '+e.message,'e'); }
  },

  importP() { $('imp-f').click(); },

  async _doImport(input) {
    if (!input.files.length) return;
    const file=input.files[0]; input.value='';
    try {
      const j=await file.text();
      const r=await eco.persistence.importBundle(j).catch(e=>({ok:false,error:e.message}));
      if (!r.ok) { ser('[ERR] '+(r.error||'formato inválido'),'e'); return; }
      doLogin(r.student);
      toast('✓ Perfil importado: '+r.student.name);
    } catch(e) { ser('[ERR] '+e.message,'e'); }
  },

  // ── FRANKY WebServer methods ────────────────────────────────
  _blocklyLoaded: false,
  _blocklyLoading: false,

  openFranky() {
    $('franky-panel').classList.add('on');
    // Dock panel into lab grid (adds 3rd column, canvas auto-resizes)
    const lab=$('v-lab');
    if(lab) lab.classList.add('franky-open');
    // Move panel into lab if not already there
    if(lab && !lab.contains($('franky-panel'))) lab.appendChild($('franky-panel'));
    getFranky().reset();
    A.wpPage('gamepad');
    if (this._frankyPoll) clearInterval(this._frankyPoll);
    this._frankyPoll = setInterval(()=>A._updateFrankyUI(), 300);
    // Resize canvas to fit new layout
    setTimeout(function(){ resize(); }, 50);
  },

  wpPage(page) {
    document.querySelectorAll('.wp-page').forEach(p=>p.classList.remove('on'));
    document.querySelectorAll('.wp-nav-btn').forEach(b=>b.classList.toggle('on',b.dataset.wp===page));
    const el=$('wp-'+page); if(el) el.classList.add('on');
    if (page === 'bloques') {
      // Open Blockly in fullscreen (workspace is too small in phone frame)
      A._ensureBlockly();
      setTimeout(function(){ A._openBlyFS(); }, this._blocklyLoaded ? 150 : 4500); // wait for load if needed
    } else {
      // Close fullscreen Blockly when navigating away
      if($('bly-fullscreen')&&$('bly-fullscreen').style.display!=='none') A._closeBlyFS();
    }
  },

  _ensureBlockly() {
    if (this._blocklyLoaded || this._blocklyLoading) {
      // Already loaded — just resize
      if (this._blocklyLoaded && window.FrankyBlockly) {
        setTimeout(()=>{ window.FrankyBlockly.resize(); }, 50);
      }
      return;
    }
    this._blocklyLoading = true;
    const bar = $('bly-load-bar');
    // Load Blockly files sequentially (they depend on each other)
    // Load order matters: blockly_compressed.js first, then extensions, then our module
    const files = [
      'blockly_compressed.js',      // Blockly core (951KB, concatenated from bly_core_1..5)
      'bly_blocks.js',               // Standard block library
      'bly_js.js',                   // JavaScript code generator
      'bly_msg.js',                   // Spanish messages
      'franky-blockly-helpers.js',   // FRANKY globals: mkPinOpts, FRANKY_PINS, etc. (MUST be before franky-blockly.js)
      'franky-blockly.js',           // FRANKY block definitions + workspace
    ];
    let loaded = 0;
    function loadNext() {
      if (loaded >= files.length) {
        A._mountBlockly();
        return;
      }
      if (bar) bar.style.width = Math.round(loaded/files.length*100)+'%';
      const s = document.createElement('script');
      s.src = files[loaded];
      s.onload = ()=>{ loaded++; loadNext(); };
      s.onerror = (e)=>{ ser('[ERR] Blockly file failed: '+files[loaded],'e'); loaded++; loadNext(); };
      document.head.appendChild(s);
    }
    loadNext();
  },

  _mountBlockly() {
    this._blocklyLoaded = true;
    this._blocklyLoading = false;
    const loading = $('bly-loading');
    if (loading) loading.style.display = 'none';
    if (!window.FrankyBlockly) {
      if ($('bly-loading')) $('bly-loading').innerHTML = '<div style="font-family:var(--fm);font-size:.55rem;color:var(--re);text-align:center;padding:12px">✗ Error cargando Blockly.<br>Verificá que todos los archivos .js estén en la misma carpeta.</div>';
      this._blocklyLoaded = false;
      ser('[ERR] FrankyBlockly module not loaded — check franky-blockly-helpers.js exists in same folder','e');
      return;
    }
    // No inicializar en bly-div (220px, inutilizable) — solo usar FS workspace
    ser('[SYS] Blockly listo — abriendo workspace completo…','i');
    // Snapshot the challenge ID at load time. If the user navigated away or changed
    // challenge during the 80ms setTimeout, the mount is stale and should be skipped
    // to avoid mounting the wrong toolbox or overwriting a valid workspace.
    const cidAtLoad = S.cid;
    setTimeout(() => {
      // Guard: only mount if still in lab, same challenge, and FS is visible or pending open
      if (S.view !== 'lab') return;
      if (S.cid !== cidAtLoad) return;
      this._mountBlocklyFS();
    }, 80);
  },

  fkBloquesRun() {
    if (!window.FrankyBlockly) { ser('[ERR] Blockly no cargado','e'); return; }
    const insts = window.FrankyBlockly.getInstructions();
    if (insts.length === 0) { ser('[SYS] No hay bloques en el programa','i'); return; }
    getFranky();
    getFranky().handleRequest('POST','/bloques/clear');
    insts.forEach(inst => getFranky().handleRequest('POST','/bloques/add',{op:inst.op,val:inst.val}));
    getFranky().handleRequest('POST','/bloques/run');
    resetBloquesVM();
    ser('[SYS] Ejecutando programa: '+(insts.length-1)+' instrucciones','i');
    A._updateFrankyUI();
    // CRITICAL: start sim loop so bloquesVMStep() runs
    if (!run) {
      run = true;
      S.ss = 'RUNNING';
      lts = performance.now();
      S._sessionLog.push({t:Date.now(),cid:S.cid,event:'play',data:{mode:'bloques',sim_t:S.simTime}});
      raf = requestAnimationFrame(loop);
      setBadge();
      $('shud').classList.add('vis');
    }
  },

  fkBloquesClear() {
    if (window.FrankyBlockly) window.FrankyBlockly.clear();
    getFranky().handleRequest('POST','/bloques/clear');
    resetBloquesVM();
    A._updateFrankyUI();
  },

  _blocklyFSLoaded: false,
  _blocklyCurrentToolbox: '',  // tracks which toolbox is currently loaded
  _openBlyFS() {
    const blyFS=$('bly-fullscreen');
    if(!blyFS) return;
    // PANEL MODE: Blockly replaces the right panel (#rp) instead of overlaying the canvas.
    // This keeps the canvas and FRANKY panel always visible — the student can
    // program blocks AND observe the robot simultaneously.
    blyFS.classList.add('panel-mode');
    blyFS.style.display='flex';
    blyFS.style.position='';  // panel-mode CSS overrides to static
    const rp=$('rp');
    if(rp) rp.classList.add('bly-mode');  // hide #rp content
    // Insert blyFS as last child of v-lab (after franky-panel and where rp was)
    const vlab=$('v-lab');
    if(vlab && blyFS.parentNode !== vlab) vlab.appendChild(blyFS);
    // Mount or resize workspace
    if(this._blocklyFSLoaded && window.FrankyBlockly) {
      setTimeout(function(){ window.FrankyBlockly.resize(); }, 60);
    } else if(this._blocklyLoaded && window.FrankyBlockly) {
      this._mountBlocklyFS();
    } else if(!this._blocklyLoading) {
      this._ensureBlockly();
    }
  },
  _closeBlyFS() {
    const blyFS=$('bly-fullscreen');
    if(blyFS){
      blyFS.classList.remove('panel-mode');
      blyFS.style.display='none';
      // Move blyFS back to body so it doesn't affect the grid
      if(blyFS.parentNode !== document.body) document.body.appendChild(blyFS);
    }
    // Restore #rp — canvas and FRANKY panel were already visible
    const rp=$('rp'); if(rp) rp.classList.remove('bly-mode');
    // DO NOT stop the simulation — the student should be able to:
    //   1. Run a Blockly program
    //   2. Close the workspace to see the robot unobstructed
    //   3. Observe the movement
    //   4. Reopen Blockly to adjust and re-run
    // Only stop if the sim is in an ERROR state (robot would be stuck anyway)
    if(S.ss === 'ERROR') { run=false; if(raf){cancelAnimationFrame(raf);raf=null;} setBadge(); }
    // Return phone to gamepad view
    document.querySelectorAll('.wp-nav-btn').forEach(function(b){b.classList.toggle('on',b.dataset.wp==='gamepad');});
    document.querySelectorAll('.wp-page').forEach(function(p){p.classList.remove('on');});
    const gp=$('wp-gamepad');if(gp)gp.classList.add('on');
  },
  _mountBlocklyFS() {
    if(!window.FrankyBlockly){return;}
    // Guard: if already mounted with SAME toolbox, just resize
    const ch_for_bly = getChallenge(S.cid);
    const neededToolbox = ch_for_bly?.blocklyToolbox || 'v1';
    if(this._blocklyFSLoaded && this._blocklyCurrentToolbox === neededToolbox) {
      setTimeout(function(){ window.FrankyBlockly.resize(); }, 80);
      return;
    }
    // Toolbox changed — dispose and re-create workspace
    if(this._blocklyFSLoaded && window.FrankyBlockly) {
      try {
        const _ws = window.FrankyBlockly.getWorkspace();
        if (_ws) { _ws.dispose(); }
      } catch(e) {}
    }
    this._blocklyFSLoaded = false;  // reset before reinit
    const fsWs=$('bly-fs-workspace');
    if(!fsWs)return;
    fsWs.innerHTML='';
    // Toolbox selection by challenge type:
    // - blocklyToolbox:'e0ext' → E0 Extendida toolbox (PWM, GPIO, Variables, Sensores+)
    // - blocklyToolbox:'full' or etapa5 tag → full toolbox
    // - default → V1 minimal toolbox
    const ch = getChallenge(S.cid);
    const blyToolbox = ch?.blocklyToolbox || 'v1';
    const useE0ext = blyToolbox === 'e0ext';
    const useFull  = blyToolbox === 'full' || (ch?.tags && ch.tags.includes('etapa5'));
    const initFn = useFull  ? (window.FrankyBlockly.init)
                 : useE0ext ? (window.FrankyBlockly.initE0ext || window.FrankyBlockly.init)
                 :             (window.FrankyBlockly.initV1   || window.FrankyBlockly.init);
    // Clear previously registered f_ blocks to prevent "overwrites previous definition" warnings
    // This happens when toolbox changes and initFn re-registers all block definitions
    if (window.Blockly && window.Blockly.Blocks) {
      Object.keys(window.Blockly.Blocks)
        .filter(function(k){ return k.startsWith('f_'); })
        .forEach(function(k){ delete window.Blockly.Blocks[k]; });
    }
    const ok=initFn.call(window.FrankyBlockly,'bly-fs-workspace',function(instructions){
      if(!franky)return;
      getFranky().handleRequest('POST','/bloques/clear');
      instructions.forEach(function(i){getFranky().handleRequest('POST','/bloques/add',{op:i.op,val:i.val});});
      const cnt=$('bly-fs-count');
      if(cnt) cnt.textContent=Math.max(0,instructions.length-1)+' bloques';
      // Show C++ equivalent in the code view (pedagogic: visual ↔ textual)
      A._showBlocklyCode();
    });
    if(ok){
      this._blocklyFSLoaded = true;  // mark as loaded ONLY after successful init
      A._blocklyCurrentToolbox = neededToolbox;  // track which toolbox is loaded
      ser('[SYS] Blockly listo','i');
      setTimeout(function(){window.FrankyBlockly.resize();},100);
    }
    else{fsWs.innerHTML='<div style="padding:20px;color:var(--re);font-family:var(--fm);font-size:.6rem">✗ Error inicializando Blockly.</div>';}
  },
  _blyCodeVisible: false,
  _showBlocklyCode() {
    if (!window.FrankyBlockly || !window.Blockly) return;
    try {
      const ws = window.FrankyBlockly.getWorkspace();
      if (!ws) return;
      // Use Blockly's JavaScript generator to get C++ equivalent
      const _blyGen = window.Blockly?.JavaScript || window.Blockly?.javascriptGenerator;
      const code = _blyGen ? _blyGen.workspaceToCode(ws) : '';
      const panel = $('bly-code-panel');
      const text = $('bly-code-text');
      const btn = $('bly-code-btn');
      if (text) text.textContent = code || '// (programa vacío)';
      if (btn) btn.style.display = code ? '' : 'none';
      if (panel && this._blyCodeVisible) panel.style.display = '';
    } catch(e) { /* generator may fail silently */ }
  },
  _toggleBlyCode() {
    this._blyCodeVisible = !this._blyCodeVisible;
    const panel = $('bly-code-panel');
    if (panel) panel.style.display = this._blyCodeVisible ? '' : 'none';
    const btn = $('bly-code-btn');
    if (btn) btn.textContent = this._blyCodeVisible ? '✕ C++' : '{} C++';
  },
  _bloquesRunFS() {
    if(!window.FrankyBlockly){ser('[ERR] Blockly no cargado','e');return;}
    const insts=window.FrankyBlockly.getInstructions();
    if(!insts.length){ser('[SYS] Sin bloques — arrastrá bloques al workspace para crear un programa.','i');return;}
    const instrCount = insts.length-1; // subtract FIN
    // Ensure FrankySimulator is initialized
    getFranky();
    getFranky().handleRequest('POST','/bloques/clear');
    insts.forEach(function(i){getFranky().handleRequest('POST','/bloques/add',{op:i.op,val:i.val});});
    getFranky().handleRequest('POST','/bloques/run');
    resetBloquesVM();
    A._updateFrankyUI();
    // CRITICAL: start sim loop so bloquesVMStep() runs inside simTick().
    // Also handles re-run from DONE state — reset to IDLE first.
    if (S.ss === 'DONE') { S.ss = 'IDLE'; }
    if (!run) {
      run = true;
      S.ss = 'RUNNING';
      lts = performance.now();
      raf = requestAnimationFrame(loop);
      setBadge();
      $('shud').classList.add('vis');
    }
    // Pedagogic message: confirm what's running
    ser('[SYS] ▶ Ejecutando '+instrCount+' instrucciones. Observá la simulación.','i');
  },

  closeFranky() {
    $('franky-panel').classList.remove('on');
    const lab=$('v-lab');
    if(lab) lab.classList.remove('franky-open');
    if (this._frankyPoll) { clearInterval(this._frankyPoll); this._frankyPoll=null; }
    setTimeout(function(){ resize(); }, 50);
  },



  _frankyOpenTimer:null,
  _frankyRaf:null,
  _startFrankyLoop(){
    if(this._frankyRaf) return;  // already running
    if(run) return;               // sim loop (loop()) already handles physics via simTick — no duplication
    const _frankyLoop=()=>{
      const ch=getChallenge(S.cid);
      if(!ch || ch.platformId!=='FRANKY'){ this._frankyRaf=null; return; }
      const sim=getFranky();
      eco.physics.step(sim.getMotorCmds(),16.67);
      this._frankyRaf=requestAnimationFrame(_frankyLoop);
    };
    this._frankyRaf=requestAnimationFrame(_frankyLoop);
  },

  _applyFrankyPhysicsNow(){
    if (run) return;  // sim loop handles physics in simTick() — no double step
    const sim=getFranky();
    eco.physics.step(sim.getMotorCmds(),16.67);
    this._startFrankyLoop();
  },

  fkReq(method, path, params={}) {
    const sim = getFranky();
    const result = sim.handleRequest(method, path, params);
    A._updateFrankyUI();
    A._emitFrankyTick();
    // Determine sim loop state BEFORE calling _applyFrankyPhysicsNow.
    // If we start run=true first, then _applyFrankyPhysicsNow → _startFrankyLoop
    // sees run=true and returns early (correct). Previous order caused double physics.
    if ((path === '/sumo/mini' || path === '/sumo/micro') && !run) {
      run = true; S.ss = 'RUNNING'; lts = performance.now();
      raf = requestAnimationFrame(loop); setBadge(); $('shud').classList.add('vis');
    }
    if (path === '/sumo/stop' || path === '/st') {
      if (run && S.ss !== 'DONE') { run=false; if(raf){cancelAnimationFrame(raf);raf=null;} S.ss='IDLE'; setBadge(); }
    }
    // Apply physics AFTER sim loop state is set — _startFrankyLoop will see run=true and skip
    A._applyFrankyPhysicsNow();
    return result;
  },

  fkMove(dir) {
    const spd = parseInt($('fk-spd')?.value || 200);
    // Swap l/r: the FrankySimulator's motor wiring has left/right physically inverted
    // relative to the D-pad visual. 'd':'l' turns the robot RIGHT on screen.
    // Swapping here makes ◀ turn LEFT and ▶ turn RIGHT as expected.
    const _physDir = dir === 'l' ? 'r' : dir === 'r' ? 'l' : dir;
    getFranky().handleRequest('POST', '/mv', {d:_physDir, val:spd});
    // Track which commands were issued (for E1.1 objective evaluation)
    if (dir==='f') S._frankyCmd_f=true;
    if (dir==='b') S._frankyCmd_b=true;
    if (dir==='l') S._frankyCmd_l=true;  // use VISUAL direction for tracking (pre-swap)
    if (dir==='r') S._frankyCmd_r=true;
    A._updateFrankyUI();
    A._applyFrankyPhysicsNow();
    A._emitFrankyTick();
  },

  fkStop() {
    getFranky().handleRequest('POST', '/st');
    A._updateFrankyUI();
    A._applyFrankyPhysicsNow();
    A._emitFrankyTick();
  },

  // Emit a SIM_TICK so challenge objectives are evaluated when gamepad/fkReq is used
  // without the main sim loop running. This fixes E1.1 (fk-control-remoto) where
  // pressing the D-Pad never triggered objective completion because SIM_TICK was
  // only emitted inside simTick() which only runs when run===true.
  _emitFrankyTick() {
    if (!franky) return;
    const effectiveMC = franky.getMotorCmds();
    const r = R();
    const obs = eco.physics.obstacles || [];
    const fs = franky.getState();
    eco.eventBus.emit({type:'SIM_TICK', payload:{
      simTime: S.simTime,
      gpio: eco.hal.getAllPins(),
      motorCmds: effectiveMC,
      robotState: r,
      obstacles: obs,
      variables: {
        motor_moved:    !!(Math.abs(effectiveMC.motorA.pwm||0)+Math.abs(effectiveMC.motorB.pwm||0) > 0),
        // forward/turn/reverse_moved: TRUE while happening OR persistently after cmd was issued.
        // Bundle evaluators that check instantaneous state miss commands after button release.
        forward_moved:  (effectiveMC.motorA.direction==='FORWARD' && effectiveMC.motorB.direction==='FORWARD' && (effectiveMC.motorA.pwm||0)>0) || !!(S._frankyCmd_f),
        turn_performed: (effectiveMC.motorA.direction !== effectiveMC.motorB.direction && (effectiveMC.motorA.pwm||0)>0) || !!(S._frankyCmd_l || S._frankyCmd_r),
        reverse_moved:  (effectiveMC.motorA.direction==='REVERSE' && effectiveMC.motorB.direction==='REVERSE' && (effectiveMC.motorA.pwm||0)>0) || !!(S._frankyCmd_b),
        robot_x: r.x, robot_y: r.y, robot_angle: r.angle,
        vL: r.vL||0, vR: r.vR||0,
        sim_time: S.simTime,
        motorSpeed: fs.motorSpeed,
        mode: fs.mode,
        adc0: fs.a0,
        pwmA: fs.pwmA,
        pwmB: fs.pwmB,
        sumo_running: fs.mode===1||fs.mode===2,
        bloques_ran: fs.mode===3 && !fs.running,
        led_on: !!(fs.ledState || fs.ledOn || fs.led),
        survived_ms: S.simTime,
        in_ring: true,
        // Cumulative command tracking for E1.1 objectives
        // Each field is set TRUE permanently once the command is issued.
        // The bundle evaluator can check 'cmd_f_sent', 'cmd_b_sent', etc.
        cmd_f_sent: S._frankyCmd_f || false,
        cmd_b_sent: S._frankyCmd_b || false,
        cmd_l_sent: S._frankyCmd_l || false,
        cmd_r_sent: S._frankyCmd_r || false,
        speed_changed: S._frankySpeedChanged || false,
      }
    }, source:'UI'});
    renderObjs();
  },

  fkSumoConfig() {
    // Read all sumo configuration sliders and store in session state
    const atkA  = parseInt($('fk-atk-a')?.value  || 255);
    const atkB  = parseInt($('fk-atk-b')?.value  || 255);
    const srchA = parseInt($('fk-srch-a')?.value || 160);
    const srchB = parseInt($('fk-srch-b')?.value || 160);
    const thrBorde = parseInt($('fk-thr-borde')?.value || 2700);
    const thrAtk   = parseInt($('fk-thr-atk')?.value   || 400);
    // Update display labels
    if ($('fk-atk-a-lbl'))      $('fk-atk-a-lbl').textContent   = atkA;
    if ($('fk-atk-b-lbl'))      $('fk-atk-b-lbl').textContent   = atkB;
    if ($('fk-srch-a-lbl'))     $('fk-srch-a-lbl').textContent  = srchA;
    if ($('fk-srch-b-lbl'))     $('fk-srch-b-lbl').textContent  = srchB;
    if ($('fk-thr-borde-lbl'))  $('fk-thr-borde-lbl').textContent = thrBorde;
    if ($('fk-thr-atk-lbl'))    $('fk-thr-atk-lbl').textContent   = thrAtk;
    // Store config for frankyAutonomousStep to read
    S._sumoConfig = { atkA, atkB, srchA, srchB, thrBorde, thrAtk };
    // Send trim to FrankySimulator via /sumo/trim endpoint (for legacy compat)
    const trimMax = Math.max(atkA, atkB, 1);
    const legacyA = Math.round(255 * atkA / trimMax);
    const legacyB = Math.round(255 * atkB / trimMax);
    getFranky().handleRequest('POST', '/sumo/trim', {ma: legacyA, mb: legacyB});
    S._frankySpeedChanged = true; // counts as config action for objectives
  },

  fkSpeed(val) {
    S._frankySpeedChanged = true;
    getFranky().handleRequest('POST', '/spd', {val});
    const lbl=$('fk-spd-lbl'); if(lbl) lbl.textContent=val;
  },

  fkTrim() {
    const ma=$('fk-trim-a')?.value||255, mb=$('fk-trim-b')?.value||255;
    getFranky().handleRequest('POST', '/sumo/trim', {ma,mb});
    const la=$('fk-trim-a-lbl'), lb=$('fk-trim-b-lbl');
    if(la) la.textContent=ma; if(lb) lb.textContent=mb;
  },

  fkAddOp(op, val) {
    getFranky().handleRequest('POST', '/bloques/add', {op,val});
    A._updateFrankyUI();
  },

  _updateFrankyUI() {
    const sim = getFranky();
    const s = sim.getState();
    const MODE_NAMES={0:'IDLE',1:'MICRO',2:'MINI',3:'BLOQUES',4:'VIVERO',5:'METEO',6:'ALARMA',7:'ACCESO'};
    const modeName = MODE_NAMES[s.mode]||'IDLE';

    // Status badge in header
    const badge=$('fk-mode-badge');
    if(badge){badge.textContent=modeName;badge.className='fk-badge '+(s.running?'mode-run':'mode-idle');}

    // Status page
    const set=(id,val)=>{const el=$(id);if(el)el.textContent=val;};
    set('fk-a0',s.a0);set('fk-a1',s.a1);
    set('fk-temp',s.temp.toFixed(1)+'°C');set('fk-hum',s.hum.toFixed(0)+'%');
    set('fk-pwma',s.pwmA);set('fk-pwmb',s.pwmB);

    const mStat=$('fk-mode-status');
    if(mStat){mStat.textContent='MODO: '+modeName;mStat.className='wp-badge '+(s.running?'mode-run':'mode-idle');}

    // Gamepad motor readout
    set('fk-ma-val',s.chA1>0?'+'+s.pwmA:s.chA2>0?'-'+s.pwmA:'0');
    set('fk-mb-val',s.chB1>0?'+'+s.pwmB:s.chB2>0?'-'+s.pwmB:'0');

    // API log
    const log=$('fk-log');
    if(log){
      const hist=sim.getHistory().slice(-5).reverse();
      log.innerHTML=hist.map(h=>
        '<div style="color:'+(h.status===200?'var(--t1)':'var(--re)')+'">'+
        h.method+' '+h.path+'→'+h.status+'</div>'
      ).join('');
    }

    // Bloques program list
    const pl=$('fk-prog-list');
    if(pl){
      const ops={1:'Avanzar',2:'Retroceder',3:'Girar Izq',4:'Girar Der',5:'Stop',
                 6:'Esperar',7:'LED ON',8:'LED OFF',30:'Leer Sensor',
                 70:'Si >',71:'Si <',74:'Repetir',0:'Fin'};
      const prog = s.program.filter(function(i){return i.op!==0;}); // hide FIN
      pl.innerHTML=prog.length===0?'':
        prog.map(function(inst,i){return '<div style="font-size:.46rem;color:var(--t1)">'+
          (i+1)+'. <span style="color:var(--cy)">'+(ops[inst.op]||'OP'+inst.op)+'</span>'+
          (inst.val>0?' ('+inst.val+'ms)':'')+
          '</div>';}).join('');
    }

    // Update sumo phase display from current state
    const _phaseLbl = $('sumo-phase-lbl');
    if (_phaseLbl && (s.mode===1||s.mode===2)) {
      if (!s.running) { _phaseLbl.textContent='IDLE'; _phaseLbl.style.color='var(--t2)'; }
      // else: phase updated by frankyAutonomousStep during run
    }
    // Sync sensor state to physics sim if running
    if(S.view==='lab'&&franky&&eco.physics?.robot){
      const r=eco.physics.robot, obs=eco.physics.obstacles||[];
      // Inject ADC0: distance-based (same as irSample but for FRANKY ADC12-bit)
      const dist_px=irRaycast(r,obs,0,0,0);
      const adc12=(dist_px>400||!isFinite(dist_px))?0:Math.round((1-dist_px/400)*4095);
      franky.injectSensors({a0:adc12,a1:Math.round(adc12*0.6),temp:22.5,hum:55.0});
    }
  },

  _completeClose(nextId) {
    $('m-complete').classList.add('hid');
    if (nextId) A.chChange(nextId); else A.nav('home');
  },
  _obStep: 0,
  _obNext() {
    const steps = document.querySelectorAll('.ob-step');
    const dots  = document.querySelectorAll('.ob-dot');
    if (this._obStep < steps.length-1) {
      steps[this._obStep].style.display = 'none';
      this._obStep++;
      steps[this._obStep].style.display = '';
      dots.forEach(function(d,i){ d.classList.toggle('on', i===A._obStep); });
      $('ob-back').style.display = '';
      if (this._obStep === steps.length-1) {
        $('ob-next').textContent = '¡Comenzar! →';
        $('ob-next').onclick = function(){ A._obFinish(); };
      }
    }
  },
  _obBack() {
    const steps = document.querySelectorAll('.ob-step');
    const dots  = document.querySelectorAll('.ob-dot');
    if (this._obStep > 0) {
      steps[this._obStep].style.display = 'none';
      this._obStep--;
      steps[this._obStep].style.display = '';
      dots.forEach(function(d,i){ d.classList.toggle('on', i===A._obStep); });
      if (this._obStep === 0) $('ob-back').style.display = 'none';
      $('ob-next').textContent = 'Siguiente →';
      $('ob-next').onclick = function(){ A._obNext(); };
    }
  },
  _obFinish() {
    $('m-onboard').classList.add('hid');
    lsSet('onboard-done','1');
  },

  profilerReport() {
    ser('[SYS] FPS:'+FPS.ema+' state:'+FPS.state,'i');
    return {fps:FPS.ema,state:FPS.state};
  },
};

// ── Wire controls ──────────────────────────────────────────────
$('btn-play').onclick  = ()=>A.play();
$('btn-pause').onclick = ()=>A.pause();
$('btn-step').onclick  = ()=>A.step();
$('btn-reset').onclick = ()=>A.reset();
$('btn-hint').onclick  = ()=>A.hint();
$('btn-load').onclick  = ()=>A.loadSketch();
$('logo-btn').onclick  = ()=>A.nav(S.view==='lab'?'home':'lab');
$('spdi').oninput      = e=>A.setSpd(e.target.value);
$('imp-f').onchange    = e=>A._doImport(e.target);
document.querySelectorAll('.npill').forEach(p=>p.onclick=()=>A.nav(p.dataset.v));
document.querySelectorAll('.ptab').forEach(t=>t.onclick=()=>A.tab(t.dataset.p));
// ── Peripheral canvas interaction ────────────────────────────────
cvs.addEventListener('mousedown', function(e) {
  if (!S._periph) return;
  const rect = cvs.getBoundingClientRect();
  const scaleX = cvs.width / rect.width;
  const scaleY = cvs.height / rect.height;
  const cx = (e.clientX - rect.left) * scaleX;
  const cy = (e.clientY - rect.top)  * scaleY;
  const _p = S._periph;
  // Button press (hold while mouse is down)
  if (_p.showBtn && _p._btnZone) {
    const bz = _p._btnZone;
    const dist = Math.sqrt((cx-bz.x)**2+(cy-bz.y)**2);
    if (dist <= bz.r+4) { _p.btnPressed = true; return; }
  }
  // DIP switches — click to toggle
  [0,1].forEach(function(i) {
    const z = _p['_dip'+i+'Zone'];
    if (!z) return;
    const dist = Math.sqrt((cx-z.x)**2+(cy-z.y)**2);
    if (dist <= z.r) {
      if (i===0) _p.dip11on = !_p.dip11on;
      else       _p.dip2on  = !_p.dip2on;
      // Inject into HAL immediately so sketch sees the change next fwStep
      try {
        if (i===0) eco.hal.setSensorValue('D11', _p.dip11on ? 0 : 1);  // pull-up: ON=LOW=0
        else       eco.hal.setSensorValue('D2',  _p.dip2on  ? 0 : 1);
      } catch(e2) {}
    }
  });
});
cvs.addEventListener('mouseup', function() {
  if (S._periph?.showBtn) S._periph.btnPressed = false;
});

window.addEventListener('resize',()=>{ if(S.view==='lab') resize(); const bf=$('bly-fullscreen'); if(window.FrankyBlockly && bf && (bf.classList.contains('panel-mode')||bf.style.display!=='none')) window.FrankyBlockly.resize(); });

// ══════════════════════════════════════════════════════════════
// BOOT — ordered, safe
// ══════════════════════════════════════════════════════════════
ld(90, 'Finalizando…');

setTimeout(async () => {
  // 1. Build challenge selector (requires full challenge DB)
  buildChallengeSelector();
  // Restore persisted teacher/session data
  S._teacherNotes = lsGet('teacher:notes') || '';
  try { const _sl=lsGet('session:log'); if(_sl) S._sessionLog=JSON.parse(_sl)||[]; } catch(e) {}

  // 2. Render units (may need localStorage data)
  renderUnits();

  // 3. Set default challenge
  const firstCh = 'u1-explorar-motores';
  S.cid = getChallenge(firstCh) ? firstCh : (CH_DB.keys().next().value || null);
  if (S.cid) {
    $('ch-nm').textContent = getChallenge(S.cid)?.name || S.cid;
    $('ch-ds').textContent = getChallenge(S.cid)?.description || '';
  }

  // 4. Auto-login most recent student, or show login modal
  const students = await eco.persistence.listStudents().catch(()=>[]);
  if (students.length) {
    const recent = students.sort((a,b)=>b.lastActiveAt-a.lastActiveAt)[0];
    await eco.persistence.setCurrentStudent(recent.id).catch(()=>{});
    doLogin(recent);
    A.nav('home');
  } else {
    A.nav('home');
    setTimeout(showLogin, 400);
  }

  A._MANUAL_SECTIONS = RL.MANUAL_SECTIONS || [];
  ld(100, 'Listo.');
  setTimeout(()=>{ $('loading').style.display='none'; }, 200);

}, 300);

})();

// Register service worker for PWA
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
}
</script>
</body>
</html>
