  
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>RoboLab</title>
<style>
/* ═══════════════════════════════════════════════════════════
   ROBOLAB — Stable Build
   Fixed: physics.robot (not .r), canvas sizing guards,
   curriculum integration, template literal syntax,
   lifecycle ordering, null guards everywhere.
═══════════════════════════════════════════════════════════ */
:root{
  --bg0:#05070c;--bg1:#090d16;--bg2:#0d1220;--bg3:#07090f;
  --ln:rgba(255,255,255,.07);--lnh:rgba(255,255,255,.13);
  --t0:#bdd4e8;--t1:#5e8499;--t2:#2e424f;
  --cy:#00cdb3;--am:#f09600;--re:#f02840;--gr:#18cc60;--pu:#8f68ec;--bl:#3878ec;
  --ff:system-ui,-apple-system,'Segoe UI',sans-serif;
  --fm:'JetBrains Mono','Fira Code',ui-monospace,monospace;
  --r:4px;--rlg:8px;
  --panel-w:clamp(340px,30vw,440px);
  --header-h:48px;--tabbar-h:36px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg0);color:var(--t0);font-family:var(--ff);font-size:13px;line-height:1.5;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--lnh);border-radius:2px;}

#app{height:100vh;display:grid;grid-template-rows:var(--header-h) 1fr;overflow:hidden;}

/* ── Header ─────────────────────────────────────────────── */
#hdr{background:var(--bg1);border-bottom:1px solid var(--ln);display:flex;align-items:center;padding:0 12px;gap:8px;overflow:hidden;flex-shrink:0;}
.logo{display:flex;align-items:center;gap:7px;font-size:.7rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;color:var(--cy);cursor:pointer;flex-shrink:0;user-select:none;}
.pip{width:7px;height:7px;border-radius:50%;background:var(--cy);box-shadow:0 0 8px var(--cy);animation:blink 2.4s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.18}}
.vd{width:1px;height:20px;background:var(--ln);flex-shrink:0;}
.badge{font-family:var(--fm);font-size:.57rem;padding:3px 8px;border-radius:var(--r);letter-spacing:.06em;text-transform:uppercase;white-space:nowrap;flex-shrink:0;}
.b-idle{color:var(--t2);border:1px solid var(--t2);}
.b-run{color:var(--cy);border:1px solid var(--cy);background:rgba(0,205,179,.08);}
.b-running{color:var(--cy);border:1px solid var(--cy);background:rgba(0,205,179,.08);}
.b-pause{color:var(--am);border:1px solid var(--am);background:rgba(240,150,0,.08);}
.b-error{color:var(--re);border:1px solid var(--re);background:rgba(240,40,64,.08);}
.b-step{color:var(--pu);border:1px solid var(--pu);}
.b-done{color:var(--gr);border:1px solid var(--gr);background:rgba(24,204,96,.08);}
.npills{display:none;gap:2px;flex-shrink:0;}
.npills.on{display:flex;}
.npill{font-family:var(--fm);font-size:.57rem;padding:4px 10px;border-radius:20px;cursor:pointer;color:var(--t2);transition:all .15s;}
.npill:hover{color:var(--t0);background:var(--ln);}
.npill.on{color:var(--cy);background:rgba(0,205,179,.12);}
#simbar{display:none;align-items:center;gap:5px;overflow:hidden;flex:1;min-width:0;}
#simbar.on{display:flex;}
.btn{font-family:var(--fm);font-size:.6rem;padding:5px 10px;border-radius:var(--r);border:1px solid var(--ln);background:var(--bg2);color:var(--t1);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0;}
.btn:hover{border-color:var(--lnh);color:var(--t0);}
.btn:active{transform:scale(.97);}
.btn-run{color:var(--cy);border-color:var(--cy);background:rgba(0,205,179,.07);}
.btn-run:hover{background:rgba(0,205,179,.16);}
.btn-warn{color:var(--am);border-color:var(--am);}
.btn-ic{padding:5px 8px;}
.btn-sm{font-size:.56rem;padding:3px 7px;}
.btn-pu{color:var(--pu);border-color:var(--pu);}
.spd-w{display:flex;align-items:center;gap:5px;font-family:var(--fm);font-size:.57rem;color:var(--t2);flex-shrink:0;}
.spd-w input{width:52px;accent-color:var(--cy);}
#chsel{font-family:var(--fm);font-size:.6rem;background:var(--bg2);color:var(--t1);border:1px solid var(--ln);border-radius:var(--r);padding:4px 7px;cursor:pointer;outline:none;flex:1;min-width:0;max-width:220px;}
#spill{display:none;align-items:center;gap:7px;margin-left:auto;cursor:pointer;flex-shrink:0;}
#spill.on{display:flex;}
.s-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;}
.s-nm{font-size:.7rem;color:var(--t1);max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

/* ── Views ─────────────────────────────────────────────── */
.view{display:none;overflow:hidden;min-height:0;}
.view.on{display:flex;}

/* ── Home ──────────────────────────────────────────────── */
#v-home{flex-direction:column;overflow-y:auto;align-items:center;padding:28px 20px 48px;gap:20px;background:var(--bg0);}
.h-hero{text-align:center;}
.h-hero h1{font-size:1.9rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--cy);}
.h-hero p{color:var(--t1);margin-top:6px;}
.stu-bar{width:100%;max-width:820px;background:var(--bg1);border:1px solid var(--ln);border-radius:var(--rlg);padding:13px 18px;display:flex;align-items:center;gap:14px;flex-shrink:0;}
.stu-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.95rem;font-weight:700;flex-shrink:0;}
.stu-info{flex:1;min-width:0;}
.stu-nm{font-weight:700;font-size:.9rem;}
.stu-sb{font-size:.7rem;color:var(--t1);margin-top:2px;}
.pbar{height:3px;background:var(--ln);border-radius:2px;margin-top:5px;overflow:hidden;}
.pbar-f{height:100%;border-radius:2px;transition:width .4s;}
.ugrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;width:100%;max-width:820px;}
.ucard{background:var(--bg1);border:1px solid var(--ln);border-radius:var(--rlg);padding:14px 16px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
.ucard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--uc,var(--cy));}
.ucard:hover:not(.locked){border-color:var(--lnh);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.ucard.locked{opacity:.35;cursor:default;}
.ucard.cur{border-color:var(--cy);background:rgba(0,205,179,.04);}
.u-num{font-family:var(--fm);font-size:.52rem;color:var(--t2);letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px;}
.u-title{font-size:.85rem;font-weight:700;margin-bottom:4px;line-height:1.3;}
.u-desc{font-size:.7rem;color:var(--t1);line-height:1.5;}
.u-tags{display:flex;gap:5px;flex-wrap:wrap;margin-top:10px;}
.u-tag{font-family:var(--fm);font-size:.52rem;padding:2px 7px;border-radius:10px;background:var(--ln);color:var(--t1);}
.u-tag.go{background:rgba(24,204,96,.12);color:var(--gr);}
.u-tag.done{background:rgba(24,204,96,.2);color:var(--gr);}

/* ── Lab ───────────────────────────────────────────────── */
#v-lab.on{display:grid;grid-template-columns:1fr var(--panel-w);min-height:0;}
.cv-w{position:relative;overflow:hidden;background:var(--bg0);min-width:0;min-height:0;display:flex;flex-direction:column;}
/* OLED HUD — fixed telemetry overlay on arena */
#oled-hud{display:none;position:absolute;top:12px;left:12px;width:256px;min-height:88px;background:#050a08;border:1.5px solid rgba(0,205,180,.5);border-radius:6px;padding:8px 10px;box-shadow:0 0 20px rgba(0,205,180,.15),0 0 5px rgba(0,205,180,.08) inset;z-index:20;pointer-events:none;font-family:'JetBrains Mono','Courier New',monospace;}
#oled-hud.vis{display:block;}
#oled-hud-title{font-size:.45rem;color:rgba(0,205,180,.45);letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px;padding-bottom:3px;border-bottom:1px solid rgba(0,205,180,.12);}
#oled-hud-lines{display:flex;flex-direction:column;gap:1px;}
#oled-hud-lines div{font-size:.62rem;color:#00cdb3;text-shadow:0 0 7px rgba(0,205,180,.55);letter-spacing:.03em;white-space:pre;min-height:1em;}
#oled-hud-lines div.dim{color:rgba(0,205,180,.35);}
#oled-hud.debug #oled-hud-title::after{content:' · DEBUG';color:#f09600;}
#cvs{flex:1;display:block;cursor:crosshair;}
.ov{position:absolute;pointer-events:none;}
.ov-lbl{top:10px;left:12px;font-family:var(--fm);font-size:.52rem;color:var(--t2);letter-spacing:.1em;text-transform:uppercase;}
#shud{bottom:12px;left:12px;background:rgba(5,7,12,.93);border:1px solid var(--lnh);border-radius:var(--r);padding:8px 12px;display:flex;gap:13px;opacity:0;transition:opacity .4s;}
#shud.vis{opacity:1;pointer-events:auto;}
.hi{display:flex;flex-direction:column;gap:3px;}
.hl{font-family:var(--fm);font-size:.5rem;color:var(--t2);text-transform:uppercase;letter-spacing:.07em;}
.hv{font-family:var(--fm);font-size:.86rem;font-weight:700;}
.hb{width:54px;height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
.hbf{height:100%;border-radius:2px;transition:width .08s;}
#vstrip{top:9px;right:10px;display:flex;flex-direction:column;gap:3px;max-width:280px;}
.vi{padding:3px 7px;border-radius:var(--r);font-family:var(--fm);font-size:.57rem;line-height:1.4;}
.vi-e{background:rgba(240,40,64,.09);border-left:2px solid var(--re);color:var(--re);}
.vi-w{background:rgba(240,150,0,.07);border-left:2px solid var(--am);color:var(--am);}
#tms{top:10px;left:50%;transform:translateX(-50%);background:rgba(24,204,96,.09);border:1px solid var(--gr);border-radius:var(--r);padding:5px 14px;font-family:var(--fm);font-size:.67rem;color:var(--gr);white-space:nowrap;opacity:0;transition:opacity .25s;}
#tms.on{opacity:1;}
#terr{bottom:14px;left:50%;transform:translateX(-50%);background:rgba(240,40,64,.09);border:1px solid var(--re);border-radius:var(--r);padding:7px 14px;font-family:var(--fm);font-size:.62rem;color:var(--re);max-width:360px;text-align:center;opacity:0;transition:opacity .25s;}
#terr.on{opacity:1;}

/* ── Right Panel ─────────────────────────────────────────── */
#rp{background:var(--bg1);border-left:1px solid var(--ln);display:flex;flex-direction:column;overflow:hidden;min-height:0;}
/* Blockly panel mode: Blockly replaces #rp so canvas+FRANKY stay visible */
#rp.bly-mode{display:none;}
#bly-fullscreen.panel-mode{
  position:static!important;      /* out of fixed positioning */
  width:var(--panel-w);flex-shrink:0;right:auto;left:auto;top:auto;bottom:auto;
  display:flex!important;border-left:1px solid var(--ln);border-right:none;z-index:auto;
}
#ptabs{display:flex;border-bottom:1px solid var(--ln);flex-shrink:0;height:var(--tabbar-h);}
.ptab{flex:1;display:flex;align-items:center;justify-content:center;gap:4px;font-family:var(--fm);font-size:.57rem;letter-spacing:.05em;text-transform:uppercase;color:var(--t2);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;}
.ptab:hover{color:var(--t1);background:rgba(255,255,255,.02);}
.ptab.on{color:var(--cy);border-bottom-color:var(--cy);}
.th-dot{width:8px;height:8px;border-radius:50%;background:var(--pu);display:none;animation:pulse-dot 1.5s ease-in-out infinite}
.th-dot.on{display:block;}
/* Blockly fullscreen responsive */
@media (max-width: 1100px) {
  #bly-fullscreen { right: var(--panel-w) !important; }
  #v-lab.on.franky-open { grid-template-columns: 1fr var(--panel-w) !important; }
}
@media (max-width: 860px) {
  #v-lab.on, #v-lab.on.franky-open {
    grid-template-columns: 1fr;
    grid-template-rows: 1fr 260px;
  }
  #franky-panel.on { display: none !important; }
}
@keyframes pulse-dot{0%,100%{box-shadow:0 0 3px var(--pu);transform:scale(1)}50%{box-shadow:0 0 10px var(--pu);transform:scale(1.35)}}
.pp{display:none;flex-direction:column;flex:1;min-height:0;overflow:hidden;}
.pp.on{display:flex;}

/* ── Challenge tab ─────────────────────────────────────── */
#pp-ch{overflow-y:auto;padding:13px 13px 20px;gap:9px;}
.ch-nm{font-size:.93rem;font-weight:700;line-height:1.3;}
.ch-ds{font-size:.71rem;color:var(--t1);line-height:1.55;}
.ch-prog{background:var(--bg2);border-radius:var(--r);padding:7px 10px;display:flex;align-items:center;gap:10px;}
.ch-pl{font-family:var(--fm);font-size:.58rem;color:var(--t2);white-space:nowrap;}
.ch-pb{flex:1;height:4px;background:var(--ln);border-radius:2px;overflow:hidden;}
.ch-pf{height:100%;border-radius:2px;background:var(--cy);transition:width .35s;}
.ch-pn{font-family:var(--fm);font-size:.58rem;color:var(--t1);white-space:nowrap;}
.sep{height:1px;background:var(--ln);flex-shrink:0;}
.ol{display:flex;flex-direction:column;gap:3px;}
.obj{display:flex;align-items:flex-start;gap:8px;padding:7px 9px;background:var(--bg2);border-radius:var(--r);}
.obj.done{background:rgba(24,204,96,.05);}
.ock{width:14px;height:14px;border-radius:3px;flex-shrink:0;margin-top:1px;border:1.5px solid var(--t2);display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .25s;}
.ock.done{background:var(--gr);border-color:var(--gr);color:#000;}
.ob-l{font-size:.7rem;color:var(--t1);line-height:1.4;}
.obj.done .ob-l{color:var(--gr);}
.hint-box{padding:10px 11px;background:rgba(143,104,236,.07);border:1px solid rgba(143,104,236,.22);border-radius:var(--r);font-size:.71rem;color:var(--pu);line-height:1.55;display:none;}
.hint-box.on{display:block;}

/* ── Hardware tab ──────────────────────────────────────── */
#pp-hw{overflow-y:auto;}
.motors{display:flex;gap:8px;padding:10px 12px;flex-shrink:0;}
.mc{flex:1;background:var(--bg2);border:1px solid var(--ln);border-radius:var(--r);padding:8px 10px;}
.mc-t{font-family:var(--fm);font-size:.52rem;color:var(--t2);margin-bottom:4px;}
.mc-d{font-size:.8rem;font-weight:700;margin-bottom:3px;}
.dc-f{color:var(--gr)}.dc-r{color:var(--am)}.dc-b{color:var(--re)}.dc-o{color:var(--t2)}
.mc-bar{height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
.mc-fl{height:100%;background:var(--cy);border-radius:2px;transition:width .12s;}
.mc-pw{font-family:var(--fm);font-size:.57rem;color:var(--t1);margin-top:3px;}
.sparks{padding:8px 12px;flex-shrink:0;}
.sp-r{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.sp-r:last-child{margin-bottom:0;}
.sp-l{font-family:var(--fm);font-size:.57rem;color:var(--t1);min-width:52px;}
.sp-c{flex:1;height:24px;display:block;}
.sp-v{font-family:var(--fm);font-size:.6rem;color:var(--t0);min-width:34px;text-align:right;}
.gpio{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;padding:8px 12px;}
.gp{background:var(--bg2);border-radius:var(--r);padding:5px 8px;}
.gp-id{font-family:var(--fm);font-size:.52rem;color:var(--t2);}
.gp-lb{font-size:.58rem;color:var(--t1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.gp-v{font-family:var(--fm);font-size:.67rem;font-weight:600;}
.gv-off{color:var(--t2)}.gv-hi{color:var(--cy)}.gv-pw{color:var(--am)}.gv-in{color:var(--pu)}.gv-ai{color:var(--gr)}

/* ── Code tab ──────────────────────────────────────────── */
#pp-co{display:flex;flex-direction:column;overflow:hidden;flex:1;position:relative;}
#vbar{height:30px;flex-shrink:0;display:flex;align-items:center;padding:0 10px;gap:8px;border-bottom:1px solid var(--ln);font-family:var(--fm);font-size:.58rem;overflow:hidden;}
.vb-ok{color:var(--gr)}.vb-err{color:var(--re)}.vb-wrn{color:var(--am)}
.ed-outer{flex:1;min-height:0;display:flex;border-bottom:1px solid var(--ln);}
.lnums{width:32px;flex-shrink:0;background:var(--bg3);border-right:1px solid var(--ln);padding:8px 6px 8px 0;overflow:hidden;font-family:var(--fm);font-size:.65rem;line-height:1.75;color:var(--t2);text-align:right;user-select:none;}
#ced{flex:1;min-height:0;background:var(--bg3);color:var(--t0);border:none;outline:none;font-family:var(--fm);font-size:.68rem;line-height:1.75;padding:8px 10px;resize:none;tab-size:2;caret-color:var(--cy);}
.ed-bar{height:36px;flex-shrink:0;display:flex;align-items:center;gap:8px;padding:0 8px;background:var(--bg1);border-top:1px solid var(--ln);}
#clbl{flex:1;font-family:var(--fm);font-size:.58rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.cl-ok{color:var(--gr)}.cl-err{color:var(--re)}
.ser-w{height:120px;flex-shrink:0;display:flex;flex-direction:column;border-top:1px solid var(--ln);}
.ser-hd{height:28px;flex-shrink:0;display:flex;align-items:center;gap:7px;padding:0 10px;font-family:var(--fm);font-size:.54rem;color:var(--t2);text-transform:uppercase;letter-spacing:.08em;}
.s-dot{width:5px;height:5px;border-radius:50%;background:var(--t2);transition:background .2s;flex-shrink:0;}
#sout{flex:1;overflow-y:auto;font-family:var(--fm);font-size:.6rem;line-height:1.65;padding:4px 10px;background:var(--bg3);}
.sl-s{color:var(--t2)}.sl-f{color:var(--cy)}.sl-e{color:var(--re)}.sl-i{color:var(--pu)}

/* ── Theory tab ─────────────────────────────────────────── */
#pp-th{overflow-y:auto;padding:16px 13px 24px;gap:11px;}
.th-em{font-size:.75rem;color:var(--t2);font-style:italic;text-align:center;margin-top:40px;padding:0 16px;line-height:1.75;}
.th-tt{font-size:.9rem;font-weight:700;color:var(--cy);line-height:1.3;}
.th-bo{font-size:.75rem;color:var(--t0);line-height:1.8;white-space:pre-wrap;word-break:break-word;}
.th-nv{display:flex;gap:8px;align-items:center;}
.th-cn{font-family:var(--fm);font-size:.57rem;color:var(--t2);}

/* ── Modal ─────────────────────────────────────────────── */
.mbg{position:fixed;inset:0;z-index:100;background:rgba(5,7,12,.94);display:flex;align-items:center;justify-content:center;}
.mbg.hid{display:none;}
.modal{background:var(--bg1);border:1px solid var(--lnh);border-radius:var(--rlg);padding:24px;width:360px;display:flex;flex-direction:column;gap:13px;}
.modal-lg{background:var(--bg1);border:1px solid var(--lnh);border-radius:var(--rlg);padding:20px;display:flex;flex-direction:column;overflow:hidden;}
.modal h2{font-size:1rem;font-weight:700;color:var(--cy);}
.modal p{font-size:.73rem;color:var(--t1);line-height:1.6;}
.flbl{font-family:var(--fm);font-size:.6rem;color:var(--t1);margin-bottom:3px;}
.finp{width:100%;background:var(--bg3);color:var(--t0);border:1px solid var(--ln);border-radius:var(--r);font-size:.82rem;padding:7px 10px;outline:none;transition:border-color .18s;}
.finp:focus{border-color:var(--cy);}
.fgrp{display:flex;flex-direction:column;}
.or-sep{display:flex;align-items:center;gap:8px;font-family:var(--fm);font-size:.58rem;color:var(--t2);}
.or-sep::before,.or-sep::after{content:'';flex:1;height:1px;background:var(--ln);}
.slist{max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;}
.sopt{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:var(--r);background:var(--bg2);cursor:pointer;transition:background .12s;border:1px solid transparent;}
.sopt:hover{background:var(--ln);}
.so-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0;}
.so-nm{font-weight:700;font-size:.8rem;}.so-sb{font-size:.62rem;color:var(--t2);}

/* ── Loading ─────────────────────────────────────────────── */
#loading{position:fixed;inset:0;z-index:200;background:var(--bg0);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
.ld-logo{font-size:1.4rem;font-weight:800;letter-spacing:.15em;color:var(--cy);}
.ld-bar{width:200px;height:2px;background:var(--ln);border-radius:2px;overflow:hidden;}
.ld-f{width:0;height:100%;background:var(--cy);transition:width .25s;border-radius:2px;}
.ld-msg{font-family:var(--fm);font-size:.6rem;color:var(--t2);}

.ob-dot{width:7px;height:7px;border-radius:50%;background:var(--ln);transition:all .2s;cursor:pointer}
.ob-dot.on{background:var(--cy);transform:scale(1.3)}
.hint-level{font-family:var(--fm);font-size:.5rem;letter-spacing:.08em;text-transform:uppercase;color:var(--t2);margin-bottom:5px}
.hint-code{font-family:var(--fm);font-size:.58rem;background:var(--bg3);border-radius:var(--r);padding:6px 8px;margin-top:6px;color:var(--cy);white-space:pre;overflow-x:auto;border-left:2px solid var(--cy)}
.hint-box.l1{border-color:rgba(143,104,236,.3)}
.hint-box.l2{border-color:rgba(240,150,0,.4)}
.hint-box.l3{border-color:rgba(240,40,64,.4)}
/* ── FRANKY WebServer Simulation ──────────────────────────── */
/* Phone frame that simulates the ESP32 web interface */
/* FRANKY panel: docked to lab grid, not a fixed overlay */
#franky-panel {
  display:none;background:var(--bg1);
  border-left:1px solid var(--ln);
  flex-direction:column;overflow:hidden;
  /* Removed: position:fixed, z-index:50 — now part of grid flow */
}
#franky-panel.on{display:flex;}
/* When FRANKY panel is open in lab: add third column to grid */
#v-lab.on.franky-open {
  grid-template-columns: 1fr clamp(260px,22vw,320px) var(--panel-w) !important;
}

.fk-header{
  height:var(--header-h);flex-shrink:0;
  background:var(--bg2);border-bottom:1px solid var(--ln);
  display:flex;align-items:center;gap:8px;padding:0 12px;
}
.fk-title{font-family:var(--fm);font-size:.65rem;font-weight:700;color:var(--cy);flex:1;}
.fk-badge{
  font-family:var(--fm);font-size:.5rem;padding:2px 7px;
  border-radius:10px;background:rgba(24,204,96,.15);color:var(--gr);
}

/* Phone viewport */
.phone-wrap{
  flex:1;display:flex;align-items:center;justify-content:center;
  padding:12px 8px;background:var(--bg0);overflow:hidden;
}
.phone-frame{
  width:220px;height:420px;
  border-radius:24px;border:2px solid var(--lnh);
  background:#0a0c12;overflow:hidden;
  display:flex;flex-direction:column;
  box-shadow:0 0 32px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.05);
  position:relative;
}
.phone-notch{
  width:60px;height:6px;border-radius:3px;background:var(--ln);
  margin:8px auto 0;flex-shrink:0;
}
.phone-screen{flex:1;overflow-y:auto;overflow-x:hidden;}

/* Simulated web pages */
.wp-nav{
  display:flex;gap:2px;padding:4px;background:var(--bg2);flex-shrink:0;
  border-bottom:1px solid var(--ln);flex-wrap:wrap;
}
.wp-nav-btn{
  font-family:var(--fm);font-size:.48rem;padding:3px 5px;
  border-radius:3px;background:var(--ln);color:var(--t2);cursor:pointer;
  border:none;transition:all .15s;
}
.wp-nav-btn:hover,.wp-nav-btn.on{background:rgba(0,205,179,.2);color:var(--cy);}

.wp-page{display:none;padding:8px;flex-direction:column;gap:6px;}
.wp-page.on{display:flex;}
.wp-section{
  background:rgba(255,255,255,.03);border:1px solid var(--ln);
  border-radius:6px;padding:7px 8px;
}
.wp-label{font-family:var(--fm);font-size:.48rem;color:var(--t2);margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;}
.wp-value{font-family:var(--fm);font-size:.75rem;font-weight:700;}
.wp-row{display:flex;gap:6px;align-items:center;}
.wp-btn{
  font-family:var(--fm);font-size:.52rem;padding:5px 8px;
  border-radius:4px;border:1px solid var(--ln);background:var(--bg3);
  color:var(--t1);cursor:pointer;transition:all .15s;flex:1;text-align:center;
}
.wp-btn:hover{background:var(--ln);color:var(--t0);}
.wp-btn.primary{background:rgba(0,205,179,.15);border-color:var(--cy);color:var(--cy);}
.wp-btn.danger{background:rgba(240,40,64,.1);border-color:var(--re);color:var(--re);}
.wp-btn.warn{background:rgba(240,150,0,.1);border-color:var(--am);color:var(--am);}
.wp-dpad{
  display:grid;grid-template-columns:repeat(3,1fr);gap:3px;
  max-width:120px;margin:0 auto;
}
.wp-dpad-btn{
  aspect-ratio:1;border-radius:4px;border:1px solid var(--ln);
  background:var(--bg3);color:var(--t1);cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:.9rem;
  transition:all .12s;user-select:none;
}
.wp-dpad-btn:hover{background:rgba(0,205,179,.15);border-color:var(--cy);}
.wp-dpad-btn:active,.wp-dpad-btn.pressed{background:rgba(0,205,179,.3);}
.wp-dpad-empty{background:transparent;border:none;}
.wp-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.wp-stat{
  background:rgba(255,255,255,.03);border:1px solid var(--ln);
  border-radius:4px;padding:5px 6px;
}
.wp-stat-lbl{font-family:var(--fm);font-size:.44rem;color:var(--t2);}
.wp-stat-val{font-family:var(--fm);font-size:.72rem;font-weight:700;}
.wp-badge{
  font-family:var(--fm);font-size:.48rem;padding:2px 6px;
  border-radius:10px;display:inline-block;margin-top:3px;
}
.mode-idle{background:rgba(46,66,79,.5);color:var(--t2);}
.mode-run {background:rgba(24,204,96,.15);color:var(--gr);}
.wp-log{
  font-family:var(--fm);font-size:.48rem;color:var(--t2);
  max-height:60px;overflow-y:auto;line-height:1.6;
}

/* FRANKY toggle button in lab header */
#btn-franky{display:none;}
#btn-franky.on{display:inline-flex;}

/* ── Curriculum Hub (Home) additions ──────────────────────── */
.curr-section-label {
  font-family:var(--fm); font-size:.55rem; letter-spacing:.14em;
  text-transform:uppercase; color:var(--t2);
  width:100%; max-width:820px; padding-bottom:6px;
  border-bottom:1px solid var(--ln);
}

/* Unit card — prereq/unlock state */
.ucard.prereq { opacity:.5; cursor:not-allowed; }
.ucard.prereq::after {
  content:'Completá la unidad anterior';
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  font-family:var(--fm); font-size:.62rem; color:var(--t1);
  background:rgba(5,7,12,.7); border-radius:var(--rlg);
  opacity:0; transition:opacity .2s;
}
.ucard.prereq:hover::after { opacity:1; }

/* Unit progress ring inside card */
.u-prog-row {
  display:flex; align-items:center; gap:8px; margin-top:10px;
}
.u-prog-bar { flex:1; height:3px; background:var(--ln); border-radius:2px; overflow:hidden; }
.u-prog-fill { height:100%; border-radius:2px; transition:width .4s; }

/* Currently active unit highlight */
.ucard.active-unit { border-color:var(--cy); background:rgba(0,205,179,.04); }

/* Section divider */
.curr-sep { width:100%; max-width:820px; height:1px; background:var(--ln); }

/* ── Responsive ──────────────────────────────────────────── */
@media(max-width:960px){:root{--panel-w:340px;}#simbar{gap:3px;}.spd-w span:first-child{display:none;}#chsel{max-width:140px;}}
@media(max-width:860px){#rp{border-left:none;border-top:1px solid var(--ln);}}
</style>
  <!-- FRANKY Blockly — loaded from firmware's SPIFFS files (real Blockly, not a mock) -->
  <!-- These files are loaded lazily only when a FRANKY Bloques challenge is active -->
  <!-- PWA -->
  <link rel="manifest" href="manifest.json">
  <link rel="icon" href="favicon.ico" type="image/png">
  <meta name="theme-color" content="#00cdb3">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
</head>
<body>
<div id="loading"><div class="ld-logo">ROBOLAB</div><div class="ld-bar"><div class="ld-f" id="ldf"></div></div><div class="ld-msg" id="ldm">Iniciando…</div></div>

<input type="file" id="imp-f" accept=".json" style="display:none">

<div class="mbg hid" id="mlogin">
  <div class="modal">
    <h2>Bienvenido a RoboLab</h2>
    <p>Seleccioná un perfil o creá uno nuevo para guardar tu progreso.</p>
    <div id="ex-w" class="hid">
      <div class="flbl" style="margin-bottom:5px">Perfiles guardados</div>
      <div class="slist" id="sl"></div>
    </div>
    <div class="or-sep">o nuevo perfil</div>
    <div class="fgrp"><div class="flbl">Tu nombre</div><input class="finp" id="in-nm" type="text" placeholder="Nombre completo" autocomplete="off"></div>
    <div class="fgrp"><div class="flbl">Alias (opcional)</div><input class="finp" id="in-al" type="text" placeholder="nickname" autocomplete="off"></div>
    <button class="btn btn-run" id="btn-crt" style="width:100%;padding:9px;font-size:.65rem">Crear perfil y comenzar →</button>
  </div>
</div>

<div id="app">
  <header id="hdr">
    <div class="logo" id="logo-btn"><div class="pip"></div>ROBOLAB</div>
    <div class="vd"></div>
    <span class="badge b-idle" id="badge">IDLE</span>
    <div class="npills" id="npills"><div class="npill" data-v="home">Inicio</div><div class="npill on" data-v="lab">Laboratorio</div></div>
    <div id="simbar">
      <div class="vd"></div>
      <button class="btn btn-run"  id="btn-play">▶ Ejecutar</button>
      <button class="btn btn-ic"   id="btn-pause" title="Pausar">⏸</button>
      <button class="btn btn-ic"   id="btn-step"  title="Un paso">⏭</button>
      <button class="btn btn-warn btn-ic" id="btn-reset" title="Reset">↺</button>
      <div class="vd"></div>
      <div class="spd-w"><span>Vel</span><input type="range" id="spdi" min=".25" max="4" step=".25" value="1"><span id="spdl">1×</span></div>
      <div class="vd"></div>
      <select id="chsel"></select>
      <button class="btn btn-ic btn-pu" id="btn-hint" title="Pedir pista">💡</button>
      <button class="btn btn-ic" id="btn-teacher" onclick="A.openTeacher()" title="Vista docente" style="font-size:.8rem">👨&#xFE0F;&#x200D;🏫</button>
      <button class="btn btn-ic" id="btn-tutorial" onclick="A.openTutorial()" title="Cuaderno de laboratorio" style="font-size:.8rem">📖</button>
    </div>
    <div id="spill" onclick="A.showLogin()"><div class="s-av" id="sav"></div><span class="s-nm" id="snm"></span></div>
  </header>

  <!-- ══ HOME — Curriculum Hub ══════════════════════════════════ -->
  <div class="view" id="v-home">

    <!-- Hero -->
    <div class="h-hero">
      <h1>RoboLab</h1>
      <p>Laboratorio educativo de robótica · ROBOARD · FRANKY · PLC-CORE</p>
    </div>

    <!-- Student profile bar -->
    <div class="stu-bar">
      <div class="stu-av" id="stu-av">?</div>
      <div class="stu-info">
        <div class="stu-nm" id="stu-nm">Estudiante</div>
        <div class="stu-sb" id="stu-sb">—</div>
        <div class="pbar"><div class="pbar-f" id="pbar" style="width:0;background:var(--cy)"></div></div>
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0;align-items:center">
        <button class="btn" onclick="A.exportP()" title="Exportar perfil">⬇ Export</button>
        <button class="btn" onclick="A.importP()" title="Importar perfil">⬆ Import</button>
        <button class="btn btn-run" onclick="A.nav('lab')">Laboratorio →</button>
      </div>
    </div>

    <!-- Curriculum map label -->
    <div class="curr-section-label">MAPA CURRICULAR</div>

    <!-- Unit grid -->
    <div class="ugrid" id="ugrid"></div>

    <!-- Spacer for scroll -->
    <div style="height:16px;flex-shrink:0"></div>

  </div>

  <!-- ══ CHALLENGE COMPLETE panel ════════════════════════════════ -->
  <div class="mbg hid" id="m-tutorial" onclick="if(event.target===this)this.classList.add('hid')">
      <div class="modal-lg" style="max-width:780px;width:96vw;max-height:85vh;padding:18px 20px;box-sizing:border-box">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-shrink:0">
          <h2 style="margin:0;font-size:1rem;color:var(--cy)">📖 Cuaderno de Laboratorio</h2>
          <button class="btn btn-sm" onclick="$('m-tutorial').classList.add('hid')">✕ Cerrar</button>
        </div>
        <div id="tutorial-body" style="overflow-y:auto;flex:1;font-size:.62rem;line-height:1.7;color:var(--t1)"></div>
      </div>
    </div>
    <div class="mbg hid" id="m-teacher" onclick="if(event.target===this)this.classList.add('hid')">
      <div class="modal-lg" style="max-width:680px;width:95vw;max-height:88vh;overflow-y:auto">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
          <h2 style="margin:0;font-size:1rem;color:var(--cy)">Vista Docente</h2>
          <button class="btn btn-sm" onclick="$('m-teacher').classList.add('hid')">✕ Cerrar</button>
        </div>
      <div id="td-student" style="font-family:var(--fm);font-size:.58rem;color:var(--t2);margin-bottom:8px"></div>
      <div id="td-progress" style="margin-bottom:12px;max-height:180px;overflow-y:auto"></div>
      <div id="td-indicators" style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap"></div>
      <div id="td-narrative" style="background:var(--bg2);border-radius:var(--r);padding:8px 10px;font-size:.58rem;color:var(--t1);margin-bottom:10px;max-height:120px;overflow-y:auto;line-height:1.6"></div>
      <div style="font-family:var(--fm);font-size:.5rem;color:var(--t2);margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em">Notas del docente</div>
      <textarea id="td-notes" rows="3" style="width:100%;background:var(--bg2);border:1px solid var(--ln);border-radius:var(--r);color:var(--t1);font-size:.58rem;padding:6px;resize:vertical;box-sizing:border-box" placeholder="Observaciones, seguimiento, próximos pasos..." oninput="S._teacherNotes=this.value;lsSet('teacher:notes',this.value)"></textarea>
      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
        <button class="btn btn-sm" onclick="A.exportTeacherJSON()" style="background:var(--cy);color:#000">⬇ Exportar JSON</button>
        <button class="btn btn-sm" onclick="$('m-teacher').classList.add('hid')">Cerrar</button>
      </div>
      </div>
    </div>
    <div class="mbg hid" id="m-complete">
    <div class="modal" style="width:380px;text-align:center;gap:10px">
      <div style="font-size:2.5rem">🏆</div>
      <h2 id="m-comp-title">¡Desafío completado!</h2>
      <p id="m-comp-desc" style="font-size:.7rem;color:var(--t1);margin:0"></p>
      <div id="m-comp-stats" style="background:var(--bg2);border-radius:var(--r);padding:9px 12px;font-family:var(--fm);font-size:.58rem;color:var(--t1);display:flex;justify-content:space-around"></div>
      <div id="m-comp-next" style="display:flex;flex-direction:column;gap:6px;width:100%"></div>
      <button class="btn" onclick="$('m-complete').classList.add('hid')" style="align-self:center">Cerrar</button>
    </div>
  </div>

  <!-- ══ ONBOARDING WIZARD ══════════════════════════════════════════ -->
  <div class="mbg hid" id="m-onboard">
    <div class="modal" style="width:420px;max-width:95vw">
      <div id="ob-steps">
        <div class="ob-step" data-step="0">
          <div style="font-size:2rem;text-align:center;margin-bottom:8px">🤖</div>
          <h2 style="text-align:center">Bienvenido/a a RoboLab</h2>
          <p>Programás robots reales desde el navegador. Sin instalar nada.<br>
          La simulación refleja exactamente el comportamiento del hardware físico.</p>
          <div style="background:var(--bg2);border-radius:var(--r);padding:10px 12px;font-family:var(--fm);font-size:.62rem;color:var(--t1);line-height:1.7">
            🟦 <strong style="color:var(--cy)">ROBOARD</strong> — Arduino. Código C++. Sensores, PWM, PID, minisumo, seguidor.<br>
            🟧 <strong style="color:var(--am)">FRANKY</strong> — ESP32. IoT, Blockly, WebServer, telemetría, control remoto.
          </div>
        </div>
        <div class="ob-step" data-step="1" style="display:none">
          <div style="font-size:2rem;text-align:center;margin-bottom:8px">🧪</div>
          <h2 style="text-align:center">El Laboratorio</h2>
          <div style="display:flex;flex-direction:column;gap:5px;font-size:.66rem">
            <div style="background:var(--bg2);padding:6px 10px;border-radius:var(--r);border-left:3px solid var(--cy)"><strong style="color:var(--cy)">Desafío</strong> — objetivos. Presioná 💡 si necesitás una pista.</div>
            <div style="background:var(--bg2);padding:6px 10px;border-radius:var(--r);border-left:3px solid var(--am)"><strong style="color:var(--am)">Hardware</strong> — sensores y motores en tiempo real.</div>
            <div style="background:var(--bg2);padding:6px 10px;border-radius:var(--r);border-left:3px solid var(--t1)"><strong>Código</strong> — ↑ Cargar compila, ▶ Ejecutar corre el programa.</div>
            <div style="background:var(--bg2);padding:6px 10px;border-radius:var(--r);border-left:3px solid var(--pu)"><strong style="color:var(--pu)">Teoría</strong> — punto morado = concepto nuevo desbloqueado.</div>
            <div style="background:var(--bg2);padding:6px 10px;border-radius:var(--r);border-left:3px solid var(--gr)"><strong style="color:var(--gr)">Manual</strong> — funciones, sensores, ejemplos de código.</div>
          </div>
        </div>
        <div class="ob-step" data-step="2" style="display:none">
          <div style="font-size:2rem;text-align:center;margin-bottom:8px">🚀</div>
          <h2 style="text-align:center">Tu primer desafío</h2>
          <p>Empezá con <strong style="color:var(--cy)">Unidad 1</strong> desde la pantalla de inicio.</p>
          <div style="background:var(--bg2);border-radius:var(--r);padding:10px 12px;font-family:var(--fm);font-size:.62rem;color:var(--t1);line-height:1.9">
            1. Seleccioná un desafío en la pantalla de inicio<br>
            2. Leé los objetivos en la pestaña <strong>Desafío</strong><br>
            3. Escribí código en la pestaña <strong>Código</strong><br>
            4. Presioná <strong style="color:var(--cy)">↑ Cargar</strong> y después <strong style="color:var(--cy)">▶ Ejecutar</strong><br>
            5. Si te trabás: presioná <strong>💡</strong> para pistas progresivas
          </div>
          <p style="margin-top:6px;font-size:.62rem;color:var(--gr);text-align:center">Tu progreso se guarda automáticamente.</p>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px">
        <div id="ob-dots" style="display:flex;gap:5px">
          <div class="ob-dot on" data-d="0"></div>
          <div class="ob-dot" data-d="1"></div>
          <div class="ob-dot" data-d="2"></div>
        </div>
        <div style="display:flex;gap:7px">
          <button class="btn" id="ob-back" style="display:none" onclick="A._obBack()">← Atrás</button>
          <button class="btn btn-run" id="ob-next" onclick="A._obNext()">Siguiente →</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ FRANKY WebServer Simulation Panel ══════════════════════ -->
  <!-- Shown when platformId=FRANKY. Simulates the ESP32 web server  -->
  <!-- in a phone frame. Connected to FrankySimulator runtime.       -->
  <div id="franky-panel">
    <div class="fk-header">
      <span class="fk-title">🤖 FRANKY WebServer</span>
      <span class="fk-badge" id="fk-mode-badge">IDLE</span>
      <button class="btn btn-sm" onclick="A.closeFranky()" title="Cerrar">✕</button>
    </div>
    <div class="phone-wrap">
      <div class="phone-frame">
        <div class="phone-notch"></div>
        <!-- Nav bar matching real SPIFFS pages -->
        <div class="wp-nav">
          <button class="wp-nav-btn on" data-wp="gamepad" onclick="A.wpPage('gamepad')">🎮</button>
          <button class="wp-nav-btn"    data-wp="sumo"    onclick="A.wpPage('sumo')">🤖</button>
          <button class="wp-nav-btn"    data-wp="status"  onclick="A.wpPage('status')">📊</button>
          <button class="wp-nav-btn"    data-wp="led"     onclick="A.wpPage('led')">💡</button>
          <button class="wp-nav-btn"    data-wp="bloques" onclick="A.wpPage('bloques')">🧩</button>
        </div>
        <div class="phone-screen" id="phone-screen">

          <!-- Gamepad page — mirrors gamepad.html -->
          <div class="wp-page on" id="wp-gamepad">
            <div class="wp-section">
              <div class="wp-label">Control de Movimiento</div>
              <div class="wp-dpad">
                <div class="wp-dpad-empty"></div>
                <div class="wp-dpad-btn" id="dpad-f" ontouchstart="A.fkMove('f')" ontouchend="A.fkStop()" onmousedown="A.fkMove('f')" onmouseup="A.fkStop()">▲</div>
                <div class="wp-dpad-empty"></div>
                <div class="wp-dpad-btn" id="dpad-l" ontouchstart="A.fkMove('l')" ontouchend="A.fkStop()" onmousedown="A.fkMove('l')" onmouseup="A.fkStop()">◀</div>
                <div class="wp-dpad-btn" id="dpad-s" onmousedown="A.fkStop()">■</div>
                <div class="wp-dpad-btn" id="dpad-r" ontouchstart="A.fkMove('r')" ontouchend="A.fkStop()" onmousedown="A.fkMove('r')" onmouseup="A.fkStop()">▶</div>
                <div class="wp-dpad-empty"></div>
                <div class="wp-dpad-btn" id="dpad-b" ontouchstart="A.fkMove('b')" ontouchend="A.fkStop()" onmousedown="A.fkMove('b')" onmouseup="A.fkStop()">▼</div>
                <div class="wp-dpad-empty"></div>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Velocidad</div>
              <div class="wp-row">
                <input type="range" min="50" max="255" value="200" id="fk-spd" style="flex:1;accent-color:var(--cy)" oninput="A.fkSpeed(this.value)">
                <span id="fk-spd-lbl" style="font-family:var(--fm);font-size:.6rem;color:var(--t1);min-width:28px">200</span>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Motor Status</div>
              <div class="wp-row">
                <div style="flex:1"><div class="wp-stat-lbl">Motor A</div><div class="wp-stat-val" id="fk-ma-val">0</div></div>
                <div style="flex:1"><div class="wp-stat-lbl">Motor B</div><div class="wp-stat-val" id="fk-mb-val">0</div></div>
              </div>
            </div>
          </div>

          <!-- Sumo page — mirrors sumo.html -->
          <div class="wp-page" id="wp-sumo">
            <div class="wp-section">
              <div class="wp-label">Microsumo</div>
              <div class="wp-row">
                <button class="wp-btn primary" onclick="A.fkReq('POST','/sumo/micro')">▶ INICIAR</button>
                <button class="wp-btn danger"  onclick="A.fkReq('POST','/sumo/stop')">■ STOP</button>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Minisumo</div>
              <div class="wp-row">
                <button class="wp-btn primary" onclick="A.fkReq('POST','/sumo/mini')">▶ INICIAR</button>
                <button class="wp-btn danger"  onclick="A.fkReq('POST','/sumo/stop')">■ STOP</button>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Fase activa: <span id="sumo-phase-lbl" style="color:var(--cy);font-family:var(--fm)">IDLE</span></div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Trim ATAQUE — Motor A y B (avanzar recto)</div>
              <div style="display:flex;flex-direction:column;gap:3px">
                <div class="wp-row"><span style="font-family:var(--fm);font-size:.5rem;color:var(--cy);min-width:16px">A</span><input type="range" min="50" max="255" value="255" id="fk-atk-a" style="flex:1;accent-color:var(--cy)" oninput="A.fkSumoConfig()"><span id="fk-atk-a-lbl" style="font-family:var(--fm);font-size:.52rem;color:var(--t1);min-width:24px">255</span></div>
                <div class="wp-row"><span style="font-family:var(--fm);font-size:.5rem;color:var(--cy);min-width:16px">B</span><input type="range" min="50" max="255" value="255" id="fk-atk-b" style="flex:1;accent-color:var(--cy)" oninput="A.fkSumoConfig()"><span id="fk-atk-b-lbl" style="font-family:var(--fm);font-size:.52rem;color:var(--t1);min-width:24px">255</span></div>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Trim BÚSQUEDA — Motor A y B (giro de barrido)</div>
              <div style="display:flex;flex-direction:column;gap:3px">
                <div class="wp-row"><span style="font-family:var(--fm);font-size:.5rem;color:var(--am);min-width:16px">A</span><input type="range" min="50" max="255" value="160" id="fk-srch-a" style="flex:1;accent-color:var(--am)" oninput="A.fkSumoConfig()"><span id="fk-srch-a-lbl" style="font-family:var(--fm);font-size:.52rem;color:var(--t1);min-width:24px">160</span></div>
                <div class="wp-row"><span style="font-family:var(--fm);font-size:.5rem;color:var(--am);min-width:16px">B</span><input type="range" min="50" max="255" value="160" id="fk-srch-b" style="flex:1;accent-color:var(--am)" oninput="A.fkSumoConfig()"><span id="fk-srch-b-lbl" style="font-family:var(--fm);font-size:.52rem;color:var(--t1);min-width:24px">160</span></div>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">Umbrales de Detección</div>
              <div style="display:flex;flex-direction:column;gap:4px;margin-top:2px">
                <div class="wp-row" style="gap:4px">
                  <span style="font-family:var(--fm);font-size:.48rem;color:var(--t2);min-width:60px">QTR Borde</span>
                  <input type="range" min="500" max="4095" value="2700" id="fk-thr-borde" style="flex:1;accent-color:var(--re)" oninput="A.fkSumoConfig()">
                  <span id="fk-thr-borde-lbl" style="font-family:var(--fm);font-size:.5rem;color:var(--re);min-width:34px">2700</span>
                </div>
                <div class="wp-row" style="gap:4px">
                  <span style="font-family:var(--fm);font-size:.48rem;color:var(--t2);min-width:60px">IR Ataque</span>
                  <input type="range" min="50" max="4095" value="400" id="fk-thr-atk" style="flex:1;accent-color:var(--gr)" oninput="A.fkSumoConfig()">
                  <span id="fk-thr-atk-lbl" style="font-family:var(--fm);font-size:.5rem;color:var(--gr);min-width:34px">400</span>
                </div>
              </div>
            </div>
            <!-- Keep legacy trim for FrankySimulator compatibility -->
            <input type="hidden" id="fk-trim-a" value="255">
            <input type="hidden" id="fk-trim-b" value="255">
          </div>

          <!-- Status page — mirrors /api data -->
          <div class="wp-page" id="wp-status">
            <div class="wp-section">
              <div class="wp-label">Estado del Robot</div>
              <div class="wp-stat-grid">
                <div class="wp-stat"><div class="wp-stat-lbl">ADC0</div><div class="wp-stat-val" id="fk-a0">—</div></div>
                <div class="wp-stat"><div class="wp-stat-lbl">ADC1</div><div class="wp-stat-val" id="fk-a1">—</div></div>
                <div class="wp-stat"><div class="wp-stat-lbl">Temp</div><div class="wp-stat-val" id="fk-temp">—°C</div></div>
                <div class="wp-stat"><div class="wp-stat-lbl">Hum</div><div class="wp-stat-val" id="fk-hum">—%</div></div>
                <div class="wp-stat"><div class="wp-stat-lbl">PWM A</div><div class="wp-stat-val" id="fk-pwma">0</div></div>
                <div class="wp-stat"><div class="wp-stat-lbl">PWM B</div><div class="wp-stat-val" id="fk-pwmb">0</div></div>
              </div>
              <div id="fk-mode-status" class="wp-badge mode-idle" style="margin-top:6px">MODO: IDLE</div>
            </div>
            <div class="wp-section">
              <div class="wp-label">WiFi</div>
              <div style="font-family:var(--fm);font-size:.57rem;color:var(--t1)">
                <div>SSID: <span id="fk-ssid" style="color:var(--cy)">FRANKY-SIM</span></div>
                <div>IP: <span id="fk-ip" style="color:var(--cy)">192.168.4.1</span></div>
              </div>
            </div>
            <div class="wp-section">
              <div class="wp-label">API Log (últimas 5)</div>
              <div class="wp-log" id="fk-log"></div>
            </div>
          </div>

          <!-- LED control -->
          <div class="wp-page" id="wp-led">
            <div class="wp-section">
              <div class="wp-label">LED Onboard (GPIO8)</div>
              <div class="wp-row">
                <button class="wp-btn primary" onclick="A.fkReq('POST','/led/on')">ON</button>
                <button class="wp-btn danger"  onclick="A.fkReq('POST','/led/off')">OFF</button>
              </div>
              <div class="wp-row" style="margin-top:6px">
                <span style="font-family:var(--fm);font-size:.5rem;color:var(--t2)">Brillo</span>
                <input type="range" min="0" max="255" value="128" id="fk-led-brillo" style="flex:1;accent-color:var(--am)" oninput="A.fkReq('POST','/led/brillo',{val:this.value})">
              </div>
            </div>
          </div>

          <!-- Bloques page — Real Blockly workspace -->
          <div class="wp-page" id="wp-bloques" style="flex-direction:column;padding:0">
            <div style="display:flex;align-items:center;gap:4px;padding:5px 7px;background:var(--bg2);border-bottom:1px solid var(--ln);flex-shrink:0">
              <button class="wp-btn primary" style="flex:1;padding:5px" onclick="A.fkBloquesRun()">▶ Ejecutar</button>
              <button class="wp-btn danger"  style="flex:1;padding:5px" onclick="A.fkReq('POST','/bloques/stop')">■ Stop</button>
              <button class="wp-btn warn"    style="flex:1;padding:5px" onclick="A.fkBloquesClear()">🗑 Limpiar</button>
            </div>
            <!-- Blockly workspace container -->
            <div id="bly-div" style="flex:1;min-height:0;width:100%;position:relative;background:#0d1220">
              <div id="bly-loading" style="display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:8px">
                <div style="font-family:var(--fm);font-size:.55rem;color:var(--t2)">Cargando Blockly…</div>
                <div style="width:80px;height:2px;background:var(--ln);border-radius:2px;overflow:hidden"><div id="bly-load-bar" style="width:0;height:100%;background:var(--cy);transition:width .3s"></div></div>
              </div>
            </div>
            <!-- Instruction count -->
            <div style="padding:4px 8px;background:var(--bg2);border-top:1px solid var(--ln);flex-shrink:0;display:flex;align-items:center;gap:6px">
              <span id="fk-blk-count" style="font-family:var(--fm);font-size:.5rem;color:var(--t2)">0 bloques</span>
              <span id="fk-prog-list" style="font-family:var(--fm);font-size:.48rem;color:var(--t2);flex:1;text-align:right"></span>
            </div>
          </div>

        </div><!-- phone-screen -->
      </div><!-- phone-frame -->
    </div><!-- phone-wrap -->
  </div><!-- franky-panel -->

  <!-- Blockly fullscreen workspace — activates when tab Bloques is selected -->
  <!-- Positioned over the left (canvas) area of the lab, not over the panel -->
  <div id="bly-fullscreen" style="display:none;position:fixed;left:0;top:var(--header-h);bottom:0;right:var(--panel-w);background:var(--bg1);border-right:1px solid var(--ln);flex-direction:column;z-index:45">
    <div style="height:36px;flex-shrink:0;background:var(--bg2);border-bottom:1px solid var(--ln);display:flex;align-items:center;gap:8px;padding:0 10px">
      <span style="font-family:var(--fm);font-size:.62rem;font-weight:700;color:var(--cy)">🧩 Bloques FRANKY</span>
      <button class="btn btn-run btn-sm" onclick="A._bloquesRunFS()">▶ Ejecutar</button>
      <button class="btn btn-sm" onclick="A.fkBloquesClear()">🗑 Limpiar</button>
      <span id="bly-fs-count" style="font-family:var(--fm);font-size:.5rem;color:var(--t2);margin-left:4px">0 bloques</span>
      <span id="bly-active-op" style="font-family:var(--fm);font-size:.5rem;color:var(--am);margin-left:8px;min-width:80px"></span>
      <div style="flex:1"></div>
      <button class="btn btn-sm" onclick="A._closeBlyFS()">✕ Cerrar</button>
      <button class="btn btn-sm" id="bly-code-btn" onclick="A._toggleBlyCode()" title="Ver código C++ equivalente" style="display:none">{} C++</button>
    </div>
    <!-- C++ equivalent panel (hidden by default, shown when workspace has blocks) -->
    <div id="bly-code-panel" style="display:none;position:absolute;bottom:0;left:0;right:0;background:var(--bg0);border-top:1px solid var(--ln);padding:8px 12px;max-height:160px;overflow-y:auto;z-index:10">
      <div style="font-family:var(--fm);font-size:.48rem;letter-spacing:.08em;text-transform:uppercase;color:var(--cy);margin-bottom:5px">Código C++ equivalente (solo referencia)</div>
      <pre id="bly-code-text" style="font-family:var(--fm);font-size:.58rem;color:var(--t1);white-space:pre-wrap;margin:0;line-height:1.7"></pre>
    </div>
    <div id="bly-fs-workspace" style="flex:1;min-height:0;background:#0d1220;position:relative"></div>
  </div>

  <div class="view" id="v-lab">
    <div class="cv-w">
      <div id="oled-hud">
        <div id="oled-hud-title">OLED · SSD1306 128×64</div>
        <div id="oled-hud-lines"></div>
      </div>
      <canvas id="cvs"></canvas>
      <div class="ov ov-lbl" id="scene-lbl">ARENA · ROBOARD</div>
      <div class="ov" id="shud">
        <div class="hi"><span class="hl" id="h0-lbl">A0 Sharp</span><span class="hv" id="hv0" style="color:var(--am)">—</span><div class="hb"><div class="hbf" id="hb0" style="background:var(--am)"></div></div></div>
        <div class="hi"><span class="hl" id="h1-lbl">A1 Lat</span><span class="hv" id="hv1" style="color:var(--t1)">—</span><div class="hb"><div class="hbf" id="hb1" style="background:var(--t1)"></div></div></div>
        <div class="hi"><span class="hl">t.sim</span><span class="hv" id="hvt" style="color:var(--t2);font-size:.7rem">0ms</span></div>
      <div class="hi" id="qtr8-bar" style="display:none"></div>
      </div>
      <div class="ov" id="vstrip"></div>
      <div class="ov" id="tms"></div>
      <div class="ov" id="terr"></div>
    </div>
    <div id="rp">
      <div id="ptabs">
        <div class="ptab on" data-p="ch">Desafío</div>
        <div class="ptab"    data-p="hw">Hardware</div>
        <div class="ptab"    data-p="co">Código</div>
        <div class="ptab"    data-p="th">Teoría <div class="th-dot" id="thdot"></div></div>
        <div class="ptab"    data-p="mn">Manual</div>
      </div>
      <div class="pp on" id="pp-ch">
        <div class="ch-nm" id="ch-nm">—</div>
        <div class="ch-ds" id="ch-ds"></div>
        <div class="ch-prog"><span class="ch-pl">Progreso</span><div class="ch-pb"><div class="ch-pf" id="ch-pf" style="width:0"></div></div><span class="ch-pn" id="ch-pn">0/0</span></div>
        <div class="sep"></div>
        <div class="ol" id="ol"></div>
        <div class="hint-box" id="hbox"></div>
      </div>
      <div class="pp" id="pp-hw">
        <div class="motors">
          <div class="mc"><div class="mc-t">MOTOR A — Izquierdo</div><div class="mc-d dc-o" id="mAd">—</div><div class="mc-bar"><div class="mc-fl" id="mAb"></div></div><div class="mc-pw">PWM <span id="mAp">0</span></div></div>
          <div class="mc"><div class="mc-t">MOTOR B — Derecho</div><div class="mc-d dc-o" id="mBd">—</div><div class="mc-bar"><div class="mc-fl" id="mBb"></div></div><div class="mc-pw">PWM <span id="mBp">0</span></div></div>
        </div>
        <div class="sep"></div>
        <div class="sparks">
          <div class="sp-r"><span class="sp-l">A0 Sharp</span><canvas class="sp-c" id="sp0" height="24"></canvas><span class="sp-v" id="spv0">—</span></div>
          <div class="sp-r"><span class="sp-l">Motor A</span><canvas class="sp-c" id="spA" height="24"></canvas><span class="sp-v" id="spvA">—</span></div>
          <div class="sp-r"><span class="sp-l">Motor B</span><canvas class="sp-c" id="spB" height="24"></canvas><span class="sp-v" id="spvB">—</span></div>
        </div>
        <div class="sep"></div>
        <div class="gpio" id="gpio"></div>
      </div>
      <div class="pp" id="pp-co">
        <div id="vbar"><span style="color:var(--t2)">Cargá un sketch para validar</span></div>
        <div class="ed-outer"><div class="lnums" id="lnums">1</div><textarea id="ced" spellcheck="false"></textarea></div>
        <div class="ed-bar"><span id="clbl"></span><button class="btn btn-sm" id="btn-load">↑ Cargar</button></div>
        <!-- Motor mini overlay — shown during execution so the student sees code→motor causality -->
        <div id="motor-mini" style="display:none;position:absolute;bottom:164px;right:10px;background:rgba(9,13,22,.96);border:1px solid rgba(0,205,179,.3);border-radius:4px;padding:5px 9px;font-family:var(--fm);font-size:.5rem;z-index:5;pointer-events:none;line-height:1.7">
          <div style="color:var(--t2);font-size:.44rem;margin-bottom:2px;letter-spacing:.07em;text-transform:uppercase">Motores</div>
          <div>A: <span id="mm-a" style="color:var(--t2)">—</span></div>
          <div>B: <span id="mm-b" style="color:var(--t2)">—</span></div>
        </div>
        <div class="ser-w"><div class="ser-hd"><div class="s-dot" id="sdot"></div>Serial Monitor<button class="btn btn-sm" id="console-mode-btn" onclick="A._toggleConsoleMode()" style="margin-left:6px;font-size:.46rem;padding:2px 6px;opacity:.55" title="Alternar modo: alumno / debug">debug</button><button class="btn btn-sm" onclick="A.clrS()" style="margin-left:auto">CLR</button></div><div id="sout"><span class="sl-s">// Console listo</span></div></div>
      </div>
      <div class="pp" id="pp-th">
        <div class="th-em" id="th-em">Los conceptos aparecerán aquí conforme avanzás en el laboratorio.</div>
        <div class="th-tt" id="th-tt" style="display:none"></div>
        <div class="sep"   id="th-sp" style="display:none"></div>
        <div class="th-bo" id="th-bo" style="display:none"></div>
        <div class="sep"   id="th-s2" style="display:none"></div>
        <div class="th-nv" id="th-nv" style="display:none"><span class="th-cn" id="th-cn"></span><button class="btn btn-sm" onclick="A.nextTh()">Siguiente →</button></div>
      </div>

      <!-- Manual tab — inline reference guide -->
      <div class="pp" id="pp-mn" style="overflow-y:auto;padding:14px 13px 24px;gap:10px;font-size:.72rem;line-height:1.75;color:var(--t0)">
        <div style="font-family:var(--fm);font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:var(--cy);padding-bottom:6px;border-bottom:1px solid var(--ln)">GUÍA DIDÁCTICA INTEGRADA</div>
        <div id="manual-content" style="display:flex;flex-direction:column;gap:8px"></div>
      </div>
    </div>
  </div>
</div>

<script src="robolab.bundle.js"></script>
<script>
'use strict';
(function(){

// ══════════════════════════════════════════════════════════════
// GUARD: ensure bundle loaded
// ══════════════════════════════════════════════════════════════
const RL = window.RoboLab;
if (!RL || typeof RL.EcosystemAssembler !== 'function') {
  document.getElementById('ldm').textContent =
    '✗ Error: robolab.bundle.js no encontrado o incompleto. ' +
    'Abrí index.html junto a robolab.bundle.js en la misma carpeta.';
  return;
}

// ── Loading helpers ────────────────────────────────────────────
const $ = id => document.getElementById(id);
window.$ = $;  // expose to inline onclick handlers
function ld(p, m) { $('ldf').style.width=p+'%'; $('ldm').textContent=m; }
function errorsToString(errors) {
  if (!Array.isArray(errors)) return String(errors || 'Error desconocido');
  return errors.map(function(e) {
    if (typeof e === 'string') return e;
    return e.message || e.msg || JSON.stringify(e);
  }).join('; ');
}


// ══════════════════════════════════════════════════════════════
// ECOSYSTEM ASSEMBLY
// All content loaded before any UI interaction is possible.
// ══════════════════════════════════════════════════════════════
ld(10, 'Creando ecosistema…');

const eco = RL.EcosystemAssembler.create('ROBOARD', {
  storage: typeof indexedDB !== 'undefined'
    ? new RL.IndexedDBStorage('robolab', 1)
    : new RL.MemoryStorage(),
});
eco.start();

ld(30, 'Cargando contenido base…');
eco.loadContent(
  RL.ROBOARD_SCENARIOS   || [],
  RL.ROBOARD_CHALLENGES  || [],
  RL.UNIT_1 ? [RL.UNIT_1] : [],
  RL.ROBOARD_THEORY      || [],
);

ld(50, 'Cargando curriculum U1–U3…');
eco.loadContent(
  [],
  RL.CURRICULUM_CHALLENGES || [],
  RL.CURRICULUM_LESSONS    || [],
  RL.EXTENDED_THEORY       || [],
);

ld(65, 'Cargando LNR…');
eco.loadContent(RL.LNR_SCENARIOS || [], RL.LNR_CHALLENGES || [], []);

ld(70, 'Cargando FRANKY…');
eco.loadContent([], RL.ALL_FRANKY_CHALLENGES || [], RL.ALL_FRANKY_LESSONS || [], RL.FRANKY_THEORY || []);

ld(75, 'Inicializando hardware virtual…');

// ══════════════════════════════════════════════════════════════
// PHYSICS GUARD
// eco.physics.robot is the canonical robot state object.
// eco.physics.r does NOT exist — DifferentialDrive uses .robot
// All code uses R() helper which is safe.
// ══════════════════════════════════════════════════════════════
function R() {
  // Safe robot accessor — always returns a valid object
  if (!eco || !eco.physics) return {x:0,y:0,angle:0,vL:0,vR:0,trail:[]};
  return eco.physics.robot || {x:0,y:0,angle:0,vL:0,vR:0,trail:[]};
}

// ── Canvas ─────────────────────────────────────────────────────
const cvs = $('cvs');
const ctx  = cvs.getContext('2d');
const rng  = new RL.SeededRNG(42);

function resize() {
  const w = cvs.parentElement;
  if (!w) return;
  cvs.width  = w.clientWidth  || 800;
  cvs.height = w.clientHeight || 500;
  eco.physics.cw = cvs.width;
  eco.physics.ch = cvs.height;
}

// ══════════════════════════════════════════════════════════════
// CHALLENGE DATABASE
// Single source of truth for all known challenges.
// Merges: base ROBOARD + curriculum U1-U3 + LNR
// ══════════════════════════════════════════════════════════════
function buildChallengeDB() {
  const db = new Map();
  const add = (arr) => { if (Array.isArray(arr)) arr.forEach(c => c && c.id && db.set(c.id, c)); };
  add(RL.ROBOARD_CHALLENGES);
  add(RL.CURRICULUM_CHALLENGES);
  add(RL.LNR_CHALLENGES);
  add(RL.ALL_FRANKY_CHALLENGES);
  return db;
}
// ══════════════════════════════════════════════════════════════
// SYNTHETIC CHALLENGE SYSTEM — Etapa 0 "Primeros Pasos"
// Challenges that live entirely in index.html without bundle support.
// Objectives are evaluated from SIM_TICK variables each tick.
// Rollback: delete this block + remove u0-* from UNITS[0].ks
// ══════════════════════════════════════════════════════════════

const SYNTHETIC_CHALLENGES = {};

// ── _synthValidate: evaluate objectives each tick ────────────────
// allReqDone triggers CHALLENGE_COMPLETED via eventBus.
// MIN_OBS_TICKS: prevent instant-complete — student must observe at least N ticks.
const SYNTH_MIN_OBS_TICKS = 5;  // ~80ms at 60fps — just enough to see the change

function _synthValidate(vars) {
  const ch = SYNTHETIC_CHALLENGES[S.cid];
  if (!ch || !ch.validate || !S._synthState) return;
  const result = ch.validate(vars, S._synthState._flags || {});
  if (!result) return;
  let anyChanged = false, allReqDone = true;
  S._synthState.objectives.forEach(function(obj) {
    const nowDone = !!result[obj.id];
    if (nowDone && !obj.completed) { obj.completed = true; anyChanged = true; }
    if (obj.required && !obj.completed) allReqDone = false;
  });
  if (anyChanged) { renderObjs(); }
  if (allReqDone) {
    // Enforce minimum observation ticks before completion modal
    S._synthState._reqDoneSince = S._synthState._reqDoneSince || 0;
    S._synthState._reqDoneSince++;
    if (S._synthState._reqDoneSince >= SYNTH_MIN_OBS_TICKS && !S._synthState._completed) {
      S._synthState._completed = true;
      _synthSaveProgress();
      eco.eventBus.emit({ type: 'CHALLENGE_COMPLETED', payload: { challengeId: S.cid } }, 'SYNTHETIC');
    }
  }
}

function _synthSaveProgress() {
  if (!S._synthState) return;
  const req  = S._synthState.objectives.filter(function(o){ return o.required; });
  const done = req.filter(function(o){ return o.completed; });
  if (done.length === req.length && req.length > 0) {
    const ui = UNIT_CHS[S.cid];
    if (ui !== undefined) {
      const key  = 'prog:u:' + ui;
      const prev = JSON.parse(lsGet(key) || '{}');
      prev[S.cid] = true;
      lsSet(key, JSON.stringify(prev));
    }
  }
}

function _synthFlag(name, value) {
  if (!S._synthState) return;
  S._synthState._flags = S._synthState._flags || {};
  if (value) S._synthState._flags[name] = true;
  return !!S._synthState._flags[name];
}

// ──────────────────────────────────────────────────────────────────
// U0.1 — LED Onboard
// ROBOARD: D10 (anode+cathode, single color)
// FRANKY:  GPIO8 (lógica invertida — LOW = encendido)
// Pedagogía: el alumno debe ESCRIBIR el código (TODO), ejecutar,
// observar el LED en el canvas, y luego hacer parpadear.
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-led-blink'] = {
  id: 'u0-led-blink',
  name: 'U0.1 — LED Onboard',
  description: 'Encendé el LED del robot con código. Solo hay una función: digitalWrite(pin, estado). Tu tarea es encontrar el pin correcto y el estado correcto.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  // Peripheral overlay: show the LED on canvas as a component
  periph: { showBtn:false, showDip:false, showOled:false,
    extLeds:[{pin:'D10',color:'#18cc60'}] },
  sketch:
`// ━━━ U0.1 — LED Onboard ━━━
// La ROBOARD tiene un LED conectado al pin D10 (ánodo/cátodo).
// Para encenderlo: el pin debe estar en HIGH.
// Para apagarlo:  el pin debe estar en LOW.
//
// Funciones que necesitás:
//   pinMode(pin, modo)       → configura el pin (OUTPUT o INPUT)
//   digitalWrite(pin, valor) → escribe HIGH o LOW en el pin

void setup() {
  Serial.begin(9600);

  // TODO 1: Configurá D10 como OUTPUT usando pinMode()
  // Escribí tu código aquí:


  Serial.println("Setup listo");
}

void loop() {
  // TODO 2: Encendé el LED (D10 = HIGH)
  // Escribí tu código aquí:

  Serial.println("LED encendido?");
  delay(500);

  // TODO 3: Apagá el LED (D10 = LOW)
  // Escribí tu código aquí:

  Serial.println("LED apagado?");
  delay(500);
}`,
  objectives: [
    { id: 'obj-pin-config', label: 'Configurar D10 como OUTPUT (pinMode)', required: true },
    { id: 'obj-led-on',     label: 'Encender el LED (D10=HIGH visible en el canvas)', required: true },
    { id: 'obj-led-off',    label: 'Apagar el LED (D10=LOW)', required: true },
    { id: 'obj-led-blink',  label: 'Hacer parpadear el LED (ON ↔ OFF ≥ 3 veces)', required: false },
  ],
  validate: function(vars, flags) {
    // Track LED transitions
    if (vars.led_on)  _synthFlag('led_on_seen',  true);
    if (!vars.led_on && flags.led_on_seen) _synthFlag('led_off_seen', true);
    // Count blinks (complete ON→OFF cycles)
    if (vars.led_on && !flags._led_was_on)  { _synthFlag('_led_was_on',  true); S._synthState._flags._led_was_on=true; }
    if (!vars.led_on && flags._led_was_on)  {
      S._synthState._flags._blink_count = (S._synthState._flags._blink_count||0)+1;
      S._synthState._flags._led_was_on = false;
    }
    // pin_config: D10 must have been set HIGH at some point (implies pinMode was called)
    // We infer it from led_on_seen (HAL requires pin in output mode for the value to stick)
    return {
      'obj-pin-config': !!(flags.led_on_seen),
      'obj-led-on':     !!(flags.led_on_seen),
      'obj-led-off':    !!(flags.led_off_seen),
      'obj-led-blink':  (S._synthState?._flags?._blink_count||0) >= 3,
    };
  },
};

// ──────────────────────────────────────────────────────────────────
// U0.2 — LEDs Externos (GPIO como salidas múltiples)
// ROBOARD: LEDs en A0, A1, A2 (pines analógicos usados como digital output)
// Pedagogía: múltiples salidas, secuencia temporal, GPIO general
// ──────────────────────────────────────────────────────────────────
SYNTHETIC_CHALLENGES['u0-leds-externos'] = {
  id: 'u0-leds-externos',
  name: 'U0.2 — LEDs Externos: Secuencia',
  description: 'La placa tiene GPIO libres (A0-A5) donde podés conectar LEDs externos con resistencia. Controlá 3 LEDs y creá secuencias de encendido.',
  platformId: 'ROBOARD', interactionMode: 'codigo',
  scenarioId: 'single-obstacle',
  // Show 3 external LEDs on canvas (A0=verde, A1=azul, A2=rojo)
  periph: { showBtn:false, showDip:false, showOled:false,
    extLeds:[
      {pin:'A0',color:'#18cc60'},
      {pin:'A1',color:'#3878ec'},
      {pin:'A2',color:'#f02840'},
    ]
  },
  sketch:
`// ━━━ U0.2 — LEDs Externos ━━━
// La ROBOARD tiene pines GPIO libres: A0, A1, A2 (entre otros).
// Aunque se llaman "analógicos", se pueden usar como salidas digitales
// con pinMode(A0, OUTPUT) y digitalWrite(A0, HIGH/LOW).
//
// Conexión recomendada:
//   LED verde  → A0 (con resistencia 220Ω a GND)
//   LED azul   → A1 (con resistencia 220Ω a GND)
//   LED rojo   → A2 (con resistencia 220Ω a GND)
//
// Los LEDs aparecen en el canvas cuando el pin está en HIGH.

#define LED_VERDE  A0
#define LED_AZUL   A1
#define LED_ROJO   A2

void setup() {
  Serial.begin(9600);

  // TODO 1: Configurá los 3 pines como OUTPUT
  // pinMode(LED_VERDE, OUTPUT);   ← descomentá y completá para A1 y A2


}

void loop() {
  // TODO 2: Encendé LED_VERDE, esperá 300ms, apagalo
  // Tip: digitalWrite(LED_VERDE, HIGH); delay(300); digitalWrite(LED_VERDE, LOW);


  // TODO 3: Encendé LED_AZUL, esperá 300ms, apagalo


  // TODO 4: Encendé LED_ROJO, esperá 300ms, apagalo


  // TODO 5 (opcional): Encendé los 3 juntos 500ms, apagalos todos
  // ¿Podés crear un patrón diferente? Experimentá con los tiempos.

}`,
  objectives: [
    { id: 'obj-led1-on',  label: 'Encender LED verde (A0=HIGH visible en canvas)', required: true },
    { id: 'obj-led2-on',  label: 'Encender LED azul (A1=HIGH visible en canvas)', required: true },
    { id: 'obj-led3-on',  label: 'Encender LED rojo (A2=HIGH visible en canvas)', required: true },
    { id: 'obj-seq',      label: 'Secuencia: los 3 LEDs se encienden en orden', required: true },
    { id: 'obj-pattern',  label: 'Crear un patrón propio (experimentar con tiempos)', required: false },
  ],
  validate: function(vars, flags) {
    // Read A0, A1, A2 from HAL as digital outputs
    const pins = (typeof eco !== 'undefined') ? eco.hal.getAllPins() : {};
    const a0on = !!(pins['A0']?.value);
    const a1on = !!(pins['A1']?.value);
    const a2on = !!(pins['A2']?.value);
    if (a0on) _synthFlag('led1_seen', true);
    if (a1on) _synthFlag('led2_seen', true);
    if (a2on) _synthFlag('led3_seen', true);
    // Sequence: all three seen, at least one after another (time > 500ms means loop ran)
    if (flags.led1_seen && flags.led2_seen && flags.led3_seen && vars.sim_time > 600) {
      _synthFlag('seq_done', true);
    }
    // Pattern: different combinations seen (at least 4 different states)
    const state = (a0on?4:0)+(a1on?2:0)+(a2on?1:0);
    S._synthState._flags._states = S._synthState._flags._states || {};
    S._synthState._flags._states[state] = true;
    const stateCount = Object.keys(S._synthState._flags._states||{}).length;
    return {
      'obj-led1-on': !!(flags.led1_seen),
      'obj-led2-on': !!(flags.led2_seen),
      'obj-led3-on': !!(flags.led3_seen),
      'obj-seq':     !!(flags.seq_done),
      'obj-pattern': stateCount >= 4,
    };
  },
};

